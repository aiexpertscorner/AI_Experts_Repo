# ============================================================
# AIExpertsCorner — .env.example
# Copy to .env and fill in real values.
# .env is gitignored — NEVER commit real keys.
# ============================================================

# ── Site ─────────────────────────────────────────────────────
PUBLIC_SITE_URL=https://aiexpertscorner.com
PUBLIC_SITE_NAME=AIExpertsCorner

# ── Logo provider (logo.dev) ──────────────────────────────────
# Used in pipeline fix-logos.mjs to generate logo-map.json.
# The token appears in logo URLs — do NOT use as a secret in
# client-side code. Keep here for pipeline use only.
LOGO_DEV_TOKEN=pk_your_token_here

# ── AI APIs — pipeline only (never in Astro frontend) ────────
# Used by enrich-tools-v6.mjs and 04c-deep-content-engine.mjs
ANTHROPIC_API_KEY=AIzaSyA9bgswHFFo5qbyaasGpcOx
OPENAI_API_KEY=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
GEMINI_API_KEY=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

# ── Pipeline build limits ─────────────────────────────────────
# Set these in Cloudflare Pages environment variables too.
TOOL_PAGE_LIMIT=19000
COMPARE_PAGE_LIMIT=5000
ALT_PAGE_LIMIT=19000

# ── Cloudflare (optional, for wrangler CLI) ───────────────────
# CLOUDFLARE_ACCOUNT_ID=your_account_id
# CLOUDFLARE_API_TOKEN=your_token_here

# ── Node build config ─────────────────────────────────────────
NODE_OPTIONS=--max-old-space-size=8192