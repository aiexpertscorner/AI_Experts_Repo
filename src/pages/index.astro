---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/site/Header.astro";
import Footer from "@/components/site/Footer.astro";
import HeroSection from "@/components/sections/HeroSection.astro";
import FlagshipToolsSection from "@/components/sections/FlagshipToolsSection.astro";
import CategoryDiscoverySection from "@/components/sections/CategoryDiscoverySection.astro";
import PopularToolsSection from "@/components/sections/PopularToolsSection.astro";
import BestOfSection from "@/components/sections/BestOfSection.astro";
import HomeEditorialSection from "@/components/sections/HomeEditorialSection.astro";
import NewsletterSection from "@/components/sections/NewsletterSection.astro";
import "@/styles/homepage.css";

import categoryMap from "@/data/build/category-map.json";
import featuredData from "@/data/build/featured-tools.json";
import homepageData from "@/data/build/homepage-data.json";

const allTools = (featuredData as any)?.global_top ?? [];
const categoryFeaturedMap = (featuredData as any)?.by_category ?? {};
const newTools = (homepageData as any)?.new_tools ?? [];
const totalToolsCount = Number((homepageData as any)?.total_tools ?? 19088);
const totalCatsCount = Number((homepageData as any)?.total_cats ?? Object.keys(categoryMap as any).length ?? 15);
const totalCompareCount = Number((homepageData as any)?.total_compare ?? 0);
const totalBestOfCount = Number((homepageData as any)?.total_bestof ?? 0);

const categories = Object.values((categoryMap as any) ?? {})
  .sort((a: any, b: any) => b.count - a.count)
  .slice(0, 8)
  .map((category: any) => ({
    ...category,
    top_tools: categoryFeaturedMap[category.slug] ?? category.tools?.slice(0, 3) ?? [],
  }));

const trustedBrands = ["OpenAI", "Anthropic", "Google AI", "Microsoft", "NVIDIA", "Meta AI"];

const bestOfLinks = [
  { label: "Best AI tools for blog writing", href: "/best/write-blog-posts-and-articles-with-ai" },
  { label: "Best AI tools for chatbots", href: "/best/build-ai-chatbots-and-assistants-with" },
  { label: "Best AI tools for image generation", href: "/ai-tools/category/ai-image-generation" },
  { label: "Best AI coding tools", href: "/ai-tools/category/ai-coding" },
  { label: "Best AI tools for SEO", href: "/ai-tools/tag/seo-and-keywords" },
  { label: "Best AI tools for video creation", href: "/ai-tools/category/ai-video" },
  { label: "Best AI tools for customer support", href: "/ai-tools/category/ai-customer-support" },
  { label: "Best AI tools for data analysis", href: "/ai-tools/category/ai-data-analytics" },
  { label: "Best AI tools for research", href: "/ai-tools/category/ai-research" },
  { label: "Best AI tools for business operations", href: "/ai-tools/category/ai-business-operations" },
  { label: "Best AI tools by use case", href: "/ai-tools/use-case" },
  { label: "Best AI tools by pricing", href: "/ai-tools/pricing/free" },
];

const editorialPosts = [
  { tag: "Guide", title: "Top 10 Must-Have AI Tools in 2026", href: "/ai-news/top-10-ai-tools-2026", excerpt: "A practical shortlist of high-impact AI tools for builders, marketers and teams." },
  { tag: "Workflow", title: "How to Build Better AI Workflows for Marketing and Automation", href: "/ai-news/ai-workflows-marketing-automation", excerpt: "A tactical framework for combining prompts, automations and specialized tools." },
  { tag: "Comparison", title: "ChatGPT vs Claude vs Gemini: Which AI Assistant Fits Your Workflow?", href: "/ai-news/chatgpt-vs-claude-vs-gemini", excerpt: "A clean comparison for research, writing, coding and business use cases." },
];

const pageTitle = "AI Tools Directory — Discover the Best AI Tools for Any Workflow";
const pageDescription = `Browse ${totalToolsCount.toLocaleString()}+ AI tools across ${totalCatsCount} categories. Compare pricing, explore alternatives, and discover the best tool for every workflow.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Header slot="header" />

  <main class="home-page">
    <HeroSection totalToolsCount={totalToolsCount} totalCatsCount={totalCatsCount} trustedBrands={trustedBrands} />
    <FlagshipToolsSection tools={allTools} />
    <CategoryDiscoverySection categories={categories} />
    <PopularToolsSection tools={allTools.slice(0, 6)} totalCompareCount={totalCompareCount} totalBestOfCount={totalBestOfCount} />
    <BestOfSection links={bestOfLinks} />
    <PopularToolsSection title="Recently Added Tools" eyebrow="Fresh Additions" description="New tools and product entries added to the directory." tools={newTools.length ? newTools.slice(0, 6) : allTools.slice(6, 12)} ctaHref="/ai-tools" ctaLabel="Browse all tools" compact={true} />
    <HomeEditorialSection posts={editorialPosts} />
    <NewsletterSection />

    <section class="home-block home-block--last">
      <div class="container home-bottom-links">
        <a href="/ai-tools" class="home-bottom-links__item">Browse all AI tools</a>
        <a href="/vs" class="home-bottom-links__item">Compare leading AI tools</a>
        <a href="/best" class="home-bottom-links__item">Explore best-of pages</a>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</BaseLayout>
