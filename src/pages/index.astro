---
import BaseLayout      from "@/layouts/BaseLayout.astro";
import Header          from "@/components/site/Header.astro";
import Footer          from "@/components/site/Footer.astro";
import FlagshipToolsSection   from "@/components/sections/FlagshipToolsSection.astro";
import HubNavSection          from "@/components/sections/HubNavSection.astro";
import CategoryDiscoverySection from "@/components/sections/CategoryDiscoverySection.astro";
import TrendingTopicsSection  from "@/components/sections/TrendingTopicsSection.astro";
import AudienceSection        from "@/components/sections/AudienceSection.astro";
import ToolCard               from "@/components/cards/ToolCard.astro";
import "@/styles/homepage.css";

import catMap       from "@/data/build/category-map.json";
import featuredData from "@/data/build/featured-tools.json";
import homepageData from "@/data/build/homepage-data.json";

// ─── Data ──────────────────────────────────────────────────────────────────
const allTools   = (featuredData as any)?.global_top    ?? [];
const newTools   = (homepageData as any)?.new_tools      ?? [];
const totalTools = (homepageData as any)?.total_tools    ?? 19488;
const totalCats  = 23;

// Categories: sorted by count, with top_tools injected where available
const categoryTopTools: Record<string, any[]> =
  (featuredData as any)?.by_category ?? {};

const categories = Object.values(catMap as any)
  .sort((a: any, b: any) => b.count - a.count)
  .map((c: any) => ({
    ...c,
    top_tools: categoryTopTools[c.slug] ?? [],
  }));

// Trust logos (static editorial — brand recognition anchors)
const trustedBrands = [
  { name: "OpenAI"    },
  { name: "Anthropic" },
  { name: "Google AI" },
  { name: "Microsoft" },
  { name: "NVIDIA"    },
  { name: "Meta AI"   },
];

// Blog posts (editorial — will be data-driven when blog is live)
const blogPosts = [
  { tag: "Guide",      title: "Top 10 Must-Have AI Tools in 2025",          slug: "top-10-ai-tools-2025",        grad: "from-blue"   },
  { tag: "Tutorial",   title: "Mastering Midjourney: The Ultimate Guide",   slug: "mastering-midjourney-guide",  grad: "from-violet" },
  { tag: "Comparison", title: "ChatGPT vs Claude vs Gemini: Full Breakdown",slug: "chatgpt-vs-claude-vs-gemini", grad: "from-cyan"   },
];

// Best-of intent links
const bestOf = [
  ["Writing blog posts",        "/best/write-blog-posts-and-articles-with-ai"],
  ["Building chatbots",         "/best/build-ai-chatbots-and-assistants-with"],
  ["Generating images",         "/ai-tools/category/image-generation"],
  ["Coding & development",      "/ai-tools/category/coding-and-dev"],
  ["Social media content",      "/ai-tools/tag/social-media"],
  ["SEO & keyword research",    "/ai-tools/tag/seo-and-keywords"],
  ["Creating videos",           "/ai-tools/tag/video-creation"],
  ["Data & analytics",          "/ai-tools/category/data-and-analytics"],
  ["Customer support",          "/ai-tools/tag/customer-support"],
  ["HR & recruiting",           "/ai-tools/category/hr-and-recruiting"],
  ["Finance & legal work",      "/ai-tools/category/legal-and-finance"],
  ["Education & research",      "/ai-tools/category/research-and-education"],
] as const;
---
<BaseLayout
  title="AI Tools Directory — Find the Best AI Tools for Any Workflow"
  description={`Browse ${totalTools.toLocaleString()}+ AI tools across ${totalCats} categories. Compare pricing, features and alternatives — all in one place.`}
>
  <Header slot="header"/>

  <!-- ═══════════════════════════════════════════════════════════
       1. HERO
  ════════════════════════════════════════════════════════════ -->
  <section class="hero">

    <!-- Ambient layers -->
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-orb hero-orb-1"></div>
      <div class="hero-orb hero-orb-2"></div>
      <div class="hero-orb hero-orb-3"></div>
      <div class="hero-grid"></div>
    </div>

    <div class="container hero-inner">

      <!-- LEFT ───────────────────────────────── -->
      <div class="hero-left">

        <div class="hero-badge">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          The #1 AI Tools Directory
        </div>

        <h1>
          Discover the Best<br/>
          <span class="text-gradient">AI Tools</span> for Any Workflow
        </h1>

        <p class="hero-sub">
          Browse {totalTools.toLocaleString()}+ AI tools, compare pricing and alternatives,
          and find exactly what you need — for free.
        </p>

        <!-- Search bar (links to /ai-tools) -->
        <a href="/ai-tools" class="hero-search" aria-label="Search AI tools">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <span class="hs-placeholder">Search {totalTools.toLocaleString()}+ AI tools…</span>
          <span class="btn btn-primary hs-cta-btn">Explore Free</span>
        </a>

        <!-- Stats -->
        <div class="hero-stats">
          <div class="hero-stat">
            <strong>{totalTools.toLocaleString()}+</strong>
            <span>AI Tools</span>
          </div>
          <div class="hero-stat-div" aria-hidden="true"></div>
          <div class="hero-stat">
            <strong>{totalCats}</strong>
            <span>Categories</span>
          </div>
          <div class="hero-stat-div" aria-hidden="true"></div>
          <div class="hero-stat">
            <strong>Daily</strong>
            <span>Updated</span>
          </div>
          <div class="hero-stat-div" aria-hidden="true"></div>
          <div class="hero-stat">
            <strong>Free</strong>
            <span>Forever</span>
          </div>
        </div>

        <!-- Trust row -->
        <div class="trust-row">
          <span class="trust-label">Covering tools from</span>
          <div class="trust-logos">
            {trustedBrands.map(b => (
              <span class="trust-chip">{b.name}</span>
            ))}
          </div>
        </div>

      </div><!-- /hero-left -->

      <!-- RIGHT: orbital CSS visual ──────────── -->
      <div class="hero-right" aria-hidden="true">
        <div class="hv-scene">

          <!-- Rings -->
          <div class="hv-core">
            <div class="hv-core-ring hv-ring-1"></div>
            <div class="hv-core-ring hv-ring-2"></div>
            <div class="hv-core-ring hv-ring-3"></div>
            <div class="hv-core-center">
              <img
                src="/logos/Logo_icon_dark.png"
                alt=""
                width="44"
                height="44"
                loading="eager"
                decoding="sync"
              />
            </div>
          </div>

          <!-- Orbiting nodes -->
          <div class="hv-orbit hv-orbit-1">
            <div class="hv-node hv-node-a">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
          </div>
          <div class="hv-orbit hv-orbit-2">
            <div class="hv-node hv-node-b">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
            </div>
          </div>
          <div class="hv-orbit hv-orbit-3">
            <div class="hv-node hv-node-c">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            </div>
          </div>
          <div class="hv-orbit hv-orbit-4">
            <div class="hv-node hv-node-d">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg>
            </div>
          </div>

          <!-- Floating stat cards -->
          <div class="hv-card hv-card-1">
            <span class="hvc-num">{totalTools.toLocaleString()}+</span>
            <span class="hvc-lbl">AI Tools</span>
          </div>
          <div class="hv-card hv-card-2">
            <div class="hvc-row"><span class="hvc-dot" style="background:var(--c-free)"></span><span class="hvc-tag">Free</span></div>
            <div class="hvc-row"><span class="hvc-dot" style="background:var(--c-freemium)"></span><span class="hvc-tag">Freemium</span></div>
            <div class="hvc-row"><span class="hvc-dot" style="background:var(--c-paid)"></span><span class="hvc-tag">Paid</span></div>
          </div>
          <div class="hv-card hv-card-3">
            <span class="hvc-num">{totalCats}</span>
            <span class="hvc-lbl">Categories</span>
          </div>

        </div>
      </div><!-- /hero-right -->

    </div>
  </section><!-- /hero -->

  <!-- ═══════════════════════════════════════════════════════════
       PAGE BODY
  ════════════════════════════════════════════════════════════ -->
  <div class="hp-body">

    <!-- ─────────────────────────────────────────────────────────
         2. TOP MAINSTREAM TOOLS (authority anchor)
    ──────────────────────────────────────────────────────────── -->
    <div class="container hp-section">
      <FlagshipToolsSection tools={allTools}/>
    </div>

    <!-- ─────────────────────────────────────────────────────────
         3. PLATFORM HUBS (main navigation)
    ──────────────────────────────────────────────────────────── -->
    <div class="hp-wide">
      <div class="container hp-section">
        <HubNavSection/>
      </div>
    </div>

    <!-- ─────────────────────────────────────────────────────────
         4. CATEGORY DISCOVERY
    ──────────────────────────────────────────────────────────── -->
    <div class="container hp-section">
      <CategoryDiscoverySection categories={categories as any} limit={9}/>
    </div>

    <!-- ─────────────────────────────────────────────────────────
         5. POPULAR AI TOOLS
    ──────────────────────────────────────────────────────────── -->
    {allTools.length > 5 && (
      <div class="hp-wide">
        <div class="container hp-section">
          <div class="section-header">
            <div>
              <span class="section-eyebrow">Top Ranked</span>
              <h2>Popular AI Tools</h2>
            </div>
            <a href="/ai-tools" class="see-all">
              View all tools
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="grid-tools">
            {allTools.slice(5, 11).map((t: any, i: number) => (
              <ToolCard tool={t} rank={i + 6}/>
            ))}
          </div>
        </div>
      </div>
    )}

    <!-- ─────────────────────────────────────────────────────────
         6. TRENDING TOPICS
    ──────────────────────────────────────────────────────────── -->
    <div class="container hp-section">
      <TrendingTopicsSection/>
    </div>

    <!-- ─────────────────────────────────────────────────────────
         7. BY PROFESSIONAL ROLE
    ──────────────────────────────────────────────────────────── -->
    <div class="container hp-section">
      <AudienceSection/>
    </div>

    <!-- ─────────────────────────────────────────────────────────
         8. BEST AI TOOLS FOR… (SEO intent links)
    ──────────────────────────────────────────────────────────── -->
    <div class="container hp-section">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">Curated lists</span>
          <h2>Best AI Tools For…</h2>
        </div>
        <a href="/best" class="see-all">
          All lists
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="bestof-grid">
        {bestOf.map(([label, href]) => (
          <a href={href} class="bestof-link">
            <span class="bestof-txt">{label}</span>
            <svg class="bestof-arr" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
          </a>
        ))}
      </div>
    </div>

    <!-- ─────────────────────────────────────────────────────────
         9. BLOG / GUIDES (editorial)
    ──────────────────────────────────────────────────────────── -->
    <div class="hp-wide">
      <div class="container hp-section">
        <div class="section-header">
          <div>
            <span class="section-eyebrow">Guides & Insights</span>
            <h2>From the Blog</h2>
          </div>
          <a href="/ai-news" class="see-all">
            View all
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="blog-grid">
          {blogPosts.map(post => (
            <a href={`/ai-news/${post.slug}`} class:list={["blog-card", post.grad]}>
              <div class="blog-card-body">
                <span class="blog-tag">{post.tag}</span>
                <h3 class="blog-title">{post.title}</h3>
                <span class="blog-read">Read article →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- ─────────────────────────────────────────────────────────
         10. NEWSLETTER CTA
    ──────────────────────────────────────────────────────────── -->
    <div class="container hp-section hp-section--last">
      <div class="nl-card">
        <div class="nl-orb nl-orb-1" aria-hidden="true"></div>
        <div class="nl-orb nl-orb-2" aria-hidden="true"></div>
        <div class="nl-content">
          <span class="section-eyebrow">Newsletter</span>
          <h2>Stay Ahead with AI</h2>
          <p>Weekly digest: the best new tools, expert comparisons and AI news.<br/>No spam. Unsubscribe anytime.</p>
          <form class="nl-form" onsubmit="return false">
            <input
              type="email"
              placeholder="your@email.com"
              class="input nl-email"
              aria-label="Email for newsletter"
            />
            <button type="submit" class="btn btn-primary">Subscribe Free</button>
          </form>
          <p class="nl-note">Join 10,000+ AI enthusiasts · Always free</p>
        </div>
      </div>
    </div>

  </div><!-- /hp-body -->

  <Footer slot="footer"/>
</BaseLayout>

<style>

/* ──────────────────────────────────────────────────────────────
   PAGE WRAPPER
   ────────────────────────────────────────────────────────────── */
.hp-body {
  padding-top: var(--sp-4);
}

/* Section spacing */
.hp-section {
  padding-top:    var(--sp-16);
  padding-bottom: var(--sp-16);
}
.hp-section--last {
  padding-bottom: var(--sp-8);
}

/* Full-width tinted stripe sections */
.hp-wide {
  background: var(--c-bg-2);
  border-top:    1px solid var(--c-border-subtle);
  border-bottom: 1px solid var(--c-border-subtle);
}

/* ── Best-of grid ─────────────────────────────────────────── */
.bestof-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
  gap: var(--sp-2);
}
.bestof-link {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  padding: 11px 15px;
  background: var(--c-bg-2);
  border: 1px solid var(--c-border);
  border-radius: var(--r-lg);
  font-family: var(--font-display);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--c-text-2);
  letter-spacing: -.01em;
  text-decoration: none;
  transition: background var(--t-fast), border-color var(--t-fast), color var(--t-fast);
}
.bestof-link:hover {
  background: var(--c-bg-3);
  border-color: var(--c-border-hover);
  color: var(--c-text);
}
.bestof-txt { flex: 1 }
.bestof-arr { color: var(--c-text-4); flex-shrink: 0; transition: transform var(--t-fast), color var(--t-fast) }
.bestof-link:hover .bestof-arr { transform: translateX(2px); color: var(--c-brand-light) }

/* ── Blog cards ───────────────────────────────────────────── */
.blog-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: var(--sp-4);
}
.blog-card {
  display: flex;
  align-items: flex-end;
  min-height: 200px;
  border-radius: var(--r-xl);
  border: 1px solid var(--c-border);
  text-decoration: none;
  overflow: hidden;
  position: relative;
  transition: border-color var(--t-base), transform var(--t-base);
  padding: var(--sp-6);
}
.blog-card:hover { border-color: var(--c-border-hover); transform: translateY(-2px) }
.blog-card::before {
  content: '';
  position: absolute;
  inset: 0;
  transition: opacity var(--t-base);
}
.from-blue::before   { background: linear-gradient(150deg, var(--c-bg) 0%, rgba(79,110,247,.50) 100%) }
.from-violet::before { background: linear-gradient(150deg, var(--c-bg) 0%, rgba(124,58,237,.50) 100%) }
.from-cyan::before   { background: linear-gradient(150deg, var(--c-bg) 0%, rgba(6,182,212,.42) 100%) }
.blog-card-body {
  position: relative; z-index: 1;
  display: flex; flex-direction: column; gap: var(--sp-2);
}
.blog-tag {
  font-family: var(--font-display);
  font-size: var(--text-2xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .09em;
  color: var(--c-brand-light);
}
.blog-title {
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--c-text);
  line-height: var(--lh-snug);
  letter-spacing: -.025em;
}
.blog-read {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--c-brand-light);
  opacity: 0;
  transition: opacity var(--t-fast);
  margin-top: 2px;
}
.blog-card:hover .blog-read { opacity: 1 }

/* ── Newsletter ───────────────────────────────────────────── */
.nl-card {
  position: relative;
  overflow: hidden;
  background: var(--c-bg-2);
  border: 1px solid var(--c-border-brand);
  border-radius: var(--r-2xl);
  padding: clamp(var(--sp-10), 7vw, var(--sp-16));
  text-align: center;
}
.nl-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(72px);
  pointer-events: none;
}
.nl-orb-1 { width: 380px; height: 380px; top: -40%; right: 5%;  background: var(--c-brand);  opacity: .10 }
.nl-orb-2 { width: 280px; height: 280px; bottom: -40%; left: 5%; background: var(--c-cyan);   opacity: .08 }
.nl-content {
  position: relative; z-index: 1;
  max-width: 500px; margin: 0 auto;
  display: flex; flex-direction: column;
  align-items: center; gap: var(--sp-5);
}
.nl-card h2 { font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl)); letter-spacing: -.03em }
.nl-card p  { font-size: var(--text-sm); color: var(--c-text-2); max-width: 400px; margin: 0; line-height: var(--lh-base) }
.nl-form    { display: flex; gap: var(--sp-2); width: 100%; max-width: 440px }
.nl-email   { flex: 1 }
.nl-note    { font-size: 11px; color: var(--c-text-3) }
@media (max-width: 500px) { .nl-form { flex-direction: column } }
</style>
