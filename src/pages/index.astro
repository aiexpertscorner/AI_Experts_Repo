---
/**
 * src/pages/index.astro — AIExpertsCorner Homepage
 * Geen inline styles. home.css geïmporteerd voor homepage-specifieke stijlen.
 */
import BaseLayout    from "@/layouts/BaseLayout.astro";
import Header        from "@/components/site/Header.astro";
import Footer        from "@/components/site/Footer.astro";
import ToolCard      from "@/components/cards/ToolCard.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import "@/styles/home.css";

import hpRaw      from "@/data/build/homepage-data.json";
import catMapRaw  from "@/data/build/category-map.json";
import logoMapRaw from "@/data/build/logo-map.json";

const hp      = hpRaw      as any;
const logoMap = logoMapRaw as Record<string, string>;
const catMap  = catMapRaw  as Record<string, any>;

const featuredTools = ((hp.featured_tools || []) as any[])
  .filter((t: any) => t?.slug)
  .map((t: any) => ({
    ...t,
    logo_url: logoMap[t.slug] || t.logo_url || null,
  }));

const totalTools   = Number(hp.total_tools   || 19088);
const totalCompare = Number(hp.total_compare || 3053);
const totalBestOf  = Number(hp.total_bestof  || 95);
const totalCats    = Number(hp.total_cats    || 23);
const freeCount    = Number(hp.pricing_dist?.free || 786);

const CAT_EMOJI: Record<string,string> = {
  "chatbots-and-llms":"💬","writing-and-content":"✍️","image-generation":"🎨",
  "video-generation":"🎬","audio-and-music":"🎵","coding-and-dev":"💻",
  "seo-and-marketing":"📈","design-and-ui":"🖌️","productivity":"⚡",
  "research-and-education":"🎓","data-and-analytics":"📊","customer-service":"🎧",
  "hr-and-recruiting":"👥","legal-and-finance":"⚖️","health-and-wellness":"❤️",
  "sales-and-crm":"💼","translation":"🌍","ai-agents":"🤖",
  "photo-editing":"📸","3d-and-ar":"🧊","e-commerce":"🛒",
  "social-media":"📱","other-ai-tools":"🔧",
};
const categories = Object.entries(catMap)
  .map(([slug, cat]: [string,any]) => ({ slug, name: cat.name||slug, count: cat.count||0, emoji: CAT_EMOJI[slug]||"🤖" }))
  .filter(c => c.count > 0)
  .sort((a,b) => b.count - a.count)
  .slice(0, 18);

function tc(s: string) { return (s||"").replace(/-/g," ").replace(/\b\w/g,(l:string)=>l.toUpperCase()); }

const HOT_PAIRS = [
  {a:"chatgpt",b:"claude"}, {a:"chatgpt",b:"google-gemini"},
  {a:"github-copilot",b:"codeium"}, {a:"midjourney",b:"dall-e-3"},
  {a:"elevenlabs",b:"murf-ai"}, {a:"jasper",b:"copy-ai"},
];
const hotComparisons = HOT_PAIRS.map(({a,b}) => ({
  nameA: featuredTools.find((t:any)=>t.slug===a)?.name || tc(a),
  nameB: featuredTools.find((t:any)=>t.slug===b)?.name || tc(b),
  logoA: logoMap[a]||null, logoB: logoMap[b]||null,
  href: `/compare/${[a,b].sort().join("-vs-")}`,
}));

const bestOfLinks = [
  {label:"Best AI writing tools",        href:"/best/ai-writing"},
  {label:"Best AI image generators",     href:"/best/ai-image-generation"},
  {label:"Best AI coding assistants",    href:"/best/ai-coding"},
  {label:"Best AI marketing tools",      href:"/best/ai-marketing"},
  {label:"Best AI video tools",          href:"/best/ai-video"},
  {label:"Best tools for blog posts",    href:"/best/write-blog-posts"},
  {label:"Best tools to generate code",  href:"/best/generate-code"},
  {label:"Best tools for SEO articles",  href:"/best/write-seo-articles"},
  {label:"Best AI tools for marketers",  href:"/best/ai-marketing"},
  {label:"Best AI tools for designers",  href:"/best/ai-design"},
  {label:"Best AI tools for developers", href:"/best/ai-coding"},
  {label:"Best free AI tools",           href:"/tools/pricing/free"},
];

const exploreCards = [
  {icon:"⚔️",  label:"Compare Tools",     sub:`${totalCompare.toLocaleString()}+ comparisons`, href:"/compare",      accent:"blue"},
  {icon:"🔀",  label:"Find Alternatives", sub:"Switch from any AI tool",                       href:"/alternatives", accent:"green"},
  {icon:"🏆",  label:"Best-Of Lists",      sub:`${totalBestOf}+ expert-ranked lists`,           href:"/best",         accent:"amber"},
  {icon:"🎯",  label:"By Use Case",        sub:"Tools for writing, coding, design & more",      href:"/use-case",     accent:"violet"},
];

const pageTitle = "AI Tools Directory — Discover the Best AI Tools for Any Workflow";
const pageDesc  = `Browse ${totalTools.toLocaleString()}+ AI tools across ${totalCats} categories. Compare pricing, find alternatives, and discover the best AI tool for your workflow.`;
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context":"https://schema.org","@type":"WebSite","name":"AIExpertsCorner",
      "url":"https://aiexpertscorner.com",
      "potentialAction":{"@type":"SearchAction","target":"https://aiexpertscorner.com/tools?q={q}","query-input":"required name=q"},
    })} />
  </Fragment>

  <Header slot="header" />

  <div class="page">

    <!-- HERO -->
    <section class="hp-hero">
      <div class="container hp-hero__inner">
        <div class="hub-hero-badge">
          <span class="hp-hero__dot"></span>
          The #1 AI Tools Directory
        </div>
        <h1 class="hp-hero__h1">Discover the Best<br/><span class="hp-hero__gradient">AI Tools</span> for Any Workflow</h1>
        <p class="hp-hero__sub">Browse {totalTools.toLocaleString()}+ AI tools across {totalCats} categories. Compare pricing, explore alternatives, and find the right tool — for free.</p>

        <div class="hp-search">
          <svg class="hp-search__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <input type="search" class="hp-search__input" placeholder={`Search ${totalTools.toLocaleString()}+ AI tools...`} autocomplete="off" />
          <a href="/tools" class="btn btn--primary btn--sm">Explore Free</a>
        </div>

        <div class="hp-hero__stats">
          {([
            [totalTools.toLocaleString()+"+","AI Tools"],
            [totalCats.toString(),"Categories"],
            ["Daily","Updated"],
            ["Free","Forever"],
          ] as [string,string][]).map(([val,lab],i) => (
            <>
              {i > 0 && <span class="hp-hero__sep" aria-hidden="true" />}
              <div class="hp-hero__stat"><strong>{val}</strong><span>{lab}</span></div>
            </>
          ))}
        </div>

        <div class="hp-hero__trusted">
          <span class="hp-hero__trusted-lbl">Covering tools from</span>
          {["OpenAI","Anthropic","Google AI","Microsoft","NVIDIA","Meta AI"].map(b=>(
            <span class="hp-hero__brand">{b}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- FEATURED TOOLS -->
    <section class="section container">
      <SectionHeader eyebrow="Mainstream AI" title="The Tools Everyone Knows" seeAllHref="/tools" seeAllLabel="View all tools →" />
      <div class="grid-tools">
        {featuredTools.slice(0,9).map((t:any,i:number)=>(
          <ToolCard tool={t} rank={i+1} showDescription={true} showPricing={true} showCategory={true} />
        ))}
      </div>
    </section>

    <!-- STATS BAR -->
    <div class="hp-stats-bar">
      <div class="hp-stats-bar__inner">
        {([
          [totalTools.toLocaleString()+"+","AI tools indexed"],
          [totalCompare.toLocaleString()+"+","Tool comparisons"],
          [totalBestOf.toLocaleString()+"+","Best-of lists"],
          [freeCount.toLocaleString()+"+","Free tools"],
        ] as [string,string][]).map(([val,lab],i)=>(
          <>
            {i>0 && <span class="hp-stats-bar__sep" aria-hidden="true" />}
            <div class="hp-stats-bar__item"><strong>{val}</strong><span>{lab}</span></div>
          </>
        ))}
      </div>
    </div>

    <!-- CATEGORIES -->
    <section class="section container">
      <SectionHeader eyebrow="Browse by Category" title="Find Tools for Any Workflow" seeAllHref="/tools" seeAllLabel="All categories →" />
      <div class="grid-cards-sm">
        {categories.map(cat=>(
          <a href={`/tools/category/${cat.slug}`} class="cat-card">
            <span class="cat-card__emoji">{cat.emoji}</span>
            <span class="cat-card__name">{cat.name}</span>
            <span class="cat-card__count">{cat.count.toLocaleString()}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- COMPARE -->
    <section class="section container">
      <SectionHeader eyebrow="Compare" title="Head-to-Head Comparisons" seeAllHref="/compare" seeAllLabel="View all →" />
      <div class="grid-cards-md">
        {hotComparisons.map(({nameA,nameB,logoA,logoB,href})=>(
          <a href={href} class="cmp-card">
            <span class="cmp-card__logos">
              {logoA ? <img src={logoA} alt="" width="24" height="24" loading="lazy" onerror="this.style.display='none'" /> : <span class="cmp-card__init">{nameA}</span>}
              <span class="cmp-card__vs">vs</span>
              {logoB ? <img src={logoB} alt="" width="24" height="24" loading="lazy" onerror="this.style.display='none'" /> : <span class="cmp-card__init">{nameB}</span>}
            </span>
            <span class="cmp-card__label">{nameA} vs {nameB}</span>
            <span class="cmp-card__arr">→</span>
          </a>
        ))}
      </div>
    </section>

    <!-- BEST-OF -->
    <section class="section container">
      <SectionHeader eyebrow="Best Of" title="Expert-Ranked AI Tool Lists" seeAllHref="/best" seeAllLabel="All lists →" />
      <div class="grid-cards-md">
        {bestOfLinks.map(l=>(
          <a href={l.href} class="best-link">
            <span>🏆</span>{l.label}<span class="best-link__arr">→</span>
          </a>
        ))}
      </div>
    </section>

    <!-- EXPLORE -->
    <section class="section container">
      <SectionHeader eyebrow="Explore" title="More Ways to Find AI Tools" />
      <div class="grid-cards-lg">
        {exploreCards.map(card=>(
          <a href={card.href} class={`exp-card exp-card--${card.accent}`}>
            <span class="exp-card__icon">{card.icon}</span>
            <strong class="exp-card__title">{card.label}</strong>
            <span class="exp-card__sub">{card.sub}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- SEO LINKS -->
    <div class="seo-links container">
      <a href="/tools">Browse all AI tools</a>
      <a href="/compare">Compare AI tools</a>
      <a href="/best">Best-of lists</a>
      <a href="/alternatives">Find alternatives</a>
      <a href="/use-case">Browse by use case</a>
      <a href="/tools/pricing/free">Free AI tools</a>
      <a href="/tools/pricing/freemium">Freemium AI tools</a>
      <a href="/submit-tool">Submit a tool</a>
    </div>

  </div>

  <Footer slot="footer" />
</BaseLayout>
