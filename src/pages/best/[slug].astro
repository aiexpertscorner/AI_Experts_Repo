---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/site/Header.astro";
import Footer from "@/components/site/Footer.astro";
import Breadcrumbs from "@/components/site/Breadcrumbs.astro";
import ToolCard from "@/components/cards/ToolCard.astro";
import bestMap from "@/data/build/best-of-map.json";
import bestPaths from "@/data/build/best-of-paths.json";

export function getStaticPaths() {
  return (bestPaths as string[]).map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const entry = (bestMap as any)[slug!];
if (!entry) return Astro.redirect('/best');
const { name, tools=[], description, count } = entry;
---
<BaseLayout title={`Best ${name} — Top AI Tools`} description={description ?? `The best AI tools for ${name}, ranked and reviewed.`}>
  <Header slot="header"/>
  <div class="container">
    <Breadcrumbs crumbs={[{label:"Best Of", href:"/best"}, {label:`Best ${name}`}]}/>
    <div class="dim-header">
      <span class="badge badge-featured">🏆 Best Of</span>
      <h1>Best {name}</h1>
      <p>{description ?? `The top-ranked AI tools for ${name}.`}</p>
      <div class="dim-meta">
        <div class="dim-meta-item"><strong>{count ?? tools.length}</strong> tools ranked</div>
      </div>
    </div>
    <div class="grid-tools">
      {tools.slice(0,24).map((t:any, i:number) => <ToolCard tool={t} rank={i+1}/>)}
    </div>
  </div>
  <Footer slot="footer"/>
</BaseLayout>
<style is:global>
@import "@/styles/dimension-page.css";
</style>
