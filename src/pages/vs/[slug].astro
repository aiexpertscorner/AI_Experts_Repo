---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/site/Header.astro";
import Footer from "@/components/site/Footer.astro";
import comparePageData from "@/data/build/compare-page-data.json";

// ── Props patroon: één slim bestand (<3MB), data per paar als prop ──
export function getStaticPaths() {
  return Object.values(comparePageData as Record<string,any>).map((entry: any) => ({
    params: { slug: entry.slug },
    props:  { entry },
  }));
}

interface Props { entry: any }
const { entry } = Astro.props;
if (!entry) return Astro.redirect('/ai-tools');

const { toolA: A, toolB: B } = entry;
const pricingLabel: Record<string,string> = { free:"Free", freemium:"Freemium", paid:"Paid" };
const pricingClass: Record<string,string>  = { free:"badge-free", freemium:"badge-freemium", paid:"badge-paid" };
const FEATURES = ["has_api","has_mobile","has_chrome_ext","is_open_source"];
const FEATURE_LABELS: Record<string,string> = {
  has_api:"API Access", has_mobile:"Mobile App",
  has_chrome_ext:"Chrome Extension", is_open_source:"Open Source"
};

function enrichTool(t: any) {
  const tier = (t.pricing_tier ?? "unknown").toLowerCase();
  return {
    ...t,
    tier,
    logo: t.logo_domain ? `https://logo.clearbit.com/${t.logo_domain}?size=64` : null,
    pricingLabel: pricingLabel[tier] ?? t.pricing_tier,
    pricingClass: pricingClass[tier] ?? "badge-unknown",
    href: t.affiliate_url || t.website_url || `/ai-tools/${t.handle}`,
  };
}
const toolA = enrichTool(A);
const toolB = enrichTool(B);
---
<BaseLayout
  title={`${toolA.name} vs ${toolB.name} — Which AI Tool is Better?`}
  description={`Compare ${toolA.name} and ${toolB.name} side by side. Features, pricing, use cases and more.`}
>
  <Header slot="header"/>
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      <a href="/vs">Compare</a>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      <span>{toolA.name} vs {toolB.name}</span>
    </nav>

    <div class="vs-header">
      <h1>{toolA.name} <span class="vs-label">vs</span> {toolB.name}</h1>
      <p>Side-by-side comparison of features, pricing and use cases.</p>
    </div>

    <div class="vs-grid">
      {[toolA, toolB].map(t => (
        <div class="vs-col">
          {t.logo && (
            <img src={t.logo} alt={t.name} width="56" height="56" class="tool-logo tool-logo-lg"
              loading="lazy" onerror="this.style.display='none'"/>
          )}
          <h2 class="vs-name">{t.name}</h2>
          <span class:list={["badge", t.pricingClass]}>{t.pricingLabel}</span>
          <p class="vs-desc">{t.tagline ?? t.description ?? ""}</p>
          <a href={t.href} class="btn btn-primary" target="_blank" rel="noopener">
            Visit {t.name} →
          </a>
          <div class="vs-features">
            {FEATURES.map(f => (
              <div class:list={["vs-feat", { "feat-yes": t[f], "feat-no": !t[f] }]}>
                <span class="feat-icon">{t[f] ? "✓" : "✗"}</span>
                {FEATURE_LABELS[f]}
              </div>
            ))}
          </div>
          {(t.feature_tags ?? []).slice(0,6).map((tag:string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      ))}
    </div>

    <div class="vs-cta">
      <a href={`/ai-tools/${toolA.handle}`} class="btn btn-ghost">View {toolA.name} details</a>
      <a href={`/ai-tools/${toolB.handle}`} class="btn btn-ghost">View {toolB.name} details</a>
      <a href={`/alternatives/${toolA.handle}`} class="btn btn-ghost">Alternatives to {toolA.name}</a>
    </div>
  </div>
  <Footer slot="footer"/>
</BaseLayout>

<style>
.breadcrumb{display:flex;align-items:center;gap:var(--sp-2);font-size:var(--text-xs);color:var(--c-text-3);padding:var(--sp-6) 0 0;margin-bottom:var(--sp-6);flex-wrap:wrap}
.breadcrumb a{color:var(--c-text-3);text-decoration:none;transition:color var(--t-fast)}
.breadcrumb a:hover{color:var(--c-brand-light)}
.vs-header{padding:var(--sp-8) 0;text-align:center}
.vs-header h1{margin-bottom:var(--sp-3)}
.vs-label{color:var(--c-text-3);font-weight:400;margin:0 var(--sp-3)}
.vs-header p{color:var(--c-text-2)}
.vs-grid{display:grid;grid-template-columns:1fr 1fr;gap:var(--sp-8);margin-bottom:var(--sp-8)}
@media(max-width:700px){.vs-grid{grid-template-columns:1fr}}
.vs-col{background:var(--c-bg-2);border:1px solid var(--c-border);border-radius:var(--r-xl);padding:var(--sp-8);display:flex;flex-direction:column;gap:var(--sp-4)}
.vs-name{font-size:var(--text-2xl)}
.vs-desc{color:var(--c-text-2);font-size:var(--text-sm)}
.vs-features{display:flex;flex-direction:column;gap:var(--sp-2);margin-top:var(--sp-2)}
.vs-feat{display:flex;align-items:center;gap:var(--sp-2);font-size:var(--text-sm);color:var(--c-text-3)}
.feat-yes{color:var(--c-text-2)}
.feat-yes .feat-icon{color:var(--c-free);font-weight:700}
.feat-no .feat-icon{color:var(--c-text-3)}
.vs-cta{display:flex;flex-wrap:wrap;gap:var(--sp-3);margin-bottom:var(--sp-16)}
</style>
