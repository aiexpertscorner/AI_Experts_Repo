---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/site/Header.astro";
import Footer from "@/components/site/Footer.astro";
import ToolCard from "@/components/cards/ToolCard.astro";
import altPageData from "@/data/build/alternatives-page-data.json";

// ── Props patroon: één slim bestand (<8MB), data per tool als prop ──
export function getStaticPaths() {
  return Object.values(altPageData as Record<string,any>).map((entry: any) => ({
    params: { slug: entry.handle },
    props:  { entry },
  }));
}

interface Props { entry: any }
const { entry } = Astro.props;
if (!entry) return Astro.redirect('/ai-tools');

const { handle, name, tagline, pricing_tier="unknown", category="", category_slug="", alts=[] } = entry;
const catSlug = category_slug || category.toLowerCase().replace(/[^a-z0-9]+/g,"-");
---
<BaseLayout
  title={`Best Alternatives to ${name} in ${new Date().getFullYear()}`}
  description={`Looking for alternatives to ${name}? Discover ${alts.length} top alternatives with similar features and use cases.`}
>
  <Header slot="header"/>
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      <a href="/ai-tools">AI Tools</a>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      <a href={`/ai-tools/${handle}`}>{name}</a>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      <span>Alternatives</span>
    </nav>

    <div class="alt-header">
      <span class="alt-badge">🔄 Alternatives</span>
      <h1>Best Alternatives to {name}</h1>
      <p>Discover {alts.length} top alternatives to {name} with similar features and use cases.</p>
      <div class="alt-meta">
        <span><strong>{alts.length}</strong> alternatives found</span>
        {pricing_tier && <span>Original pricing: <strong>{pricing_tier}</strong></span>}
      </div>
      <a href={`/ai-tools/${handle}`} class="btn btn-ghost btn-sm">← Back to {name}</a>
    </div>

    {alts.length > 0
      ? <div class="grid-tools">{alts.map((t:any, i:number) => <ToolCard tool={t} rank={i+1}/>)}</div>
      : <p class="empty">No alternatives found yet.</p>
    }
  </div>
  <Footer slot="footer"/>
</BaseLayout>

<style>
.breadcrumb{display:flex;align-items:center;gap:var(--sp-2);font-size:var(--text-xs);color:var(--c-text-3);padding:var(--sp-6) 0 0;margin-bottom:var(--sp-6);flex-wrap:wrap}
.breadcrumb a{color:var(--c-text-3);text-decoration:none;transition:color var(--t-fast)}
.breadcrumb a:hover{color:var(--c-brand-light)}
.alt-header{padding:var(--sp-6) 0 var(--sp-10)}
.alt-badge{display:inline-block;font-size:var(--text-xs);font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--c-brand-light);background:rgba(99,102,241,.1);border:1px solid rgba(99,102,241,.3);padding:4px 12px;border-radius:var(--r-full);margin-bottom:var(--sp-4)}
.alt-header h1{font-size:clamp(var(--text-2xl),4vw,var(--text-4xl));margin-bottom:var(--sp-3)}
.alt-header p{font-size:var(--text-base);color:var(--c-text-2);margin-bottom:var(--sp-4);max-width:560px}
.alt-meta{display:flex;gap:var(--sp-6);font-size:var(--text-sm);color:var(--c-text-3);margin-bottom:var(--sp-6)}
.alt-meta strong{color:var(--c-text);font-family:var(--font-display)}
.empty{text-align:center;color:var(--c-text-3);padding:4rem 0}
</style>
