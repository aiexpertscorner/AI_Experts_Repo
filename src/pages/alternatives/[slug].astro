---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/site/Header.astro";
import Footer from "@/components/site/Footer.astro";
import Breadcrumbs from "@/components/site/Breadcrumbs.astro";
import ToolCard from "@/components/cards/ToolCard.astro";
import altMap from "@/data/build/alternatives-map.json";
import toolPaths from "@/data/build/tool-paths.json";
import toolMap from "@/data/build/tool-map.json";

export function getStaticPaths() {
  return (toolPaths as string[]).slice(0, 3000).filter(h => (altMap as any)[h]).map(h => ({ params: { slug: h } }));
}

const { slug } = Astro.params;
const tool = (toolMap as any)[slug!];
const alts = (altMap as any)[slug!] ?? [];
if (!tool) return Astro.redirect('/ai-tools');
---
<BaseLayout
  title={`Best Alternatives to ${tool.name} in ${new Date().getFullYear()}`}
  description={`Looking for alternatives to ${tool.name}? We found ${alts.length} top alternatives with similar features.`}
>
  <Header slot="header"/>
  <div class="container">
    <Breadcrumbs crumbs={[{label:"AI Tools",href:"/ai-tools"},{label:`Alternatives to ${tool.name}`}]}/>
    <div class="dim-header">
      <span class="badge badge-unknown">🔄 Alternatives</span>
      <h1>Best Alternatives to {tool.name}</h1>
      <p>Discover {alts.length} top alternatives to {tool.name} with similar features and use cases.</p>
      <div class="dim-meta">
        <div class="dim-meta-item"><strong>{alts.length}</strong> alternatives found</div>
        {tool.pricing_tier && <div class="dim-meta-item">Original: <strong>{tool.pricing_tier}</strong></div>}
      </div>
    </div>
    <div class="grid-tools">
      {alts.map((t:any, i:number) => <ToolCard tool={t} rank={i+1}/>)}
    </div>
    {alts.length === 0 && <p style="color:var(--c-text-3);text-align:center;padding:3rem 0">No alternatives found yet.</p>}
  </div>
  <Footer slot="footer"/>
</BaseLayout>
<style is:global>
@import "@/styles/dimension-page.css";
</style>