---
/**
 * src/pages/alternatives/[slug].astro
 * Best alternatives for a specific AI tool.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header     from "@/components/site/Header.astro";
import Footer     from "@/components/site/Footer.astro";
import ToolCard   from "@/components/cards/ToolCard.astro";
import ToolLogo   from "@/components/ui/ToolLogo.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";

import altPagesRaw from "@/data/build/page-payloads/alternatives-pages.json";

export async function getStaticPaths() {
  const pages = altPagesRaw as any[];
  return pages
    .filter(p => p?.seed_tool?.slug && p?.alternatives?.length >= 3)
    .map(page => ({
      params: { slug: page.seed_tool.slug },
      props:  { page },
    }));
}

const { page }  = Astro.props as any;
const seed      = page.seed_tool;
const alts      = page.alternatives || [];
const seedName  = seed.name || seed.slug;

const title       = page.seo?.title       || `Best ${seedName} Alternatives 2026 — Top ${alts.length} Picks`;
const description = page.seo?.description || `Looking for ${seedName} alternatives? Compare ${alts.length} similar tools with features, pricing and expert picks.`;
---

<BaseLayout title={title} description={description}>
  <Header slot="header" />

  <div class="alternatives-page">

    <div class="container">
      <Breadcrumb crumbs={[
        { label: "Home",         href: "/" },
        { label: "Alternatives", href: "/alternatives" },
        { label: `${seedName} Alternatives` },
      ]} />
    </div>

    <!-- Hero -->
    <section class="alternatives-page__hero">
      <div class="container">
        <div class="alternatives-seed">
          <ToolLogo
            slug={seed.slug}
            name={seedName}
            logoUrl={seed.logo_url}
            logoDomain={seed.logo_domain}
            size={64}
            loading="eager"
          />
          <div>
            <p class="alternatives-seed__label">Finding alternatives for</p>
            <h1 class="alternatives-seed__name">{seedName}</h1>
          </div>
        </div>

        <p class="alternatives-page__intro">
          We found <strong>{alts.length} alternatives</strong> to {seedName}.
          Compare features, pricing and find the best fit for your workflow.
        </p>
      </div>
    </section>

    <!-- Alternatives grid -->
    <section class="alternatives-page__list">
      <div class="container">
        <div class="grid-tools">
          {alts.map((tool: any, i: number) => (
            <ToolCard
              tool={tool}
              rank={i + 1}
              showDescription={true}
              showPricing={true}
              showCategory={true}
              showCTA={false}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Compare CTA -->
    <section class="alternatives-page__compare-cta">
      <div class="container">
        <h2>Compare {seedName} directly</h2>
        <p>See a detailed side-by-side comparison with top alternatives.</p>
        <div class="alternatives-page__compare-links">
          {alts.slice(0, 4).map((alt: any) => {
            const altName = alt.name || alt.slug;
            const [a, b] = [seed.slug, alt.slug].sort();
            return (
              <a href={`/compare/${a}-vs-${b}`} class="btn btn--secondary">
                {seedName} vs {altName}
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <div class="container">
      <div class="seo-links" style="margin-top: var(--sp-8)">
        <a href="/alternatives">All alternatives</a>
        <a href={`/tools/${seed.slug}`}>← Back to {seedName}</a>
        <a href="/compare">Compare tools</a>
        <a href="/best">Best-of lists</a>
      </div>
    </div>

  </div>

  <Footer slot="footer" />
</BaseLayout>