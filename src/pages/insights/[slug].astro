---
/**
 * src/pages/insights/[slug].astro
 * FIX: tool-map.json verwijderd (152MB, gitignored → build crash)
 *      Leest nu individuele tools/{slug}.json via fs.readFileSync
 *      Inline CSS verplaatst naar insights.css
 */
import fs   from "node:fs";
import path from "node:path";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header     from "@/components/site/Header.astro";
import Footer     from "@/components/site/Footer.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";
import ToolLogo   from "@/components/ui/ToolLogo.astro";
import Badge      from "@/components/ui/Badge.astro";
import "@/styles/insights.css";

import postsRaw  from "@/data/build/posts.json";
import logoMapRaw from "@/data/build/logo-map.json";

const logoMap = logoMapRaw as Record<string, string>;

export function getStaticPaths() {
  return (postsRaw as any[]).map(post => ({
    params: { slug: post.slug },
    props:  { post },
  }));
}

const { post } = Astro.props as any;

// FIX: lees individueel tool bestand via fs i.p.v. tool-map.json import
let tool: any = null;
if (post.tool_slug) {
  const toolFile = path.join(process.cwd(), "src/data/build/tools", `${post.tool_slug}.json`);
  if (fs.existsSync(toolFile)) {
    try { tool = JSON.parse(fs.readFileSync(toolFile, "utf8")); } catch {}
  }
}

const toolName    = tool?.hero?.name    || post.tool_name    || null;
const toolPricing = tool?.commercial?.pricing_tier           || null;
const toolDesc    = tool?.content?.description               || null;
const toolWebsite = tool?.hero?.website_url                  || null;

// Related posts
const allPosts = postsRaw as any[];
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug && (
    p.insights_category === post.insights_category ||
    (p.tool_slug && p.tool_slug === post.tool_slug)
  ))
  .slice(0, 4);

// Related tool cards — lees ook via individuele files
const relatedToolCards = (post.related_tools || [])
  .slice(0, 4)
  .map((slug: string) => {
    const f = path.join(process.cwd(), "src/data/build/tools", `${slug}.json`);
    if (!fs.existsSync(f)) return null;
    try { return { slug, ...JSON.parse(fs.readFileSync(f, "utf8")) }; } catch { return null; }
  })
  .filter(Boolean);

const CAT_LABELS: Record<string, string> = {
  "tutorials":     "Tutorial",
  "analysis":      "Analysis",
  "news":          "News",
  "tool-releases": "Tool Release",
  "trends":        "Trend",
  "research":      "Research",
  "market":        "Market",
  "case-studies":  "Case Study",
};
const catLabel = CAT_LABELS[post.insights_category] || post.insights_category;

function formatDate(d: string) {
  return new Date(d).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "description": post.seo?.description || post.excerpt,
  "datePublished": post.date,
  "dateModified": post.date_updated || post.date,
  "author": { "@type": "Person", "name": post.author || "AI Expert" },
  "publisher": { "@type": "Organization", "name": "AIExpertsCorner", "url": "https://aiexpertscorner.com" },
  "url": post.seo?.canonical,
  "keywords": post.seo?.keywords,
  "articleSection": post.insights_category,
};
---

<BaseLayout title={post.seo?.title || post.title} description={post.seo?.description || post.excerpt}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <meta property="article:published_time" content={post.date} />
    <meta property="article:section"        content={post.insights_category} />
    {(post.tags || []).map((tag: string) => <meta property="article:tag" content={tag} />)}
  </Fragment>

  <Header slot="header" />

  <div class="page">
    <div class="container container--narrow">

      <Breadcrumb crumbs={[
        { label: "Home",     href: "/" },
        { label: "Insights", href: "/insights" },
        { label: catLabel,   href: `/insights/category/${post.insights_category}` },
        { label: post.title.slice(0, 40) + (post.title.length > 40 ? "…" : "") },
      ]} />

      <!-- Article header -->
      <header class="art-header">
        <div class="art-header__meta">
          <a href={`/insights/category/${post.insights_category}`} class="art-header__cat">
            {catLabel}
          </a>
          <span class="art-header__dot">·</span>
          <span class="art-header__read">{post.reading_time_min} min read</span>
          <span class="art-header__dot">·</span>
          <span class="art-header__date">{formatDate(post.date)}</span>
        </div>

        <h1 class="art-header__title">{post.title}</h1>
        <p class="art-header__excerpt">{post.excerpt}</p>

        <div class="art-header__byline">
          <div class="art-header__author">
            <span class="art-header__avatar">{(post.author || "AI").charAt(0)}</span>
            <span>{post.author || "AI Expert"}</span>
          </div>
          {post.tool_slug && toolName && (
            <a href={`/tools/${post.tool_slug}`} class="art-header__tool-badge">
              <ToolLogo slug={post.tool_slug} name={toolName} size={20} loading="eager" />
              <span>{toolName}</span>
            </a>
          )}
        </div>
      </header>

      <!-- Tool spotlight -->
      {tool && toolName && (
        <aside class="art-tool-spot">
          <ToolLogo slug={post.tool_slug} name={toolName} size={48} loading="eager" />
          <div class="art-tool-spot__info">
            <span class="art-tool-spot__label">Tool in this article</span>
            <strong class="art-tool-spot__name">{toolName}</strong>
            {toolDesc && <p class="art-tool-spot__desc">{toolDesc.slice(0, 120)}…</p>}
          </div>
          <div class="art-tool-spot__actions">
            {toolPricing && <Badge tier={toolPricing} />}
            <a href={`/tools/${post.tool_slug}`} class="btn btn--secondary btn--sm">View tool →</a>
            {toolWebsite && (
              <a href={toolWebsite} class="btn btn--primary btn--sm" target="_blank" rel="noopener">
                Try {toolName} →
              </a>
            )}
          </div>
        </aside>
      )}

      <!-- Article body -->
      <article class="art-body">
        {post.content_format === "markdown" ? (
          <div class="prose" set:html={
            (post.content || "")
              .replace(/^### (.+)$/gm, "<h3>$1</h3>")
              .replace(/^## (.+)$/gm,  "<h2>$1</h2>")
              .replace(/^# (.+)$/gm,   "<h1>$1</h1>")
              .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
              .replace(/\*([^*]+)\*/g,     "<em>$1</em>")
              .replace(/`([^`]+)`/g,       "<code>$1</code>")
              .replace(/\[([^\]]+)\]\((\/tools\/[^)]+)\)/g, '<a href="$2" class="art-tool-link">$1</a>')
              .replace(/\[([^\]]+)\]\(([^)]+)\)/g,          '<a href="$2" target="_blank" rel="noopener">$1</a>')
              .replace(/(?:^|\n)((?:[-*+] .+\n?)+)/gm, (_: string, block: string) =>
                "<ul>" + block.split("\n").filter((l: string) => /^[-*+] /.test(l))
                  .map((l: string) => `<li>${l.replace(/^[-*+] /, "")}</li>`).join("") + "</ul>"
              )
              .replace(/(?:^|\n)((?:\d+\. .+\n?)+)/gm, (_: string, block: string) =>
                "<ol>" + block.split("\n").filter((l: string) => /^\d+\. /.test(l))
                  .map((l: string) => `<li>${l.replace(/^\d+\. /, "")}</li>`).join("") + "</ol>"
              )
              .replace(/^> (.+)$/gm, "<blockquote>$1</blockquote>")
              .replace(/\n\n(?!<[uo]l|<h[1-6]|<blockquote)/g, "</p><p>")
              .replace(/^(?!<)(.)/m, "<p>$1") + "</p>"
          } />
        ) : (
          <div class="prose">
            {(post.content || "").split("\n\n").map((para: string) => (
              para.trim().length > 3 ? <p>{para.trim()}</p> : null
            ))}
          </div>
        )}
      </article>

      <!-- Tags -->
      {(post.tags || []).length > 0 && (
        <div class="art-tags">
          <span class="art-tags__label">Tags:</span>
          <div class="chips">
            {post.tags.slice(0, 8).map((tag: string) => (
              <span class="chip">{tag}</span>
            ))}
          </div>
        </div>
      )}

      <!-- Related tools -->
      {relatedToolCards.length > 0 && (
        <aside class="art-related-tools">
          <h2 class="hub-section-title">Tools mentioned in this article</h2>
          <div class="art-related-tools__grid">
            {relatedToolCards.map((t: any) => {
              const s    = t.slug;
              const n    = t.hero?.name || s;
              const tier = t.commercial?.pricing_tier || "unknown";
              const desc = t.content?.description || "";
              return (
                <a href={`/tools/${s}`} class="art-tool-card">
                  <ToolLogo slug={s} name={n} size={40} loading="lazy" />
                  <div class="art-tool-card__info">
                    <div class="art-tool-card__row">
                      <strong>{n}</strong>
                      <Badge tier={tier} />
                    </div>
                    {desc && <p>{desc.slice(0, 80)}…</p>}
                  </div>
                </a>
              );
            })}
          </div>
        </aside>
      )}

    </div>

    <!-- Related articles -->
    {relatedPosts.length > 0 && (
      <section class="art-related-posts">
        <div class="container">
          <h2 class="hub-section-title">Related Articles</h2>
          <div class="grid-cards-lg">
            {relatedPosts.map((p: any) => (
              <a href={`/insights/${p.slug}`} class="ins-post-card">
                <div class="ins-post-card__meta">
                  <span class="ins-post-card__cat">{p.insights_category}</span>
                  <span class="ins-post-card__read">{p.reading_time_min} min read</span>
                </div>
                <h3 class="ins-post-card__title">{p.title}</h3>
                <div class="ins-post-card__footer">
                  {p.tool_name && <span class="ins-post-card__tool">{p.tool_name}</span>}
                  <span class="ins-post-card__date">{formatDate(p.date)}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <div class="container">
      <div class="seo-links" style="margin-top:var(--sp-8)">
        <a href="/insights">All Insights</a>
        <a href={`/insights/category/${post.insights_category}`}>{catLabel}</a>
        {post.tool_slug && <a href={`/tools/${post.tool_slug}`}>{post.tool_name} tool page</a>}
        {post.tool_slug && <a href={`/alternatives/${post.tool_slug}`}>{post.tool_name} alternatives</a>}
        {post.tool_slug && <a href="/compare">Compare AI tools</a>}
      </div>
    </div>

  </div>

  <Footer slot="footer" />
</BaseLayout>