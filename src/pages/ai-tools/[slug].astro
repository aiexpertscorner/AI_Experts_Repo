---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/site/Header.astro";
import Footer from "@/components/site/Footer.astro";
import ToolCard from "@/components/cards/ToolCard.astro";
import toolPageData from "@/data/build/tool-page-data.json";

// ── Props patroon: data eenmalig geladen in getStaticPaths,
//    per tool doorgegeven als prop → V8 kan grote map GC'en ──
export function getStaticPaths() {
  return Object.values(toolPageData as Record<string,any>).map((tool: any) => ({
    params: { slug: tool.handle },
    props:  { tool },
  }));
}

interface Props { tool: any }
const { tool } = Astro.props;
if (!tool) return Astro.redirect('/ai-tools');

const {
  handle="", name="", tagline="", description="", pricing_tier="unknown",
  logo_domain="", website_url="", affiliate_url="",
  category="", category_slug="", feature_tags=[], use_cases=[],
  industries=[], seo_title="", seo_description="",
  has_api=false, has_mobile=false, has_chrome_ext=false, is_open_source=false,
  complexity="", target_audience="", workflow_stage="",
  compare_targets=[], related=[]
} = tool;

const slug = handle;
const tier = (pricing_tier||"unknown").toLowerCase();
const pricingClass: Record<string,string> = { free:"badge-free", freemium:"badge-freemium", paid:"badge-paid" };
const pricingLabel: Record<string,string> = { free:"Free", freemium:"Freemium", paid:"Paid" };
const logoSrc = logo_domain ? `https://logo.clearbit.com/${logo_domain}?size=128` : null;
const ctaHref = affiliate_url || website_url || "#";
const ctaRel  = affiliate_url ? "noopener sponsored" : "noopener noreferrer";
const catSlug = category_slug || (category||"").toLowerCase().replace(/[^a-z0-9]+/g,"-");
const relatedTools = Array.isArray(related) ? related.slice(0,3) : [];
const targetAudienceStr = String(target_audience || "");
const workflowStr = String(workflow_stage || "");
const features = [
  has_api && "API Access",
  has_mobile && "Mobile App",
  has_chrome_ext && "Browser Extension",
  is_open_source && "Open Source",
].filter(Boolean) as string[];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": name,
  "description": seo_description || tagline || description,
  "url": website_url,
  "applicationCategory": "AIApplication",
  "offers": { "@type": "Offer", "price": tier === "free" ? "0" : undefined, "priceCurrency": "USD" }
};
---
<BaseLayout
  title={seo_title || `${name} — AI Tool Review & Alternatives`}
  description={seo_description || tagline || description}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}/>
  </Fragment>
  <Header slot="header"/>

  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      <a href="/ai-tools">AI Tools</a>
      {category && (<>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <a href={`/ai-tools/category/${catSlug}`}>{category}</a>
      </>)}
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      <span>{name}</span>
    </nav>

    <div class="tool-layout">
      <div class="tool-main">
        <div class="tool-hero">
          <div class="th-top">
            {logoSrc ? (
              <img src={logoSrc} alt={`${name} logo`} width="72" height="72" class="th-logo"
                loading="eager" onerror="this.onerror=null;this.style.display='none';this.nextElementSibling.style.display='flex'"/>
            ) : null}
            <span class="th-fb" style={logoSrc ? "display:none" : ""}>{(name||"A").charAt(0)}</span>
            <div class="th-meta">
              <div class="th-badges">
                <span class:list={["badge", pricingClass[tier]||"badge-unknown"]}>{pricingLabel[tier]||pricing_tier}</span>
                {category && <a href={`/ai-tools/category/${catSlug}`} class="badge badge-unknown">{category}</a>}
              </div>
              <h1 class="th-name">{name}</h1>
              <p class="th-tagline">{tagline || description}</p>
            </div>
          </div>
          <div class="th-ctas">
            <a href={ctaHref} class="btn btn-primary btn-lg" target="_blank" rel={ctaRel}>
              Visit {name}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
            <a href={`/alternatives/${slug}`} class="btn btn-ghost btn-lg">Alternatives</a>
            {(Array.isArray(compare_targets)?compare_targets:[]).length > 0 && (
              <a href={`/vs/${[slug,(compare_targets as string[])[0]].sort().join('-vs-')}`} class="btn btn-ghost btn-lg">Compare</a>
            )}
          </div>
        </div>

        {description && description !== tagline && (
          <section class="tool-section">
            <h2>About {name}</h2>
            <p>{description}</p>
          </section>
        )}

        {(Array.isArray(use_cases) ? use_cases : []).length > 0 && (
          <section class="tool-section">
            <h2>What Can You Do With {name}?</h2>
            <ul class="uc-list">
              {(use_cases as string[]).slice(0,8).map(uc => (
                <li class="uc-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--c-brand)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  {uc}
                </li>
              ))}
            </ul>
          </section>
        )}

        {(Array.isArray(feature_tags) ? feature_tags : []).length > 0 && (
          <section class="tool-section">
            <h2>Features & Tags</h2>
            <div class="tag-cloud">
              {(feature_tags as string[]).map(t => (
                <a href={`/ai-tools/tag/${t.toLowerCase().replace(/[^a-z0-9]+/g,'-')}`} class="tag">{t}</a>
              ))}
            </div>
          </section>
        )}

        {relatedTools.length > 0 && (
          <section class="tool-section">
            <h2>Top Alternatives to {name}</h2>
            <div class="grid-tools">
              {relatedTools.map((t:any) => <ToolCard tool={t}/>)}
            </div>
            <a href={`/alternatives/${slug}`} class="btn btn-ghost" style="margin-top:1rem">See all alternatives →</a>
          </section>
        )}
      </div>

      <aside class="tool-sidebar">
        <div class="sb-card">
          <h3>Quick Facts</h3>
          <table class="sb-table">
            <tbody>
              <tr><td>Pricing</td><td><span class:list={["badge", pricingClass[tier]||"badge-unknown"]}>{pricingLabel[tier]||pricing_tier}</span></td></tr>
              {complexity && <tr><td>Complexity</td><td>{complexity}</td></tr>}
              {workflowStr && <tr><td>Workflow</td><td>{workflowStr}</td></tr>}
              {targetAudienceStr && <tr><td>Best For</td><td>{targetAudienceStr}</td></tr>}
              {(Array.isArray(industries)?industries:[]).length > 0 && (
                <tr><td>Industries</td><td>{(industries as string[]).slice(0,2).join(", ")}</td></tr>
              )}
            </tbody>
          </table>
        </div>

        {features.length > 0 && (
          <div class="sb-card">
            <h3>Platform Features</h3>
            <div class="sb-features">
              {features.map(f => (
                <div class="sb-feat">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--c-free)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  {f}
                </div>
              ))}
            </div>
          </div>
        )}

        {(Array.isArray(compare_targets)?compare_targets:[]).length > 0 && (
          <div class="sb-card">
            <h3>Compare With</h3>
            <div class="sb-compare">
              {(compare_targets as string[]).slice(0,4).map(t => (
                <a href={`/vs/${[slug,t].sort().join('-vs-')}`} class="sb-cmp-link">
                  {name} vs {t.replace(/-/g,' ')}
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="sb-cta">
          <a href={ctaHref} class="btn btn-primary" target="_blank" rel={ctaRel} style="width:100%;justify-content:center">Visit {name} →</a>
          <a href={`/alternatives/${slug}`} class="btn btn-ghost" style="width:100%;justify-content:center;margin-top:var(--sp-2)">Find Alternatives</a>
        </div>
      </aside>
    </div>
  </div>

  <Footer slot="footer"/>
</BaseLayout>

<style>
.breadcrumb{display:flex;align-items:center;gap:var(--sp-2);font-size:var(--text-xs);color:var(--c-text-3);padding:var(--sp-6) 0 0;margin-bottom:var(--sp-8);flex-wrap:wrap}
.breadcrumb a{color:var(--c-text-3);text-decoration:none;transition:color var(--t-fast)}
.breadcrumb a:hover{color:var(--c-brand-light)}
.tool-layout{display:grid;grid-template-columns:1fr 300px;gap:var(--sp-10);align-items:start;padding-bottom:var(--sp-16)}
@media(max-width:900px){.tool-layout{grid-template-columns:1fr}}
@media(max-width:900px){.tool-sidebar{order:-1}}
.tool-hero{background:var(--c-bg-2);border:1px solid var(--c-border);border-radius:var(--r-xl);padding:var(--sp-8);margin-bottom:var(--sp-8)}
.th-top{display:flex;gap:var(--sp-5);align-items:flex-start;margin-bottom:var(--sp-6)}
.th-logo{width:72px;height:72px;border-radius:var(--r-md);object-fit:contain;background:var(--c-bg-4);border:1px solid var(--c-border);flex-shrink:0}
.th-fb{width:72px;height:72px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:900;font-family:var(--font-display);color:var(--c-brand);background:var(--c-brand-glow);border-radius:var(--r-md)}
.th-meta{flex:1}
.th-badges{display:flex;flex-wrap:wrap;gap:var(--sp-2);margin-bottom:var(--sp-3)}
.th-name{font-size:clamp(var(--text-2xl),4vw,var(--text-3xl));margin-bottom:var(--sp-2)}
.th-tagline{font-size:var(--text-base);color:var(--c-text-2);line-height:1.6}
.th-ctas{display:flex;flex-wrap:wrap;gap:var(--sp-3)}
.tool-section{margin-bottom:var(--sp-10)}
.tool-section h2{font-size:var(--text-xl);margin-bottom:var(--sp-4);padding-bottom:var(--sp-3);border-bottom:1px solid var(--c-border)}
.uc-list{list-style:none;display:flex;flex-direction:column;gap:var(--sp-2)}
.uc-item{display:flex;align-items:flex-start;gap:var(--sp-2);font-size:var(--text-sm);color:var(--c-text-2);line-height:1.5}
.tag-cloud{display:flex;flex-wrap:wrap;gap:var(--sp-2)}
.tool-sidebar{position:sticky;top:calc(var(--header-h) + 1rem);display:flex;flex-direction:column;gap:var(--sp-4)}
.sb-card{background:var(--c-bg-2);border:1px solid var(--c-border);border-radius:var(--r-lg);padding:var(--sp-5)}
.sb-card h3{font-size:var(--text-sm);font-weight:700;font-family:var(--font-display);color:var(--c-text-2);text-transform:uppercase;letter-spacing:.05em;margin-bottom:var(--sp-4)}
.sb-table{width:100%;border-collapse:collapse}
.sb-table td{padding:6px 0;font-size:var(--text-sm);vertical-align:top;border-bottom:1px solid var(--c-border)}
.sb-table td:first-child{color:var(--c-text-3);width:40%;font-weight:500}
.sb-table td:last-child{color:var(--c-text);padding-left:var(--sp-3)}
.sb-table tr:last-child td{border-bottom:none}
.sb-features{display:flex;flex-direction:column;gap:var(--sp-2)}
.sb-feat{display:flex;align-items:center;gap:var(--sp-2);font-size:var(--text-sm);color:var(--c-text-2)}
.sb-compare{display:flex;flex-direction:column;gap:2px}
.sb-cmp-link{display:flex;align-items:center;justify-content:space-between;font-size:var(--text-xs);color:var(--c-text-2);text-decoration:none;padding:6px 8px;border-radius:var(--r-sm);transition:all var(--t-fast)}
.sb-cmp-link:hover{background:var(--c-bg-3);color:var(--c-brand-light)}
.sb-cta{background:var(--c-bg-2);border:1px solid var(--c-border);border-radius:var(--r-lg);padding:var(--sp-4)}
</style>
