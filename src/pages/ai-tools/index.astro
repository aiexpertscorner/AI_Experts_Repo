---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/site/Header.astro";
import Footer from "@/components/site/Footer.astro";
import CategoryGrid from "@/components/sections/CategoryGrid.astro";
import FeaturedToolsSection from "@/components/sections/FeaturedToolsSection.astro";

import catMap from "@/data/build/category-map.json";
import featuredData from "@/data/build/featured-tools.json";
import homepageData from "@/data/build/homepage-data.json";

const categories = Object.values(catMap as any).sort((a:any,b:any) => b.count - a.count);
const featuredTools = (featuredData as any)?.global_top ?? [];
const totalTools = (homepageData as any)?.total_tools ?? 19066;

const pricingLinks = [
  { label: "Free", href: "/ai-tools/pricing/free", color: "var(--c-free)" },
  { label: "Freemium", href: "/ai-tools/pricing/freemium", color: "var(--c-freemium)" },
];
const featureLinks = [
  { label: "No-Code", href: "/ai-tools/feature/no-code" },
  { label: "API Access", href: "/ai-tools/feature/api-access" },
  { label: "Open Source", href: "/ai-tools/feature/open-source" },
  { label: "Mobile App", href: "/ai-tools/feature/mobile-app" },
  { label: "Browser Extension", href: "/ai-tools/feature/browser-based" },
  { label: "Team Features", href: "/ai-tools/feature/team-features" },
];
---
<BaseLayout
  title="AI Tools Directory — Browse 19,000+ AI Tools"
  description={`Discover and compare ${totalTools.toLocaleString()}+ AI tools across 23 categories. Filter by pricing, features, industry and more.`}
>
  <Header slot="header"/>

  <div class="container">

    <!-- Hub Header -->
    <div class="hub-header">
      <div class="hub-breadcrumb">
        <a href="/">Home</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <span>AI Tools</span>
      </div>
      <h1>AI Tools Directory</h1>
      <p class="hub-desc">
        Discover, compare and find the best AI tools for every workflow.
        {totalTools.toLocaleString()}+ tools across 23 categories, updated daily.
      </p>

      <!-- Quick filters -->
      <div class="hub-filters">
        <span class="hf-label">Filter by:</span>
        {pricingLinks.map(l => (
          <a href={l.href} class="filter-chip" style={`--chip-color:${l.color}`}>{l.label}</a>
        ))}
        {featureLinks.map(l => (
          <a href={l.href} class="filter-chip">{l.label}</a>
        ))}
        <a href="/vs" class="filter-chip">⚔️ Compare</a>
        <a href="/best" class="filter-chip">🏆 Best-Of</a>
      </div>
    </div>

    <!-- All Categories -->
    <section class="hub-section">
      <div class="section-header">
        <h2>All 23 Categories</h2>
      </div>
      <CategoryGrid categories={categories as any} showAll={true}/>
    </section>

    <hr class="divider"/>

    <!-- Top Tools -->
    {featuredTools.length > 0 && (
      <FeaturedToolsSection
        tools={featuredTools.slice(0, 12)}
        title="Top Rated AI Tools"
        subtitle="Highest-scoring tools across all categories"
        showRank={true}
      />
    )}

    <!-- Browse By Dimension -->
    <section class="hub-section">
      <h2 class="dim-h2">More Ways to Browse</h2>
      <div class="dim-grid">
        <div class="dim-block">
          <h3>By Industry</h3>
          <div class="dim-links">
            {[
              ["Marketing", "/ai-tools/industry/marketing"],
              ["Sales", "/ai-tools/industry/sales"],
              ["Finance", "/ai-tools/industry/finance"],
              ["Healthcare", "/ai-tools/industry/healthcare"],
              ["Legal", "/ai-tools/industry/legal"],
              ["Education", "/ai-tools/industry/education"],
              ["E-commerce", "/ai-tools/industry/e-commerce"],
              ["Software Dev", "/ai-tools/industry/software-dev"],
            ].map(([l,h]) => <a href={h} class="dim-link">{l}</a>)}
          </div>
        </div>
        <div class="dim-block">
          <h3>By Use Case</h3>
          <div class="dim-links">
            {[
              ["Text Generation", "/ai-tools/tag/text-generation"],
              ["Image Generation", "/ai-tools/tag/image-generation"],
              ["Code Assistant", "/ai-tools/tag/code-assistant"],
              ["Writing Assistant", "/ai-tools/tag/writing-assistant"],
              ["SEO & Keywords", "/ai-tools/tag/seo-and-keywords"],
              ["Video Creation", "/ai-tools/tag/video-creation"],
              ["Data & Analytics", "/ai-tools/tag/data-and-analytics"],
              ["Document AI", "/ai-tools/tag/document-ai"],
            ].map(([l,h]) => <a href={h} class="dim-link">{l}</a>)}
          </div>
        </div>
        <div class="dim-block">
          <h3>By Feature</h3>
          <div class="dim-links">
            {[
              ["No-Code", "/ai-tools/feature/no-code"],
              ["API Access", "/ai-tools/feature/api-access"],
              ["Open Source", "/ai-tools/feature/open-source"],
              ["Mobile App", "/ai-tools/feature/mobile-app"],
              ["Browser Extension", "/ai-tools/feature/browser-based"],
              ["Automation", "/ai-tools/feature/automation"],
              ["Templates", "/ai-tools/feature/templates"],
              ["Enterprise", "/ai-tools/feature/enterprise"],
            ].map(([l,h]) => <a href={h} class="dim-link">{l}</a>)}
          </div>
        </div>
        <div class="dim-block">
          <h3>Comparisons</h3>
          <div class="dim-links">
            <a href="/vs" class="dim-link">⚔️ Compare Tools</a>
            <a href="/alternatives" class="dim-link">🔄 Find Alternatives</a>
            <a href="/best" class="dim-link">🏆 Best-Of Lists</a>
            <a href="/ai-tools/pricing/free" class="dim-link">🆓 Free Tools</a>
            <a href="/ai-tools/pricing/freemium" class="dim-link">🔓 Freemium Tools</a>
            <a href="/prompts" class="dim-link">💬 Prompt Library</a>
            <a href="/submit-tool" class="dim-link">➕ Submit a Tool</a>
          </div>
        </div>
      </div>
    </section>

  </div>

  <Footer slot="footer"/>
</BaseLayout>

<style>
.hub-header{padding:var(--sp-10) 0 var(--sp-8);border-bottom:1px solid var(--c-border);margin-bottom:var(--sp-10)}
.hub-breadcrumb{display:flex;align-items:center;gap:var(--sp-2);font-size:var(--text-xs);color:var(--c-text-3);margin-bottom:var(--sp-4)}
.hub-breadcrumb a{color:var(--c-text-3);text-decoration:none}
.hub-breadcrumb a:hover{color:var(--c-brand-light)}
.hub-header h1{font-size:clamp(var(--text-3xl),5vw,var(--text-4xl));margin-bottom:var(--sp-3)}
.hub-desc{font-size:var(--text-base);color:var(--c-text-2);max-width:560px;margin-bottom:var(--sp-6)}
.hub-filters{display:flex;flex-wrap:wrap;gap:var(--sp-2);align-items:center}
.hf-label{font-size:var(--text-xs);font-weight:600;color:var(--c-text-3);text-transform:uppercase;letter-spacing:.05em;margin-right:var(--sp-1)}
.filter-chip{--chip-color:var(--c-text-2)}

.hub-section{margin-bottom:var(--sp-16)}
.dim-h2{font-size:clamp(var(--text-xl),2.5vw,var(--text-2xl));margin-bottom:var(--sp-6)}
.dim-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:var(--sp-6)}
.dim-block h3{font-size:var(--text-sm);font-weight:700;font-family:var(--font-display);color:var(--c-text-2);text-transform:uppercase;letter-spacing:.05em;margin-bottom:var(--sp-3)}
.dim-links{display:flex;flex-direction:column;gap:var(--sp-2)}
.dim-link{font-size:var(--text-sm);color:var(--c-text-2);text-decoration:none;padding:6px 10px;border-radius:var(--r-sm);transition:all var(--t-fast);border:1px solid transparent}
.dim-link:hover{background:var(--c-bg-3);color:var(--c-text);border-color:var(--c-border)}
</style>
