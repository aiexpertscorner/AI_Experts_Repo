---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/site/Header.astro";
import Footer from "@/components/site/Footer.astro";
import CategoryGrid from "@/components/sections/CategoryGrid.astro";
import FeaturedToolsSection from "@/components/sections/FeaturedToolsSection.astro";

import catMap from "@/data/build/category-map.json";
import featuredData from "@/data/build/featured-tools.json";
import homepageData from "@/data/build/homepage-data.json";

const categories = Object.values(catMap as any).sort((a: any, b: any) => b.count - a.count);
const featuredTools = (featuredData as any)?.global_top ?? [];
const totalTools = (homepageData as any)?.total_tools ?? 19066;

const dims = [
  { label: "🆓 Free Tools",        href: "/ai-tools/pricing/free" },
  { label: "⚡ Freemium",          href: "/ai-tools/pricing/freemium" },
  { label: "🧩 No-Code",           href: "/ai-tools/feature/no-code" },
  { label: "🔌 API Access",        href: "/ai-tools/feature/api-access" },
  { label: "🔓 Open Source",       href: "/ai-tools/feature/open-source" },
  { label: "📱 Mobile App",        href: "/ai-tools/feature/mobile-app" },
  { label: "🌐 Browser Extension", href: "/ai-tools/feature/browser-based" },
  { label: "👥 Team Features",     href: "/ai-tools/feature/team-features" },
  { label: "⚔️ Compare Tools",    href: "/vs" },
  { label: "🏆 Best-Of Lists",     href: "/best" },
];
---
<BaseLayout
  title="AI Tools Directory — Browse 19,000+ AI Tools"
  description={`Discover and compare ${totalTools.toLocaleString()}+ AI tools across 23 categories. Filter by pricing, features, industry and more.`}
>
  <Header slot="header"/>
  <div class="container">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      <span>AI Tools</span>
    </nav>

    <!-- Hub header -->
    <div class="hub-hd">
      <div class="hub-hd-left">
        <h1>AI Tools Directory</h1>
        <p>Discover, compare and find the best AI tools for every workflow. {totalTools.toLocaleString()}+ tools across 23 categories, updated daily.</p>

        <!-- Quick dims -->
        <div class="hub-dims">
          {dims.map(d => (
            <a href={d.href} class="filter-chip">{d.label}</a>
          ))}
        </div>
      </div>
      <div class="hub-hd-stats">
        <div class="hub-stat">
          <strong>{totalTools.toLocaleString()}+</strong>
          <span>AI Tools</span>
        </div>
        <div class="hub-stat">
          <strong>23</strong>
          <span>Categories</span>
        </div>
        <div class="hub-stat">
          <strong>Daily</strong>
          <span>Updates</span>
        </div>
      </div>
    </div>

    <!-- Browse by category -->
    <section class="hub-section">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">Discover</span>
          <h2>Browse by Category</h2>
        </div>
        <span class="hub-count">{categories.length} categories</span>
      </div>
      <CategoryGrid categories={categories as any} showAll={true}/>
    </section>

    <!-- Featured tools -->
    {featuredTools.length > 0 && (
      <section class="hub-section">
        <div class="section-header">
          <div>
            <span class="section-eyebrow">Top Rated</span>
            <h2>Most Popular AI Tools</h2>
          </div>
          <a href="/ai-tools" class="see-all">
            View all
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <FeaturedToolsSection tools={featuredTools.slice(0, 9)} showRank={true}/>
      </section>
    )}

    <!-- By industry -->
    <section class="hub-section">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">By Industry</span>
          <h2>AI Tools for Your Industry</h2>
        </div>
      </div>
      <div class="ind-grid">
        {[
          ["🏥", "Healthcare & Wellness",   "/ai-tools/industry/healthcare"],
          ["⚖️", "Finance & Legal",         "/ai-tools/industry/finance"],
          ["📚", "Education & Research",    "/ai-tools/industry/education"],
          ["🛒", "E-Commerce & Retail",     "/ai-tools/industry/ecommerce"],
          ["💻", "Technology & SaaS",       "/ai-tools/industry/technology"],
          ["🎭", "Media & Entertainment",   "/ai-tools/industry/media"],
          ["🏗️", "Real Estate",            "/ai-tools/industry/real-estate"],
          ["📣", "Marketing & Advertising", "/ai-tools/industry/marketing"],
        ].map(([em, label, href]) => (
          <a href={href} class="ind-card">
            <span class="ind-em">{em}</span>
            <span class="ind-label">{label}</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
          </a>
        ))}
      </div>
    </section>

  </div>
  <Footer slot="footer"/>
</BaseLayout>

<style>
.hub-hd {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: var(--sp-10);
  align-items: start;
  padding: var(--sp-10) 0 var(--sp-10);
  border-bottom: 1px solid var(--c-border);
  margin-bottom: var(--sp-12);
}
@media (max-width: 700px) { .hub-hd { grid-template-columns: 1fr } .hub-hd-stats { display: none } }

.hub-hd-left { display: flex; flex-direction: column; gap: var(--sp-5) }
.hub-hd h1   { font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl)) }
.hub-hd p    { font-size: var(--text-lg); max-width: 520px }

.hub-dims { display: flex; flex-wrap: wrap; gap: var(--sp-2) }

.hub-hd-stats {
  display: flex;
  flex-direction: column;
  gap: var(--sp-4);
  background: var(--c-bg-2);
  border: 1px solid var(--c-border);
  border-radius: var(--r-xl);
  padding: var(--sp-5) var(--sp-6);
  min-width: 140px;
}
.hub-stat { display: flex; flex-direction: column; gap: 3px }
.hub-stat strong { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 800; color: var(--c-brand-light); line-height: 1; letter-spacing: -.03em }
.hub-stat span   { font-size: 10px; color: var(--c-text-3); font-weight: 600; text-transform: uppercase; letter-spacing: .06em }

.hub-section { margin-bottom: var(--sp-16) }
.hub-count   { font-size: var(--text-sm); color: var(--c-text-3); font-weight: 500 }

/* Industry grid */
.ind-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: var(--sp-3);
}
.ind-card {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  padding: 12px var(--sp-4);
  background: var(--c-bg-2);
  border: 1px solid var(--c-border);
  border-radius: var(--r-lg);
  text-decoration: none;
  transition: all var(--t-fast);
}
.ind-card:hover { border-color: var(--c-border-hover); background: var(--c-bg-3); color: var(--c-text) }
.ind-em    { font-size: 16px; flex-shrink: 0 }
.ind-label { flex: 1; font-size: var(--text-sm); font-weight: 600; font-family: var(--font-display); color: var(--c-text-2); letter-spacing: -.01em; line-height: 1.3 }
.ind-card:hover .ind-label { color: var(--c-text) }
.ind-card svg { color: var(--c-text-4); flex-shrink: 0; transition: transform var(--t-fast), color var(--t-fast) }
.ind-card:hover svg { transform: translateX(2px); color: var(--c-brand-light) }
</style>
