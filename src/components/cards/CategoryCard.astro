---
import CategoryIcon from "@/components/site/CategoryIcon.astro";

interface Props {
  category: {
    slug: string;
    name: string;
    count: number;
    description?: string;
  };
}

const { category } = Astro.props;
---

<a 
  href={`/tools/category/${category.slug}`} 
  class="group relative flex flex-col p-6 rounded-2xl border border-ai-border bg-ai-surface/50 hover:bg-ai-surface-elevated hover:border-ai-primary/50 transition-all duration-300 hover:-translate-y-1 shadow-lg shadow-black/20"
>
  <!-- Icon Well: Maakt het icoon beheersbaar en stijlvol -->
  <div class="mb-6 flex items-center justify-between">
    <div class="w-14 h-14 flex items-center justify-center rounded-xl bg-ai-dark border border-ai-border group-hover:border-ai-primary/30 transition-colors">
      <CategoryIcon slug={category.slug} class="w-7 h-7 text-ai-text-secondary group-hover:text-ai-primary transition-colors" />
    </div>
    <span class="text-[10px] font-bold uppercase tracking-widest text-ai-text-faint bg-ai-dark px-2 py-1 rounded-md border border-ai-border">
      {category.count.toLocaleString()} Tools
    </span>
  </div>

  <div class="flex-1">
    <h3 class="text-xl font-bold text-white mb-2 group-hover:text-ai-primary transition-colors">
      {category.name}
    </h3>
    <p class="text-sm text-ai-text-secondary leading-relaxed line-clamp-3">
      {category.description || `Explore the best ${category.name.toLowerCase()} tools, compare features and optimize your workflow.`}
    </p>
  </div>

  <div class="mt-6 pt-4 border-t border-ai-border flex items-center justify-between">
    <span class="text-xs font-bold text-ai-primary uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity">
      Explore Hub
    </span>
    <svg class="w-5 h-5 text-ai-text-faint group-hover:text-ai-primary transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M7 17 17 7M7 7h10v10" />
    </svg>
  </div>
</a>