---
import { getCategoryIconBySlug } from "@/data/categoryIcons";
interface Props {
  name:         string;
  slug:         string;
  count:        number;
  description?: string;
  topTools?:    string[];
}
const { name, slug, count, description, topTools = [] } = Astro.props;
const icon = getCategoryIconBySlug(slug);
---
<a href={`/ai-tools/category/${slug}`} class="cc">
  <!-- Icon -->
  <div class="cc-icon" set:html={icon} aria-hidden="true"/>

  <!-- Body -->
  <div class="cc-body">
    <strong class="cc-name">{name}</strong>
    {description && <p class="cc-desc">{description}</p>}
  </div>

  <!-- Meta + arrow -->
  <div class="cc-right">
    <span class="cc-count">{count >= 1000 ? `${(count/1000).toFixed(1)}k` : count}</span>
    <svg class="cc-arr" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
  </div>
</a>

<style>
.cc {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  padding: var(--sp-4) var(--sp-4);
  border-radius: var(--r-xl);
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  text-decoration: none;
  transition: border-color var(--t-base), background var(--t-base),
              box-shadow var(--t-base), transform var(--t-base);
  position: relative;
  overflow: hidden;
}
/* Subtle inner glow */
.cc::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 60% 60% at 0% 50%, var(--glow-brand-xs) 0%, transparent 70%);
  opacity: 1;
  transition: opacity var(--t-base);
  pointer-events: none;
}
.cc:hover {
  border-color: var(--card-hover-border);
  box-shadow: var(--card-hover-shadow);
  transform: var(--card-hover-lift);
}
.cc:hover::before { opacity: 3 }

/* Icon container */
.cc-icon {
  width: 36px;
  height: 36px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(79,110,247,.08);
  border: 1px solid rgba(79,110,247,.14);
  border-radius: var(--r-md);
  transition: background var(--t-base), border-color var(--t-base);
}
.cc:hover .cc-icon {
  background: rgba(79,110,247,.14);
  border-color: rgba(79,110,247,.28);
}
.cc-icon :global(svg) {
  width: 18px;
  height: 18px;
}

/* Body */
.cc-body  { flex: 1; min-width: 0 }
.cc-name {
  display: block;
  font-family: var(--font-display);
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--c-text);
  letter-spacing: -.015em;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cc-desc {
  display: block;
  font-size: 11px;
  color: var(--c-text-4);
  margin-top: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 0;
  line-height: 1.4;
}

/* Right side */
.cc-right {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}
.cc-count {
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 600;
  color: var(--c-brand-light);
  letter-spacing: -.01em;
  opacity: .7;
}
.cc-arr {
  color: var(--c-text-4);
  transition: transform var(--t-fast), color var(--t-fast);
  flex-shrink: 0;
}
.cc:hover .cc-arr { transform: translateX(2px); color: var(--c-brand-light) }
</style>
