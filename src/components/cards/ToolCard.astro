---
interface ToolShape {
  name?: string;
  handle?: string;
  slug?: string;
  tagline?: string;
  short?: string;
  desc?: string;
  description?: string;
  pricing_tier?: string;
  pricing?: string;
  logo_domain?: string;
  logo_url?: string;
  feature_tags?: string[];
  tags?: string[];
  category?: string;
  category_slug?: string;
  is_featured?: boolean;
  affiliate_url?: string;
  website_url?: string;
}

interface Props {
  tool: ToolShape;
  rank?: number;
  compact?: boolean;
  variant?: "default" | "authority" | "row";
  showDescription?: boolean;
  showPricing?: boolean;
  showCategory?: boolean;
  showCTA?: boolean;
}

const {
  tool,
  rank,
  compact = false,
  variant = "default",
  showDescription = true,
  showPricing = true,
  showCategory = true,
  showCTA = false,
} = Astro.props;

const resolvedHandle = tool?.handle || tool?.slug || "tool";
const resolvedName = tool?.name || resolvedHandle;
const resolvedPricing = String(tool?.pricing_tier || tool?.pricing || "unknown").toLowerCase();
const resolvedTags = (
  Array.isArray(tool?.feature_tags) && tool.feature_tags.length
    ? tool.feature_tags
    : tool?.tags ||[]
).slice(0, 3);

const resolvedDescription = String(
  tool?.tagline || tool?.short || tool?.desc || tool?.description || ""
).slice(0, 120);

const categorySlug =
  tool?.category_slug ||
  String(tool?.category || "other-ai-tools").toLowerCase().replace(/[^a-z0-9]+/g, "-");

const href = tool?.affiliate_url || `/tools/${resolvedHandle}`;
const isAffiliate = !!tool?.affiliate_url;

/* Logo afhandeling */
const resolvedLogoDomain =
  tool?.logo_domain ||
  tool?.website_url?.replace(/^https?:\/\//, "").replace(/^www\./, "").split("/")[0] ||
  "";
const logoSrc =
  tool?.logo_url ||
  (resolvedLogoDomain ? `https://logo.clearbit.com/${resolvedLogoDomain}?size=64` : null);

const fallbackLetter = (resolvedName || "A").charAt(0).toUpperCase();

const classes =[
  "tc-card",
  `tc-card--${variant}`,
  compact ? "tc-card--compact" : "",
  tool?.is_featured ? "tc-card--featured" : "",
].filter(Boolean).join(" ");

const pricingLabel: Record<string, string> = {
  free: "Free",
  freemium: "Freemium",
  paid: "Paid",
  unknown: "Unknown",
};
---

<article class={classes}>
  <div class="tc-content">
    
    <!-- Lichte, uitspringende logo wrapper -->
    <div class="tc-logo-wrapper">
      {logoSrc ? (
        <>
          <img
            src={logoSrc}
            alt={`${resolvedName} logo`}
            width="48"
            height="48"
            loading="lazy"
            decoding="async"
            class="tc-logo-img"
            onerror="this.onerror=null;this.style.display='none';this.nextElementSibling.style.display='flex';"
          />
          <span class="tc-logo-fallback" style="display:none;">
            {fallbackLetter}
          </span>
        </>
      ) : (
        <span class="tc-logo-fallback">{fallbackLetter}</span>
      )}
    </div>

    <!-- Titel & Badge in één rij, zoals in je design -->
    <header class="tc-header">
      <h3 class="tc-name">
        <a
          href={href}
          class="tc-main-link"
          target={isAffiliate ? "_blank" : undefined}
          rel={isAffiliate ? "noopener sponsored" : undefined}
        >
          {resolvedName}
        </a>
      </h3>

      {showPricing ? (
        <span class={`tc-badge tc-badge--${resolvedPricing}`}>
          {pricingLabel[resolvedPricing] || "Unknown"}
        </span>
      ) : null}
    </header>

    {/* Categorie in strakke uppercase style */}
    {showCategory && tool?.category ? (
      <span class="tc-category">{tool.category}</span>
    ) : null}

    {showDescription && resolvedDescription && variant !== "row" ? (
      <p class="tc-desc">
        {resolvedDescription}
        {resolvedDescription.length >= 120 ? "…" : ""}
      </p>
    ) : null}

    {variant !== "row" && !compact && resolvedTags.length > 0 ? (
      <div class="tc-tags">
        {resolvedTags.map((tag) => <span class="tc-tag">{tag}</span>)}
      </div>
    ) : null}
  </div>

  <footer class="tc-footer">
    <div class="tc-footer-left">
      {showCTA ? (
        <span class="tc-action-link">
          Visit {resolvedName} 
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
        </span>
      ) : (
        <span class="tc-action-link">
          {tool?.category ? (
            <a href={`/tools/category/${categorySlug}`} class="tc-category-link">
              More in {tool.category} 
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
            </a>
          ) : (
             <>View details <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg></>
          )}
        </span>
      )}
    </div>

    <!-- Rank badge rechtsonderin (zoals in bijlage 2) -->
    {typeof rank === "number" ? <span class="tc-rank">#{rank}</span> : null}
    
    {tool?.is_featured && typeof rank !== "number" ? (
       <div class="tc-featured-indicator" title="Featured Tool">
         <span class="tc-dot tc-dot-ping"></span>
         <span class="tc-dot tc-dot-static"></span>
       </div>
    ) : null}
  </footer>
</article>

<style>
  /* --- High-End Dark Theme Integration Variables --- */
  article {
    /* Base colors that match your dark background (e.g. #0B0F1C) */
    --tc-bg: #111624; /* Subtiel lichtere blauw/zwarte tint voor de kaart */
    --tc-border: #1e293b; 
    --tc-hover-border: #3b82f640; /* Subtiele blauwe gloed op hover */
    --tc-text-main: #f8fafc;
    --tc-text-muted: #94a3b8;
    --tc-primary: #60a5fa; /* Lichtere blauw voor links in dark mode */
    --tc-radius: 16px;
    --tc-transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Inherit fonts van je website */
  .tc-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--tc-bg);
    border: 1px solid var(--tc-border);
    border-radius: var(--tc-radius);
    overflow: hidden;
    transition: var(--tc-transition);
    font-family: inherit; 
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .tc-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.4), 0 0 16px rgba(59, 130, 246, 0.05);
    border-color: var(--tc-hover-border);
  }

  /* Maakt de hele kaart klikbaar o.b.v. de main link */
  .tc-main-link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .tc-content {
    padding: 1.5rem 1.25rem 1.25rem 1.25rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  /* --- Logo Wrapper (Licht & Diepte, zoals gevraagd) --- */
  .tc-logo-wrapper {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    border-radius: 14px;
    /* Lichte achtergrond met subtiele gradient */
    background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%);
    /* Harde schaduw naar buiten (diepte) + Witte rand naar binnen (bevel effect) */
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.5), inset 0 2px 4px rgba(255, 255, 255, 0.8);
    border: 1px solid #e2e8f0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin-bottom: 1.25rem; /* Ruimte tussen logo en titel */
  }

  .tc-logo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: #ffffff; /* Zorgt dat transparante PNGs mooi blijven */
  }

  .tc-logo-fallback {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f172a; /* Donkere fallback letter omdat de bg licht is */
  }

  /* --- Header (Titel + Badge op één rij) --- */
  .tc-header {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 0.35rem;
  }

  .tc-name {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--tc-text-main);
    line-height: 1.2;
  }

  .tc-main-link {
    text-decoration: none;
    color: inherit;
  }

  /* --- Categorie (Strakke dark mode styling) --- */
  .tc-category {
    font-size: 0.65rem;
    color: var(--tc-text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
    display: block;
  }

  /* --- Dark Theme Pricing Badges --- */
  .tc-badge {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    letter-spacing: 0.025em;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  /* Transparante donkere badges met neon/gekleurde tekst (zoals in je design) */
  .tc-badge--free { background: rgba(34, 197, 94, 0.1); color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.2); }
  .tc-badge--freemium { background: rgba(59, 130, 246, 0.1); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.2); }
  .tc-badge--paid { background: rgba(249, 115, 22, 0.1); color: #fb923c; border: 1px solid rgba(249, 115, 22, 0.2); }
  .tc-badge--unknown { background: rgba(148, 163, 184, 0.1); color: #94a3b8; border: 1px solid rgba(148, 163, 184, 0.2); }

  /* --- Description & Tags --- */
  .tc-desc {
    margin: 0 0 1rem 0;
    font-size: 0.875rem;
    color: var(--tc-text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
  }

  .tc-tag {
    font-size: 0.7rem;
    background: rgba(255, 255, 255, 0.05);
    color: var(--tc-text-muted);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-weight: 500;
  }

  /* --- Footer --- */
  .tc-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    background: transparent;
    border-top: 1px solid var(--tc-border);
    margin-top: auto;
  }

  .tc-action-link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--tc-primary);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .tc-category-link {
    position: relative;
    z-index: 2; 
    text-decoration: none;
    color: inherit;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .tc-category-link:hover {
    color: #93c5fd;
  }

  /* --- Rank Badge rechtsonder --- */
  .tc-rank {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #1e293b;
    color: #94a3b8;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    z-index: 2;
  }

  /* --- Featured State --- */
  .tc-card--featured {
    border: 1px solid var(--tc-primary);
    box-shadow: 0 0 15px rgba(59, 130, 246, 0.15);
  }

  .tc-featured-indicator {
    position: relative;
    display: flex;
    height: 10px;
    width: 10px;
  }

  .tc-dot {
    position: absolute;
    border-radius: 50%;
    height: 100%;
    width: 100%;
    background-color: var(--tc-primary);
  }

  .tc-dot-ping {
    animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
    opacity: 0.75;
  }

  @keyframes ping {
    75%, 100% { transform: scale(2.5); opacity: 0; }
  }

  /* --- Compact Variant --- */
  .tc-card--compact .tc-content {
    padding: 1.25rem 1rem 1rem 1rem;
  }
  
  .tc-card--compact .tc-logo-wrapper {
    width: 48px;
    height: 48px;
    margin-bottom: 1rem;
  }

  .tc-card--compact .tc-footer {
    padding: 0.75rem 1rem;
  }
</style>