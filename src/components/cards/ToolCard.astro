---
interface ToolShape {
  name?: string;
  handle?: string;
  slug?: string;
  tagline?: string;
  short?: string;
  desc?: string;
  description?: string;
  pricing_tier?: string;
  pricing?: string;
  logo_domain?: string;
  logo_url?: string;
  feature_tags?: string[];
  tags?: string[];
  category?: string;
  category_slug?: string;
  is_featured?: boolean;
  affiliate_url?: string;
  website_url?: string;
}

interface Props {
  tool: ToolShape;
  rank?: number;
  compact?: boolean;
  variant?: "default" | "authority" | "row";
  showDescription?: boolean;
  showPricing?: boolean;
  showCategory?: boolean;
  showCTA?: boolean;
}

const {
  tool,
  rank,
  compact = false,
  variant = "default",
  showDescription = true,
  showPricing = true,
  showCategory = true,
  showCTA = false,
} = Astro.props;

const resolvedHandle = tool?.handle || tool?.slug || "tool";
const resolvedName = tool?.name || resolvedHandle;
const resolvedPricing = String(tool?.pricing_tier || tool?.pricing || "unknown").toLowerCase();
const resolvedTags = (Array.isArray(tool?.feature_tags) && tool.feature_tags.length ? tool.feature_tags : tool?.tags || []).slice(0, 3);
const resolvedDescription = String(tool?.tagline || tool?.short || tool?.desc || tool?.description || "").slice(0, 120);
const categorySlug = tool?.category_slug || String(tool?.category || "other-ai-tools").toLowerCase().replace(/[^a-z0-9]+/g, "-");
const href = tool?.affiliate_url || `/ai-tools/${resolvedHandle}`;
const isAffiliate = !!tool?.affiliate_url;

let logoSrc = tool?.logo_url || "";
if (!logoSrc && tool?.logo_domain) {
  logoSrc = `https://www.google.com/s2/favicons?domain=${tool.logo_domain}&sz=128`;
}

const classes = [
  "tool-card",
  `tool-card--${variant}`,
  compact ? "tool-card--compact" : "",
  tool?.is_featured ? "tool-card--featured" : "",
].filter(Boolean).join(" ");

const pricingLabel: Record<string, string> = {
  free: "Free",
  freemium: "Freemium",
  paid: "Paid",
  unknown: "Unknown",
};
---

<article class={classes}>
  {typeof rank === "number" ? <span class="tool-card__rank">#{rank}</span> : null}

  <a href={href} class="tool-card__link" target={isAffiliate ? "_blank" : undefined} rel={isAffiliate ? "noopener sponsored" : undefined}>
    <header class="tool-card__header">
      <div class="tool-card__logo-wrapper">
        {logoSrc ? (
          <>
            <img src={logoSrc} alt={`${resolvedName} logo`} width="48" height="48" loading="lazy" decoding="async" class="tool-card__logo-img" onerror="this.remove(); this.nextElementSibling?.classList.remove('is-hidden');" />
            <span class="tool-card__logo-fallback is-hidden">{resolvedName.charAt(0).toUpperCase()}</span>
          </>
        ) : (
          <span class="tool-card__logo-fallback">{resolvedName.charAt(0).toUpperCase()}</span>
        )}
      </div>

      <div class="tool-card__info">
        <h3 class="tool-card__name">{resolvedName}</h3>
        {showCategory && tool?.category ? <span class="tool-card__category">{tool.category}</span> : null}
      </div>

      {showPricing ? <span class={`badge badge--${resolvedPricing}`}>{pricingLabel[resolvedPricing] || "Unknown"}</span> : null}
    </header>

    {showDescription && resolvedDescription && variant !== "row" ? (
      <p class="tool-card__desc">{resolvedDescription}{resolvedDescription.length >= 120 ? "…" : ""}</p>
    ) : null}

    {variant !== "row" && !compact && resolvedTags.length > 0 ? (
      <div class="tool-card__tags">
        {resolvedTags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    ) : null}

    <footer class="tool-card__footer">
      <div class="tool-card__footer-left">
        {showCTA ? (
          <span class="tool-card__cta">Visit {resolvedName}</span>
        ) : (
          <span class="tool-card__hint">{tool?.category ? <a href={`/ai-tools/category/${categorySlug}`} class="tool-card__category-link">Open category</a> : "View details"}</span>
        )}
      </div>
      {tool?.is_featured ? <span class="tool-card__featured-dot"></span> : null}
    </footer>
  </a>
</article>
