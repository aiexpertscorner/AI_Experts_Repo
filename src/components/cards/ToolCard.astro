---
interface Props {
  tool: any;
  rank?: number;
  compact?: boolean;
}
const { tool, rank, compact = false } = Astro.props;
const {
  name = "", handle = "", tagline = "", description = "",
  pricing_tier = "unknown", logo_domain = "", feature_tags = [],
  category = "", category_slug = "", is_featured = false,
  affiliate_url = "", website_url = ""
} = tool;

const pricingClass: Record<string, string> = {
  free: "badge-free", freemium: "badge-freemium", paid: "badge-paid"
};
const pricingLabel: Record<string, string> = {
  free: "Free", freemium: "Freemium", paid: "Paid"
};
const tier = (pricing_tier || "unknown").toLowerCase();
const logoSrc = logo_domain ? `https://logo.clearbit.com/${logo_domain}?size=64` : null;
const fallback = (name || "A").charAt(0).toUpperCase();
const tags = (Array.isArray(feature_tags) ? feature_tags : []).slice(0, 3);
const href = affiliate_url || `/ai-tools/${handle}`;
const isAffiliate = !!affiliate_url;
const catSlug = category_slug || (category || "").toLowerCase().replace(/[^a-z0-9]+/g, "-");
const desc = (tagline || description || "").slice(0, 110);
---
<article class:list={["tc", { compact }]}>
  {rank && <span class="tc-rank">#{rank}</span>}
  <a
    href={href}
    class="tc-a"
    target={isAffiliate ? "_blank" : undefined}
    rel={isAffiliate ? "noopener sponsored" : undefined}
  >
    <div class="tc-top">
      <div class="tc-logo-wrap">
        {logoSrc && (
          <img
            src={logoSrc}
            alt=""
            width="40" height="40"
            loading="lazy"
            class="tc-logo-img"
            onerror="this.onerror=null;this.style.display='none';this.nextElementSibling.style.display='flex'"
          />
        )}
        <span class="tc-fallback" style={logoSrc ? "display:none" : ""}>{fallback}</span>
      </div>
      <div class="tc-info">
        <strong class="tc-name">{name}</strong>
        {category && (
          <a
            href={`/ai-tools/category/${catSlug}`}
            class="tc-cat"
            onclick="event.stopPropagation()"
          >{category}</a>
        )}
      </div>
      <span class:list={["badge", pricingClass[tier] || "badge-unknown"]}>
        {pricingLabel[tier] || pricing_tier}
      </span>
    </div>

    {!compact && desc && <p class="tc-desc">{desc}{desc.length >= 110 ? "…" : ""}</p>}

    {!compact && tags.length > 0 && (
      <div class="tc-tags">
        {tags.map((t: string) => <span class="tag">{t}</span>)}
      </div>
    )}

    <div class="tc-foot">
      <span class="tc-cta">
        Visit {name}
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
      </span>
      {is_featured && <span class="tc-feat-badge">⭐ Featured</span>}
    </div>
  </a>
</article>

<style>
.tc {
  position: relative;
  background: var(--c-bg-2);
  border: 1px solid var(--c-border);
  border-radius: var(--r-xl);
  overflow: hidden;
  transition: border-color var(--t-base), box-shadow var(--t-base), transform var(--t-base);
  display: flex;
  flex-direction: column;
}
.tc::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--c-brand-glow-xs) 0%, transparent 60%);
  opacity: 0;
  transition: opacity var(--t-base);
  pointer-events: none;
  border-radius: inherit;
}
.tc:hover {
  border-color: var(--c-border-hover);
  box-shadow: 0 0 0 1px rgba(79,110,247,.2), 0 8px 32px rgba(79,110,247,.1);
  transform: translateY(-2px);
}
.tc:hover::before { opacity: 1 }

/* Rank badge */
.tc-rank {
  position: absolute;
  top: 10px; right: 10px;
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 700;
  color: var(--c-text-3);
  background: var(--c-bg-4);
  padding: 2px 7px;
  border-radius: var(--r-full);
  border: 1px solid var(--c-border);
  z-index: 1;
}

/* Link wrapper */
.tc-a {
  padding: var(--sp-5);
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
  text-decoration: none;
  flex: 1;
}

/* Top row */
.tc-top {
  display: flex;
  align-items: flex-start;
  gap: var(--sp-3);
}

/* Logo */
.tc-logo-wrap {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  flex-shrink: 0;
  background: var(--c-bg-4);
  border: 1px solid var(--c-border);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.tc-logo-img { width: 40px; height: 40px; object-fit: contain }
.tc-fallback {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 800;
  font-family: var(--font-display);
  color: var(--c-brand-light);
  background: linear-gradient(135deg, var(--c-brand-glow) 0%, var(--c-violet-glow) 100%);
}

/* Name + cat */
.tc-info { flex: 1; min-width: 0 }
.tc-name {
  display: block;
  font-size: var(--text-sm);
  font-weight: 700;
  font-family: var(--font-display);
  color: var(--c-text);
  margin-bottom: 3px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: -.01em;
}
.tc-cat {
  display: block;
  font-size: 10px;
  color: var(--c-text-3);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .05em;
  text-decoration: none;
  transition: color var(--t-fast);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.tc-cat:hover { color: var(--c-brand-light) }

/* Description */
.tc-desc {
  font-size: var(--text-sm);
  color: var(--c-text-2);
  line-height: 1.55;
  flex: 1;
}

/* Tags */
.tc-tags { display: flex; flex-wrap: wrap; gap: 4px }

/* Footer */
.tc-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: var(--sp-2);
  border-top: 1px solid var(--c-border-subtle);
  margin-top: auto;
}
.tc-cta {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: var(--text-xs);
  font-weight: 600;
  font-family: var(--font-display);
  color: var(--c-brand-light);
  opacity: 0;
  transition: opacity var(--t-fast);
  letter-spacing: .01em;
}
.tc:hover .tc-cta { opacity: 1 }
.tc-feat-badge {
  font-size: 10px;
  color: var(--c-paid);
  font-weight: 600;
  font-family: var(--font-display);
}

/* Compact variant */
.tc.compact .tc-a { padding: var(--sp-3) var(--sp-4); gap: var(--sp-2) }
.tc.compact .tc-foot { display: none }
</style>
