---
import ToolCard from "@/components/cards/ToolCard.astro";

interface Props {
  tool: any;
  rank?: number;
  compact?: boolean;
  featured?: boolean;
}

const { tool, rank, compact = false, featured = false } = Astro.props;

const mergedTool = {
  ...tool,
  is_featured: tool?.is_featured || featured,
};
---

<ToolCard
  tool={mergedTool}
  rank={rank}
  compact={compact}
  variant="authority"
  showDescription={true}
  showPricing={true}
  showCategory={true}
  showCTA={true}
/>