---
/**
 * AuthorityToolCard — compact horizontal card for ranked tools
 * Used in: Global Top 100, Category Top 10, Featured authority sections
 */
interface Props {
  handle:       string;
  name:         string;
  display_name?: string;
  logo_url?:    string;
  logo_domain?: string;
  category?:    string;
  cat_slug?:    string;
  pricing_tier?: string;
  tagline?:     string;
  rank?:        number;
  website_url?: string;
  global_rank?: number;
  in_production?: boolean;
}
const {
  handle,
  name,
  display_name,
  logo_url,
  logo_domain,
  category    = "",
  cat_slug    = "",
  pricing_tier = "unknown",
  tagline     = "",
  rank,
  website_url = "",
  global_rank,
  in_production = true,
} = Astro.props;

const displayName  = display_name || name;
const tier         = (pricing_tier || "unknown").toLowerCase();
const logoSrc      = logo_url || (logo_domain ? `https://logo.clearbit.com/${logo_domain}?size=48` : null);
const fallbackChar = (displayName || "A").charAt(0).toUpperCase();
const href         = in_production ? `/ai-tools/${handle}` : (website_url || "#");
const showRank     = rank ?? global_rank;
const catHref      = cat_slug ? `/ai-tools/category/${cat_slug}` : null;

const pricingLabel: Record<string,string> = {
  free: "Free", freemium: "Freemium", paid: "Paid"
};
---
<a
  href={href}
  class="atc"
  target={!in_production ? "_blank" : undefined}
  rel={!in_production ? "noopener" : undefined}
>
  {showRank && (
    <span class="atc-rank" aria-label={`Rank ${showRank}`}>
      {String(showRank).padStart(2, "0")}
    </span>
  )}

  <div class="atc-logo">
    {logoSrc ? (
      <img
        src={logoSrc}
        alt=""
        width="36"
        height="36"
        loading="lazy"
        decoding="async"
        class="atc-logo-img"
        onerror="this.onerror=null;this.style.display='none';this.nextElementSibling.style.display='flex'"
      />
    ) : null}
    <span class="atc-logo-fb" style={logoSrc ? "display:none" : ""}>{fallbackChar}</span>
  </div>

  <div class="atc-body">
    <span class="atc-name">{displayName}</span>
    {tagline && <span class="atc-tagline">{tagline.slice(0, 60)}</span>}
  </div>

  <div class="atc-meta">
    {category && catHref && (
      <span class="atc-cat">{category}</span>
    )}
    <span class:list={["badge", `badge-${tier}`]}>
      {pricingLabel[tier] || pricing_tier}
    </span>
  </div>

  <svg class="atc-arr" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
</a>

<style>
.atc {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  padding: 12px var(--sp-4);
  border-radius: var(--r-lg);
  background: var(--card-bg);
  border: 1px solid var(--c-border-subtle);
  text-decoration: none;
  transition: border-color var(--t-fast), background var(--t-fast), transform var(--t-fast);
  position: relative;
  overflow: hidden;
}
.atc:hover {
  border-color: var(--c-border-hover);
  background: var(--c-bg-3);
  transform: translateX(2px);
}

/* Rank */
.atc-rank {
  font-family: var(--font-mono);
  font-size: var(--text-2xs);
  font-weight: 700;
  letter-spacing: .02em;
  color: var(--c-text-4);
  min-width: 24px;
  flex-shrink: 0;
  text-align: right;
}

/* Logo */
.atc-logo {
  width: 36px;
  height: 36px;
  border-radius: var(--r-sm);
  background: var(--c-bg-4);
  border: 1px solid var(--c-border-subtle);
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.atc-logo-img {
  width: 36px;
  height: 36px;
  object-fit: contain;
}
.atc-logo-fb {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 800;
  color: var(--c-brand-light);
  background: linear-gradient(135deg, var(--glow-brand) 0%, var(--glow-violet) 100%);
}

/* Body */
.atc-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.atc-name {
  font-family: var(--font-display);
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--c-text);
  letter-spacing: -.015em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.atc-tagline {
  font-size: 11px;
  color: var(--c-text-3);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}

/* Meta */
.atc-meta {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  flex-shrink: 0;
}
.atc-cat {
  font-family: var(--font-display);
  font-size: var(--text-2xs);
  font-weight: 600;
  color: var(--c-text-4);
  text-transform: uppercase;
  letter-spacing: .05em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100px;
}
@media (max-width: 640px) { .atc-cat { display: none } }
@media (max-width: 480px) { .atc-meta .badge { display: none } }

/* Arrow */
.atc-arr {
  color: var(--c-text-4);
  flex-shrink: 0;
  opacity: 0;
  transition: opacity var(--t-fast), transform var(--t-fast);
}
.atc:hover .atc-arr { opacity: 1; transform: translateX(2px) }
</style>
