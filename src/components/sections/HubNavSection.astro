---
/**
 * HubNavSection — 6 platform hub cards
 * Primary internal navigation block for the homepage.
 */
import { MAIN_NAV } from "@/data/homeConfig";

const hubs = [
  {
    title:   "AI Tools",
    href:    "/tools",
    soon:    false,
    stat:    "19,000+ tools",
    desc:    "Browse, filter and compare tools across 23 categories.",
    icon:    `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    accent:  "brand",
  },
  {
    title:   "Prompts",
    href:    "/prompts",
    soon:    true,
    stat:    "Coming soon",
    desc:    "Curated prompts for ChatGPT, Claude, Midjourney and more.",
    icon:    `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
    accent:  "violet",
  },
  {
    title:   "Workflows",
    href:    "/ai-workflows",
    soon:    true,
    stat:    "Coming soon",
    desc:    "Step-by-step AI automation workflows for every role.",
    icon:    `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
    accent:  "brand",
  },
  {
    title:   "Learn AI",
    href:    "/learn-ai",
    soon:    true,
    stat:    "Coming soon",
    desc:    "Guides, tutorials and courses to master AI tools faster.",
    icon:    `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>`,
    accent:  "cyan",
  },
  {
    title:   "Compare",
    href:    "/vs",
    soon:    false,
    stat:    "73k+ pairs",
    desc:    "Side-by-side comparisons: pricing, features and ratings.",
    icon:    `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>`,
    accent:  "brand",
  },
  {
    title:   "Best Of",
    href:    "/best",
    soon:    false,
    stat:    "Curated lists",
    desc:    "Expert-ranked best-of lists for every workflow and role.",
    icon:    `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`,
    accent:  "violet",
  },
];
---

<section class="hubs-section">
  <div class="section-header">
    <div>
      <span class="section-eyebrow">Platform</span>
      <h2>Explore the Platform</h2>
    </div>
  </div>
  <div class="hubs-grid">
    {hubs.map(h => (
      <a
        href={h.soon ? undefined : h.href}
        class:list={["hub-card", h.soon && "hub-card--soon"]}
        aria-disabled={h.soon ? "true" : undefined}
      >
        <div class="hub-card-top">
          <div class:list={["hub-icon", `hub-icon--${h.accent}`]} set:html={h.icon} aria-hidden="true"/>
          <svg class="hub-arr" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
        </div>
        <div class="hub-card-body">
          <span class="hub-title">
            {h.title}
            {h.soon && <span class="hub-soon">Soon</span>}
          </span>
          <p class="hub-desc">{h.desc}</p>
        </div>
        <span class="hub-stat">{h.stat}</span>
      </a>
    ))}
  </div>
</section>

<style>
.hubs-section { margin-bottom: var(--sp-20) }

.hubs-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-3);
}
@media (max-width: 900px) { .hubs-grid { grid-template-columns: repeat(2, 1fr) } }
@media (max-width: 540px) { .hubs-grid { grid-template-columns: 1fr } }

/* Base card */
.hub-card {
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
  padding: var(--sp-5);
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: var(--card-radius);
  text-decoration: none;
  transition: border-color var(--t-base), box-shadow var(--t-base), transform var(--t-base);
  position: relative;
  overflow: hidden;
}
/* Ambient glow sweep */
.hub-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 80% 60% at 0% 110%, var(--glow-brand-xs) 0%, transparent 65%);
  pointer-events: none;
  border-radius: inherit;
  transition: opacity var(--t-base);
}
.hub-card:hover {
  border-color: var(--card-hover-border);
  box-shadow: var(--card-hover-shadow);
  transform: var(--card-hover-lift);
}
.hub-card:hover::before { opacity: 3 }

/* Soon state */
.hub-card--soon {
  cursor: default;
  pointer-events: none;
  opacity: .6;
}
.hub-card--soon .hub-arr { display: none }

/* Top row */
.hub-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* Icon */
.hub-icon {
  width: 40px; height: 40px;
  display: flex; align-items: center; justify-content: center;
  border-radius: var(--r-md);
  border: 1px solid transparent;
  transition: background var(--t-fast), border-color var(--t-fast);
  flex-shrink: 0;
}
.hub-icon--brand {
  background: rgba(79,110,247,.08);
  border-color: rgba(79,110,247,.16);
  color: var(--c-brand-light);
}
.hub-icon--violet {
  background: rgba(124,58,237,.08);
  border-color: rgba(124,58,237,.18);
  color: var(--c-violet-light);
}
.hub-icon--cyan {
  background: rgba(6,182,212,.08);
  border-color: rgba(6,182,212,.16);
  color: var(--c-cyan-light);
}
.hub-card:hover .hub-icon--brand  { background: rgba(79,110,247,.15); border-color: rgba(79,110,247,.30) }
.hub-card:hover .hub-icon--violet { background: rgba(124,58,237,.15); border-color: rgba(124,58,237,.30) }
.hub-card:hover .hub-icon--cyan   { background: rgba(6,182,212,.12);  border-color: rgba(6,182,212,.28) }

/* Arrow */
.hub-arr {
  color: var(--c-text-4);
  transition: transform var(--t-fast), color var(--t-fast), opacity var(--t-fast);
  opacity: 0;
}
.hub-card:hover .hub-arr {
  opacity: 1;
  transform: translate(2px, -2px);
  color: var(--c-brand-light);
}

/* Body */
.hub-card-body { display: flex; flex-direction: column; gap: 4px }
.hub-title {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  font-family: var(--font-display);
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--c-text);
  letter-spacing: -.02em;
  line-height: 1.2;
}
.hub-desc {
  font-size: var(--text-xs);
  color: var(--c-text-3);
  line-height: var(--lh-snug);
  margin: 0;
}

/* Stat footer */
.hub-stat {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--c-brand-light);
  opacity: .65;
  letter-spacing: .01em;
  margin-top: auto;
  padding-top: var(--sp-2);
  border-top: 1px solid var(--c-border-subtle);
}
</style>
