---
import CategoryCard from "@/components/cards/CategoryCard.astro";

interface Props {
  categories: any[];
}

const { categories = [] } = Astro.props;
---

<section class="py-24 bg-ai-dark relative overflow-hidden">
  <!-- Subtiele achtergrond glow om de sectie te liften -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-full bg-ai-primary/5 blur-[120px] pointer-events-none" aria-hidden="true"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 rounded-full border border-ai-primary/20 bg-ai-primary/5 text-ai-primary text-xs font-bold uppercase tracking-widest">
          <span class="w-1.5 h-1.5 rounded-full bg-ai-cyan animate-pulse"></span>
          Taxonomy Explorer
        </div>
        <h2 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight leading-tight">
          Browse by <span class="text-gradient-ai">Core Categories</span>
        </h2>
        <p class="mt-4 text-lg text-ai-text-secondary leading-relaxed">
          The most comprehensive classification system for AI tools. Find specialized solutions for every part of your workflow.
        </p>
      </div>
      
      <a href="/ai-tools" class="btn btn--link group text-white font-bold">
        View All Categories
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14m-7-7 7 7-7 7" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {categories.map((category) => (
        <CategoryCard category={category} />
      ))}
    </div>
  </div>
</section>