---
interface Props {
  posts: { tag: string; title: string; href: string; excerpt: string }[];
}

const { posts = [] } = Astro.props;
---

<section class="py-24 bg-[#0B0F19] border-t border-[#1E293B]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
      <div class="max-w-2xl">
        <span class="inline-block px-3 py-1 mb-4 text-xs font-semibold tracking-wider text-primary uppercase bg-primary/10 border border-primary/20 rounded-full">
          Guides & Insights
        </span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Editorial Content Built for Discovery
        </h2>
        <p class="text-lg text-[#94A3B8]">
          Deep dives into AI workflows, tool comparisons, and strategic guides to help you navigate the rapidly evolving landscape.
        </p>
      </div>
      <a href="/ai-news" class="group flex items-center gap-2 text-white font-medium transition-colors hover:text-primary">
        View all articles
        <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {posts.map((post) => (
        <article class="group relative flex flex-col bg-[#121826] border border-[#1E293B] rounded-2xl overflow-hidden transition-all hover:border-[#334155] hover:-translate-y-1">
          <div class="aspect-video bg-[#1A2233] relative overflow-hidden">
             <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-accent/10 group-hover:opacity-60 transition-opacity"></div>
             <div class="absolute top-4 left-4">
               <span class="px-2.5 py-1 text-[10px] font-bold uppercase tracking-widest bg-black/40 backdrop-blur-md text-white border border-white/10 rounded">
                 {post.tag}
               </span>
             </div>
          </div>
          <div class="p-8 flex flex-col flex-grow">
            <h3 class="text-xl font-bold text-white mb-3 group-hover:text-primary transition-colors leading-snug">
              <a href={post.href}>
                <span class="absolute inset-0"></span>
                {post.title}
              </a>
            </h3>
            <p class="text-[#94A3B8] text-sm leading-relaxed mb-6 line-clamp-3">
              {post.excerpt}
            </p>
            <div class="mt-auto flex items-center gap-2 text-xs font-bold text-[#64748B] uppercase tracking-wider">
              <span>Read Guide</span>
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path d="M5 12h14m-7-7 7 7-7 7" />
              </svg>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>