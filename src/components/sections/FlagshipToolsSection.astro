---
interface Tool {
  handle: string;
  name: string;
  tagline?: string;
  pricing_tier?: string;
  category?: string;
  logo_domain?: string;
  is_featured?: boolean;
}

interface Props {
  tools: Tool[];
}

const { tools = [] } = Astro.props;
---

<section class="py-20 bg-[#0B0F19]">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
      <div class="max-w-2xl">
        <div class="text-[#3B82F6] font-semibold text-sm uppercase tracking-widest mb-3">Flagship AI</div>
        <h2 class="text-3xl md:text-4xl font-bold text-[#F8FAFC] mb-4">Essential AI Platforms</h2>
        <p class="text-[#94A3B8] text-lg">
          The industry-defining models and platforms that power the current AI revolution. Highly recommended for any professional workflow.
        </p>
      </div>
      <a href="/ai-tools" class="inline-flex items-center text-[#F8FAFC] font-medium hover:text-[#3B82F6] transition-colors group">
        Browse all tools
        <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {tools.map((tool) => (
        <a 
          href={`/ai-tools/${tool.handle}`} 
          class="group relative flex flex-col p-6 rounded-2xl bg-[#121826] border border-[#1E293B] hover:border-[#334155] transition-all duration-300 hover:shadow-[0_0_30px_-10px_rgba(59,130,246,0.2)]"
        >
          <div class="flex items-start justify-between mb-6">
            <div class="w-14 h-14 rounded-xl bg-[#1A2233] border border-[#1E293B] flex items-center justify-center overflow-hidden transition-transform group-hover:scale-105">
              {tool.logo_domain ? (
                <img 
                  src={`https://www.google.com/s2/favicons?domain=${tool.logo_domain}&sz=128`} 
                  alt=""
                  class="w-8 h-8"
                />
              ) : (
                <span class="text-2xl text-[#3B82F6]">✦</span>
              )}
            </div>
            <div class="flex flex-col items-end gap-2">
              <span class:list={[
                "px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider",
                tool.pricing_tier?.toLowerCase() === 'free' ? "bg-emerald-500/10 text-emerald-400" : "bg-blue-500/10 text-blue-400"
              ]}>
                {tool.pricing_tier || 'Freemium'}
              </span>
              {tool.is_featured && (
                <span class="bg-amber-500/10 text-amber-400 px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider">
                  Featured
                </span>
              )}
            </div>
          </div>

          <div class="flex-1">
            <h3 class="text-xl font-bold text-[#F8FAFC] mb-2 group-hover:text-blue-400 transition-colors">
              {tool.name}
            </h3>
            <p class="text-[#94A3B8] text-sm leading-relaxed mb-6 line-clamp-2 italic">
              "{tool.tagline || 'Leading AI solution for professional workflows.'}"
            </p>
          </div>

          <div class="flex items-center justify-between pt-6 border-t border-[#1E293B]">
            <span class="text-xs font-medium text-[#64748B] flex items-center">
              <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
              </svg>
              {tool.category || 'AI Platform'}
            </span>
            <span class="text-[#3B82F6] text-sm font-semibold opacity-0 group-hover:opacity-100 transition-opacity flex items-center">
              View Details
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>