---
/**
 * FlagshipToolsSection
 * Shows the 5 most recognised mainstream AI tools high on the homepage.
 * Drives instant authority + trust. Data-driven from featuredTools array.
 * Falls back to inline editorial data if a tool is not found in production.
 */

interface Tool {
  handle:       string;
  name?:        string;
  display_name?: string;
  tagline?:     string;
  description?: string;
  logo_domain?: string;
  logo_url?:    string;
  pricing_tier?: string;
  category?:    string;
  category_slug?: string;
  website_url?: string;
  affiliate_url?: string;
  [key: string]: any;
}

interface Props {
  tools: Tool[];
}

const { tools = [] } = Astro.props;

/* ─── Editorial fallback data ───────────────────────────────── */
const editorial: Record<string, Omit<Tool, 'handle'>> = {
  "chatgpt": {
    name: "ChatGPT",
    tagline: "The world's most popular AI assistant for text, code and reasoning.",
    logo_domain: "chat.openai.com",
    pricing_tier: "freemium",
    category: "Chatbots & LLMs",
    category_slug: "chatbots-and-llms",
    website_url: "https://chat.openai.com",
  },
  "claude": {
    name: "Claude",
    tagline: "Anthropic's AI assistant known for safety, long context and nuanced reasoning.",
    logo_domain: "claude.ai",
    pricing_tier: "freemium",
    category: "Chatbots & LLMs",
    category_slug: "chatbots-and-llms",
    website_url: "https://claude.ai",
  },
  "google-gemini": {
    name: "Google Gemini",
    tagline: "Google's multimodal AI — text, images, code and Google Workspace integrated.",
    logo_domain: "gemini.google.com",
    pricing_tier: "freemium",
    category: "Chatbots & LLMs",
    category_slug: "chatbots-and-llms",
    website_url: "https://gemini.google.com",
  },
  "midjourney": {
    name: "Midjourney",
    tagline: "The most powerful AI image generator. Used by designers and creatives worldwide.",
    logo_domain: "midjourney.com",
    pricing_tier: "paid",
    category: "Image Generation",
    category_slug: "image-generation",
    website_url: "https://midjourney.com",
  },
  "microsoft-copilot": {
    name: "Microsoft Copilot",
    tagline: "AI built into Microsoft 365, Windows and Bing — productivity at scale.",
    logo_domain: "copilot.microsoft.com",
    pricing_tier: "freemium",
    category: "Productivity",
    category_slug: "productivity",
    website_url: "https://copilot.microsoft.com",
  },
};

const FLAGSHIP_HANDLES = ["chatgpt", "claude", "google-gemini", "midjourney", "microsoft-copilot"];

/* Build final list: merge production data over editorial fallback */
const toolMap = new Map(tools.map((t: Tool) => [t.handle, t]));

const flagship = FLAGSHIP_HANDLES.map(h => {
  const prod = toolMap.get(h) ?? {} as Tool;
  const ed   = editorial[h]   ?? {};
  return { handle: h, ...ed, ...prod };
});

const pricingLabel: Record<string,string> = {
  free: "Free", freemium: "Freemium", paid: "Paid"
};
---

<section class="fts">
  <div class="section-header">
    <div>
      <span class="section-eyebrow">Mainstream AI</span>
      <h2>The Tools Everyone Knows</h2>
    </div>
    <a href="/ai-tools" class="see-all">
      All AI Tools
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>

  <div class="fts-grid">
    {flagship.map((t, i) => {
      const tier     = (t.pricing_tier || "unknown").toLowerCase();
      const logoSrc  = t.logo_url || (t.logo_domain ? `https://logo.clearbit.com/${t.logo_domain}?size=80` : null);
      const name     = t.display_name || t.name || t.handle;
      const href     = t.affiliate_url || `/ai-tools/${t.handle}`;
      const isExt    = !!t.affiliate_url;
      const catSlug  = t.category_slug || "";
      const fallback = name.charAt(0).toUpperCase();
      const desc     = (t.tagline || t.description || "").slice(0, 90);

      return (
        <article class:list={["ftc", i === 0 && "ftc--hero"]}>
          {/* Rank stripe */}
          <div class="ftc-stripe" aria-hidden="true"/>

          <a
            href={href}
            class="ftc-inner"
            target={isExt ? "_blank" : undefined}
            rel={isExt ? "noopener sponsored" : undefined}
          >
            {/* Logo */}
            <div class="ftc-logo">
              {logoSrc ? (
                <img
                  src={logoSrc}
                  alt={`${name} logo`}
                  width="56"
                  height="56"
                  loading={i < 2 ? "eager" : "lazy"}
                  decoding="async"
                  onerror="this.onerror=null;this.style.display='none';this.nextElementSibling.style.display='flex'"
                />
              ) : null}
              <span class="ftc-logo-fb" style={logoSrc ? "display:none" : ""}>{fallback}</span>
            </div>

            {/* Body */}
            <div class="ftc-body">
              <div class="ftc-nameline">
                <strong class="ftc-name">{name}</strong>
                <span class:list={["badge", `badge-${tier}`]}>
                  {pricingLabel[tier] || tier}
                </span>
              </div>

              {t.category && (
                <span class="ftc-cat">{t.category}</span>
              )}

              {desc && (
                <p class="ftc-desc">{desc}{desc.length >= 90 ? "…" : ""}</p>
              )}
            </div>

            {/* Footer CTA */}
            <div class="ftc-foot">
              <span class="ftc-cta">
                Visit {name}
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
              </span>
              <span class="ftc-rank" aria-label={`Rank ${i + 1}`}>#{i + 1}</span>
            </div>
          </a>
        </article>
      );
    })}
  </div>
</section>

<style>
.fts { margin-bottom: var(--sp-20) }

/* ── Grid: 3 cols, first card spans 2 rows ─────────────────── */
.fts-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: auto auto;
  gap: var(--sp-4);
}
@media (max-width: 900px) {
  .fts-grid { grid-template-columns: repeat(2, 1fr) }
  .ftc--hero { grid-column: span 2 }
}
@media (max-width: 600px) {
  .fts-grid { grid-template-columns: 1fr }
  .ftc--hero { grid-column: span 1 }
}

/* ── Base card ─────────────────────────────────────────────── */
.ftc {
  position: relative;
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: var(--card-radius);
  overflow: hidden;
  transition: border-color var(--t-base), box-shadow var(--t-base), transform var(--t-base);
}
/* Ambient glow */
.ftc::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 55% at 10% 0%, var(--glow-brand-xs) 0%, transparent 70%);
  pointer-events: none;
  transition: opacity var(--t-base);
  border-radius: inherit;
}
.ftc:hover {
  border-color: var(--card-hover-border);
  box-shadow: var(--card-hover-shadow);
  transform: var(--card-hover-lift);
}
.ftc:hover::after { opacity: 3 }

/* Hero card — slightly elevated */
.ftc--hero {
  border-color: rgba(79,110,247,.18);
  background: linear-gradient(145deg, var(--c-bg-2) 60%, rgba(79,110,247,.04) 100%);
}
.ftc--hero::after {
  background: radial-gradient(ellipse 80% 70% at 0% 0%, rgba(79,110,247,.08) 0%, transparent 70%);
}
.ftc--hero:hover { box-shadow: 0 0 0 1px rgba(79,110,247,.22), 0 12px 48px rgba(79,110,247,.12) }

/* Rank stripe */
.ftc-stripe {
  height: 2px;
  background: var(--g-brand);
  opacity: .35;
  transition: opacity var(--t-base);
}
.ftc--hero .ftc-stripe { opacity: .7 }
.ftc:hover .ftc-stripe { opacity: .8 }

/* Inner link */
.ftc-inner {
  padding: var(--sp-5);
  display: flex;
  flex-direction: column;
  gap: var(--sp-4);
  text-decoration: none;
  height: 100%;
}
.ftc--hero .ftc-inner { padding: var(--sp-6) }

/* Logo */
.ftc-logo {
  width: 56px; height: 56px;
  border-radius: var(--r-md);
  background: var(--c-bg-4);
  border: 1px solid var(--c-border-subtle);
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ftc--hero .ftc-logo { width: 64px; height: 64px; border-radius: 14px }
.ftc-logo img { width: 100%; height: 100%; object-fit: contain }
.ftc-logo-fb {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-size: 24px; font-weight: 800;
  color: var(--c-brand-light);
  background: linear-gradient(135deg, var(--glow-brand) 0%, var(--glow-violet) 100%);
}

/* Name row */
.ftc-nameline {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  flex-wrap: wrap;
}
.ftc-name {
  font-family: var(--font-display);
  font-size: var(--text-base);
  font-weight: 800;
  color: var(--c-text);
  letter-spacing: -.025em;
  line-height: 1.2;
}
.ftc--hero .ftc-name { font-size: var(--text-lg) }

.ftc-cat {
  font-family: var(--font-display);
  font-size: var(--text-2xs);
  font-weight: 600;
  color: var(--c-text-4);
  text-transform: uppercase;
  letter-spacing: .07em;
}

.ftc-desc {
  font-size: var(--text-sm);
  color: var(--c-text-2);
  line-height: var(--lh-snug);
  flex: 1;
  margin: 0;
}

/* Footer */
.ftc-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: var(--sp-3);
  border-top: 1px solid var(--c-border-subtle);
  margin-top: auto;
}
.ftc-cta {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-family: var(--font-display);
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--c-brand-light);
  letter-spacing: .01em;
  transition: gap var(--t-fast);
}
.ftc:hover .ftc-cta { gap: 7px }
.ftc-rank {
  font-family: var(--font-mono);
  font-size: 9px;
  font-weight: 700;
  color: var(--c-text-4);
  background: var(--c-bg-4);
  border: 1px solid var(--c-border);
  padding: 2px 7px;
  border-radius: var(--r-full);
}
</style>
