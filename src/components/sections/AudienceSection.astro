---
const audiences = [
  { title: "Marketers & Growth",      emoji: "📈", desc: "AI for SEO, content, ads, social media and lead generation.", href: "/ai-tools/industry/marketing" },
  { title: "Developers",              emoji: "⚡", desc: "Code assistants, API tools, testing and DevOps automation.", href: "/ai-tools/category/coding-and-dev" },
  { title: "Content Creators",        emoji: "✍️", desc: "Writing, video, images, podcasts and creative workflows.", href: "/ai-tools/category/writing-and-content" },
  { title: "Business & Sales",        emoji: "💼", desc: "CRM, outreach, proposals, contracts and analytics.", href: "/ai-tools/industry/sales" },
  { title: "Designers",               emoji: "🎨", desc: "Image generation, UI design, branding and creative tools.", href: "/ai-tools/category/design-and-ui" },
  { title: "Researchers & Educators", emoji: "🧠", desc: "Research assistants, summarization, learning and tutoring.", href: "/ai-tools/category/research-and-education" },
];
---
<section class="aud">
  <div class="section-header">
    <div>
      <span class="section-eyebrow">For every professional</span>
      <h2>Find Tools for Your Role</h2>
    </div>
  </div>
  <div class="aud-grid">
    {audiences.map(a => (
      <a href={a.href} class="aud-card">
        <div class="aud-icon">
          <span class="aud-em">{a.emoji}</span>
        </div>
        <div class="aud-body">
          <strong class="aud-title">{a.title}</strong>
          <p class="aud-desc">{a.desc}</p>
        </div>
        <svg class="aud-arr" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
      </a>
    ))}
  </div>
</section>

<style>
.aud { margin-bottom: var(--sp-20) }
.aud-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: var(--sp-3);
}
.aud-card {
  display: flex;
  align-items: center;
  gap: var(--sp-4);
  padding: var(--sp-5) var(--sp-5);
  background: var(--c-bg-2);
  border: 1px solid var(--c-border);
  border-radius: var(--r-xl);
  text-decoration: none;
  transition: all var(--t-base);
  position: relative;
  overflow: hidden;
}
.aud-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--c-brand-glow-xs) 0%, transparent 60%);
  opacity: 0;
  transition: opacity var(--t-base);
}
.aud-card:hover {
  border-color: var(--c-border-hover);
  transform: translateY(-2px);
  box-shadow: 0 4px 24px rgba(79,110,247,.1);
}
.aud-card:hover::before { opacity: 1 }
.aud-icon {
  width: 44px; height: 44px;
  background: var(--c-bg-4);
  border: 1px solid var(--c-border);
  border-radius: var(--r-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background var(--t-fast), border-color var(--t-fast);
}
.aud-card:hover .aud-icon {
  background: var(--c-brand-glow);
  border-color: rgba(79,110,247,.2);
}
.aud-em { font-size: 1.25rem; line-height: 1 }
.aud-body { flex: 1; min-width: 0 }
.aud-title {
  display: block;
  font-size: var(--text-sm);
  font-weight: 700;
  font-family: var(--font-display);
  color: var(--c-text);
  margin-bottom: 3px;
  letter-spacing: -.01em;
}
.aud-desc {
  font-size: var(--text-xs);
  color: var(--c-text-3);
  line-height: 1.5;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.aud-arr {
  color: var(--c-text-4);
  flex-shrink: 0;
  transition: transform var(--t-fast), color var(--t-fast);
}
.aud-card:hover .aud-arr { transform: translateX(3px); color: var(--c-brand-light) }
</style>
