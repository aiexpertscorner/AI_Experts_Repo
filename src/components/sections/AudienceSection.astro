---
const audiences = [
  { title: "Marketers & Growth", emoji: "📈", desc: "AI for SEO, content, ads, social media and lead generation.", href: "/ai-tools/industry/marketing" },
  { title: "Developers", emoji: "⚡", desc: "Code assistants, API tools, testing and DevOps automation.", href: "/ai-tools/category/coding-and-dev" },
  { title: "Content Creators", emoji: "✍️", desc: "Writing, video, images, podcasts and creative workflows.", href: "/ai-tools/category/writing-and-content" },
  { title: "Business & Sales", emoji: "💼", desc: "CRM, outreach, proposals, contracts and analytics.", href: "/ai-tools/industry/sales" },
  { title: "Designers", emoji: "🎨", desc: "Image generation, UI design, branding and creative tools.", href: "/ai-tools/category/design-and-ui" },
  { title: "Researchers & Educators", emoji: "🧠", desc: "Research assistants, summarization, learning and tutoring.", href: "/ai-tools/category/research-and-education" },
];
---
<section class="aud">
  <div class="section-header">
    <h2>Find Tools for Your Role</h2>
  </div>
  <div class="aud-grid">
    {audiences.map(a => (
      <a href={a.href} class="aud-card">
        <span class="aud-em">{a.emoji}</span>
        <div>
          <strong class="aud-title">{a.title}</strong>
          <p class="aud-desc">{a.desc}</p>
        </div>
        <svg class="aud-arr" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
      </a>
    ))}
  </div>
</section>
<style>
.aud{margin-bottom:var(--sp-16)}
.aud-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:var(--sp-3)}
.aud-card{display:flex;align-items:flex-start;gap:var(--sp-4);padding:var(--sp-5);background:var(--c-bg-2);border:1px solid var(--c-border);border-radius:var(--r-lg);text-decoration:none;transition:all var(--t-base)}
.aud-card:hover{border-color:var(--c-border-hover);transform:translateY(-2px);background:var(--c-bg-3)}
.aud-em{font-size:1.5rem;flex-shrink:0;margin-top:2px}
.aud-title{display:block;font-size:var(--text-sm);font-weight:700;font-family:var(--font-display);color:var(--c-text);margin-bottom:4px}
.aud-desc{font-size:var(--text-xs);color:var(--c-text-3);line-height:1.5}
.aud-arr{color:var(--c-text-3);flex-shrink:0;margin-left:auto;margin-top:4px;transition:transform var(--t-fast)}
.aud-card:hover .aud-arr{transform:translateX(2px);color:var(--c-brand-light)}
</style>
