---
import ToolCard from "@/components/cards/ToolCard.astro";
interface Props { tools: any[] }
const { tools } = Astro.props;
if (!tools?.length) return;
---
<section class="nts">
  <div class="section-header">
    <div>
      <span class="section-eyebrow">Just Added</span>
      <h2>New This Week</h2>
    </div>
    <a href="/ai-tools" class="see-all">
      Browse all
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
  <div class="grid-tools">
    {tools.slice(0, 6).map((t: any) => <ToolCard tool={t}/>)}
  </div>
</section>

<style>
.nts { margin-bottom: var(--sp-20) }
</style>
