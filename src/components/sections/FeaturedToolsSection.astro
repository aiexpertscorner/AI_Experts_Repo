---
import ToolCard from "@/components/cards/ToolCard.astro";
interface Props { tools: any[]; showRank?: boolean }
const { tools, showRank = false } = Astro.props;
if (!tools?.length) return;
---
<div class="grid-tools">
  {tools.map((t: any, i: number) => (
    <ToolCard tool={t} rank={showRank ? i + 1 : undefined}/>
  ))}
</div>
