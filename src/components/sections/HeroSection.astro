---
interface Props {
  totalToolsCount: number;
  totalCatsCount: number;
  trustedBrands: string[];
}

const { totalToolsCount = 19000, totalCatsCount = 25, trustedBrands = [] } = Astro.props;
---

<section class="relative pt-24 pb-20 overflow-hidden bg-[#0B0F19]">
  {/* Background Glow Effects */}
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[600px] pointer-events-none">
    <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[60%] rounded-full bg-blue-500/10 blur-[120px]"></div>
    <div class="absolute bottom-[10%] right-[-5%] w-[35%] h-[50%] rounded-full bg-purple-500/10 blur-[120px]"></div>
    <div class="absolute top-0 left-0 w-full h-full opacity-20" style="background-image: radial-gradient(#1E293B 1px, transparent 1px); background-size: 40px 40px;"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center px-4 py-1.5 mb-6 rounded-full border border-blue-500/30 bg-blue-500/5 text-blue-400 text-sm font-medium">
        <span class="relative flex h-2 w-2 mr-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
        </span>
        AI Discovery Engine & Knowledge Hub
      </div>
      
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight text-[#F8FAFC] leading-[1.1] mb-6">
        Discover the Best <span class="bg-gradient-to-r from-[#3B82F6] via-[#22D3EE] to-[#8B5CF6] bg-clip-text text-transparent">AI Tools</span> for Any Workflow
      </h1>
      
      <p class="text-lg md:text-xl text-[#94A3B8] max-w-2xl mx-auto mb-10 leading-relaxed">
        Search and compare {totalToolsCount.toLocaleString()}+ AI tools across {totalCatsCount} categories. The most comprehensive directory for builders, marketers, and developers.
      </p>

      <div class="max-w-2xl mx-auto relative group mb-12">
        <div class="absolute -inset-1 bg-gradient-to-r from-blue-500 to-purple-600 rounded-2xl blur opacity-25 group-focus-within:opacity-50 transition duration-300"></div>
        <form action="/tools" method="get" class="relative flex items-center bg-[#121826] border border-[#1E293B] rounded-xl p-2 shadow-2xl">
          <div class="pl-4 text-[#64748B]">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <input 
            type="search" 
            name="q" 
            placeholder="Search 19,000+ AI tools (e.g. 'video editor' or 'coding assistant')..." 
            class="w-full bg-transparent border-none focus:ring-0 text-[#F8FAFC] placeholder-[#64748B] px-4 py-3 text-base"
          />
          <button type="submit" class="bg-[#3B82F6] hover:bg-blue-600 text-white font-semibold px-6 py-3 rounded-lg transition-all">
            Search
          </button>
        </form>
      </div>

      {/* Stats Bar */}
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8 py-8 border-y border-[#1E293B] mb-12">
        <div class="text-center">
          <div class="text-2xl font-bold text-[#F8FAFC]">{totalToolsCount.toLocaleString()}</div>
          <div class="text-xs uppercase tracking-wider text-[#64748B]">AI Tools Indexed</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-[#F8FAFC]">Daily</div>
          <div class="text-xs uppercase tracking-wider text-[#64748B]">Database Updates</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-[#F8FAFC]">1,200+</div>
          <div class="text-xs uppercase tracking-wider text-[#64748B]">Prompts Library</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-[#F8FAFC]">Free</div>
          <div class="text-xs uppercase tracking-wider text-[#64748B]">Workflows</div>
        </div>
      </div>

      {trustedBrands.length > 0 && (
        <div class="flex flex-col items-center">
          <span class="text-xs font-semibold text-[#64748B] uppercase tracking-[0.2em] mb-6">Trusted by teams at</span>
          <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 opacity-40 grayscale hover:grayscale-0 transition-all duration-500">
            {/* Mapping logos or placeholders based on trustedBrands string array */}
            {trustedBrands.map((brand) => (
              <span class="text-[#F8FAFC] text-lg font-bold">{brand}</span>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</section>