---
interface Props {
  links: { label: string; href: string }[];
}

const { links = [] } = Astro.props;
---

<section class="py-24 bg-[#0B0F19]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-12">
      <div class="max-w-2xl">
        <span class="inline-block px-3 py-1 mb-4 text-xs font-semibold tracking-wider text-cyan-400 uppercase bg-cyan-400/10 border border-cyan-400/20 rounded-full">
          Best Of
        </span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          High-Intent Discovery Paths
        </h2>
        <p class="text-lg text-[#94A3B8]">
          Curated routes designed to help you find the absolute best AI tools by specific use case, pricing structure, and industry needs.
        </p>
      </div>
      <a href="/best" class="group flex items-center gap-2 text-white font-medium transition-colors hover:text-primary">
        Open best-of hub
        <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {links.map((item) => (
        <a
          href={item.href}
          class="group relative flex items-center justify-between p-5 bg-[#121826] border border-[#1E293B] rounded-xl transition-all duration-300 hover:border-[#334155] hover:bg-[#1A2233] hover:shadow-xl hover:shadow-black/20"
        >
          <span class="text-[#F8FAFC] font-medium transition-colors group-hover:text-white">
            {item.label}
          </span>
          <div class="flex items-center justify-center w-8 h-8 rounded-lg bg-[#0B0F19] text-[#64748B] group-hover:text-cyan-400 group-hover:bg-[#0B0F19]/80 transition-all">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <path d="m9 18 6-6-6-6" />
            </svg>
          </div>
          <div class="absolute inset-0 border border-primary/0 rounded-xl transition-colors group-hover:border-primary/10"></div>
        </a>
      ))}
    </div>
  </div>
</section>