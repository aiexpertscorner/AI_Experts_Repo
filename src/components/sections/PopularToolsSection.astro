---
import ToolCard from "@/components/cards/ToolCard.astro";

interface Props {
  title?: string;
  eyebrow?: string;
  description?: string;
  tools: any[];
  totalCompareCount?: number;
  totalBestOfCount?: number;
  ctaHref?: string;
  ctaLabel?: string;
  compact?: boolean;
}

const {
  title = "Popular AI Tools",
  eyebrow = "Top Ranked",
  description = "Explore some of the most visible and frequently visited tools in the directory.",
  tools = [],
  ctaHref = "/ai-tools",
  ctaLabel = "View all tools",
  compact = false
} = Astro.props;
---

<section class="py-24 bg-[#121826]/50 border-y border-slate-800/50">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
      <div class="max-w-3xl">
        <span class="inline-block px-3 py-1 mb-4 text-xs font-bold tracking-widest text-violet-400 uppercase bg-violet-400/10 border border-violet-400/20 rounded-full">
          {eyebrow}
        </span>
        <h2 class="text-4xl md:text-5xl font-bold text-white tracking-tight">
          {title}
        </h2>
        <p class="mt-6 text-lg text-slate-400 leading-relaxed">
          {description}
        </p>
      </div>

      <div class="flex flex-col items-start md:items-end gap-4">
        <a href={ctaHref} class="inline-flex items-center justify-center px-6 py-3 text-sm font-bold text-white bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-xl transition-all duration-300">
          {ctaLabel}
        </a>
      </div>
    </div>

    <div class:list={[
      "grid gap-6",
      compact ? "grid-cols-1 sm:grid-cols-2 lg:grid-cols-4" : "grid-cols-1 md:grid-cols-2 xl:grid-cols-3"
    ]}>
      {tools.map((tool, index) => (
        <ToolCard
          tool={tool}
          rank={index + 1}
          variant="default"
          showDescription={!compact}
          showPricing={true}
          showCategory={true}
          showCTA={false}
        />
      ))}
    </div>

    <div class="mt-16 flex flex-wrap justify-center gap-x-12 gap-y-6 py-8 border-t border-slate-800/60">
      <div class="flex flex-col items-center md:items-start">
        <span class="text-3xl font-bold text-white tracking-tight">19,000+</span>
        <span class="text-sm text-slate-500 uppercase tracking-widest font-semibold mt-1">Tools Indexed</span>
      </div>
      <div class="w-px h-12 bg-slate-800 hidden md:block"></div>
      <div class="flex flex-col items-center md:items-start">
        <span class="text-3xl font-bold text-white tracking-tight">1,200+</span>
        <span class="text-sm text-slate-500 uppercase tracking-widest font-semibold mt-1">Comparisons</span>
      </div>
      <div class="w-px h-12 bg-slate-800 hidden md:block"></div>
      <div class="flex flex-col items-center md:items-start">
        <span class="text-3xl font-bold text-white tracking-tight">450+</span>
        <span class="text-sm text-slate-500 uppercase tracking-widest font-semibold mt-1">Best-Of Guides</span>
      </div>
    </div>
  </div>
</section>