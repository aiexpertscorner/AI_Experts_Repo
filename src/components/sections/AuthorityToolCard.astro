---
/**
 * AuthorityToolCard — compact horizontal card for ranked tools
 * Used in: Global Top 100, Category Top 10, Featured authority sections
 *
 * CHANGELOG v3.1:
 *   - Replaced inline logo code with <ToolLogo> component
 *   - Removed dynamic Clearbit URL construction (logo_url from logo-map.json)
 *   - Fixes logo-master.mjs needs_fix flag
 */
import ToolLogo from "@/components/ui/ToolLogo.astro";

interface Props {
  handle:         string;
  name:           string;
  display_name?:  string;
  logo_url?:      string;
  category?:      string;
  cat_slug?:      string;
  pricing_tier?:  string;
  tagline?:       string;
  rank?:          number;
  website_url?:   string;
  global_rank?:   number;
  in_production?: boolean;
}

const {
  handle,
  name,
  display_name,
  logo_url,
  category     = "",
  cat_slug     = "",
  pricing_tier = "unknown",
  tagline      = "",
  rank,
  website_url  = "",
  global_rank,
  in_production = true,
} = Astro.props;

const displayName = display_name || name;
const tier        = (pricing_tier || "unknown").toLowerCase();
const href        = in_production ? `/tools/${handle}` : (website_url || "#");
const showRank    = rank ?? global_rank;
const catHref     = cat_slug ? `/tools/category/${cat_slug}` : null;

const pricingLabel: Record<string, string> = {
  free: "Free", freemium: "Freemium", paid: "Paid",
};
---
<a
  href={href}
  class="atc"
  target={!in_production ? "_blank" : undefined}
  rel={!in_production ? "noopener" : undefined}
>
  {showRank && (
    <span class="atc-rank" aria-label={`Rank ${showRank}`}>
      {String(showRank).padStart(2, "0")}
    </span>
  )}

  <ToolLogo
    name={displayName}
    logoUrl={logo_url || null}
    size="sm"
    radius="sm"
    class="atc-logo"
  />

  <div class="atc-body">
    <span class="atc-name">{displayName}</span>
    {tagline && <span class="atc-tagline">{tagline.slice(0, 72)}</span>}
    {category && catHref && (
      <a
        href={catHref}
        class="atc-cat"
        onclick="event.stopPropagation()"
      >{category}</a>
    )}
    {category && !catHref && (
      <span class="atc-cat">{category}</span>
    )}
  </div>

  <span class:list={["badge", `badge-${tier}`, "atc-badge"]}>
    {pricingLabel[tier] || pricing_tier}
  </span>

  <svg
    class="atc-arr"
    width="14" height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <path d="M9 18l6-6-6-6"/>
  </svg>
</a>

<style>
/* ── Shell ─────────────────────────────────────────────────────*/
.atc {
  display:         flex;
  align-items:     center;
  gap:             var(--sp-3);
  padding:         var(--sp-3) var(--sp-4);
  border-radius:   var(--r-md);
  background:      var(--c-bg-2);
  border:          1px solid var(--c-border);
  text-decoration: none;
  transition:      border-color var(--t-fast), background var(--t-fast), transform var(--t-fast);
  position:        relative;
}
.atc:hover {
  border-color: var(--c-border-hover);
  background:   var(--c-bg-3);
  transform:    translateX(2px);
}

/* ── Rank ──────────────────────────────────────────────────────*/
.atc-rank {
  font-family:    var(--font-mono);
  font-size:      var(--text-xs);
  font-weight:    700;
  color:          var(--c-text-3);
  letter-spacing: .02em;
  min-width:      26px;
  flex-shrink:    0;
}

/* ── Logo hover wiring ─────────────────────────────────────────*/
.atc:hover .atc-logo { border-color: var(--c-border) }

/* ── Body ──────────────────────────────────────────────────────*/
.atc-body {
  display:        flex;
  flex-direction: column;
  gap:            2px;
  flex:           1;
  min-width:      0;
}

.atc-name {
  font-family:    var(--font-display);
  font-size:      var(--text-sm);
  font-weight:    700;
  color:          var(--c-text);
  letter-spacing: -.015em;
  line-height:    1.25;
  overflow:       hidden;
  text-overflow:  ellipsis;
  white-space:    nowrap;
}

.atc-tagline {
  font-size:     var(--text-xs);
  color:         var(--c-text-3);
  line-height:   var(--lh-snug);
  overflow:      hidden;
  text-overflow: ellipsis;
  white-space:   nowrap;
}

.atc-cat {
  font-family:    var(--font-display);
  font-size:      var(--text-2xs);
  font-weight:    600;
  color:          var(--c-text-4);
  text-transform: uppercase;
  letter-spacing: .06em;
  text-decoration: none;
  transition:     color var(--t-fast);
}
a.atc-cat:hover { color: var(--c-brand-light) }

/* ── Badge + arrow ─────────────────────────────────────────────*/
.atc-badge  { flex-shrink: 0 }
.atc-arr    { color: var(--c-text-4); flex-shrink: 0; transition: transform var(--t-fast) }
.atc:hover .atc-arr { transform: translateX(2px); color: var(--c-brand-light) }

/* ── Mobile — hide tagline on very small screens ───────────────*/
@media (max-width: 400px) {
  .atc-tagline { display: none }
}
</style>