---
/**
 * src/components/site/Header.astro
 * ─────────────────────────────────────────────────────────────────
 * Volledige nav met:
 *  - Logo + wordmark
 *  - Desktop nav met dropdown mega-menus voor Tools en Explore
 *  - Mobile menu (toggle)
 *  - Submit Tool CTA
 *
 * Interne links — alle routes die gebouwd zijn:
 *   /tools                    → AI Tools hub
 *   /compare                  → Compare hub
 *   /best                     → Best-of hub
 *   /alternatives             → Alternatives hub
 *   /use-case                 → Use Case hub
 *   /workflow                 → Workflow hub
 *   /industry                 → Industry hub
 *   /capability               → Capability hub
 *   /subcategory              → Subcategory hub
 *   /tools/pricing/free       → Free tools
 *   /tools/category/[slug]    → Category pagina's
 * ─────────────────────────────────────────────────────────────────
 */
import { SITE_NAME } from "@/data/homeConfig";

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}

const toolsCategories = [
  { label: "Chatbots & LLMs",       href: "/tools/category/chatbots-and-llms",       emoji: "💬" },
  { label: "Writing & Content",     href: "/tools/category/writing-and-content",     emoji: "✍️" },
  { label: "Image Generation",      href: "/tools/category/image-generation",        emoji: "🎨" },
  { label: "Coding & Dev",          href: "/tools/category/coding-and-dev",          emoji: "💻" },
  { label: "Video Generation",      href: "/tools/category/video-generation",        emoji: "🎬" },
  { label: "Audio & Music",         href: "/tools/category/audio-and-music",         emoji: "🎵" },
  { label: "SEO & Marketing",       href: "/tools/category/seo-and-marketing",       emoji: "📈" },
  { label: "Design & UI",           href: "/tools/category/design-and-ui",           emoji: "🖌️" },
  { label: "Productivity",          href: "/tools/category/productivity",            emoji: "⚡" },
  { label: "AI Agents",             href: "/tools/category/ai-agents",              emoji: "🤖" },
  { label: "Data & Analytics",      href: "/tools/category/data-and-analytics",      emoji: "📊" },
  { label: "Research & Education",  href: "/tools/category/research-and-education",  emoji: "🎓" },
];

const exploreLinks = [
  {
    group: "Find & Compare",
    items: [
      { label: "Compare Tools",       href: "/compare",      icon: "⚔️",  desc: "Side-by-side comparisons" },
      { label: "Find Alternatives",   href: "/alternatives", icon: "🔀",  desc: "Switch from any tool" },
      { label: "Best-Of Lists",       href: "/best",         icon: "🏆",  desc: "Expert-ranked picks" },
    ]
  },
  {
    group: "Browse by",
    items: [
      { label: "Use Case",            href: "/use-case",     icon: "🎯",  desc: "What you want to do" },
      { label: "Industry",            href: "/industry",     icon: "🏭",  desc: "Your field of work" },
      { label: "Workflow",            href: "/workflow",     icon: "⚙️",  desc: "Step-by-step guides" },
      { label: "Capability",          href: "/capability",   icon: "🔬",  desc: "AI features & skills" },
    ]
  },
  {
    group: "Filter by",
    items: [
      { label: "Free Tools",          href: "/tools/pricing/free",     icon: "🆓",  desc: "No credit card needed" },
      { label: "Freemium Tools",      href: "/tools/pricing/freemium", icon: "✨",  desc: "Free + paid tiers" },
      { label: "Submit a Tool",       href: "/submit-tool",            icon: "➕",  desc: "Add your AI tool" },
    ]
  }
];
---

<header class="hdr" id="site-header">
  <div class="hdr__inner">

    <!-- Logo -->
    <a href="/" class="hdr__logo" aria-label={`${SITE_NAME} home`}>
      <div class="hdr__logo-icon">
        <div class="hdr__logo-icon-inner">
          <img src="/logos/logo-icon-128.png" alt="" width="22" height="22" loading="eager" />
        </div>
        <div class="hdr__logo-glow" aria-hidden="true"></div>
      </div>
      <span class="hdr__logo-text">
        <span class="hdr__logo-ai">AI</span>ExpertsCorner<span class="hdr__logo-com">.com</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hdr__nav" aria-label="Main navigation">

      <!-- Tools (met dropdown) -->
      <div class="hdr__item hdr__item--dropdown" data-dropdown="tools">
        <a
          href="/tools"
          class:list={["hdr__link", isActive("/tools") && "hdr__link--active"]}
          aria-haspopup="true"
          aria-expanded="false"
        >
          Tools
          <svg class="hdr__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M6 9l6 6 6-6"/>
          </svg>
          {isActive("/tools") && <span class="hdr__active-dot" aria-hidden="true"></span>}
        </a>
        <!-- Tools mega dropdown -->
        <div class="hdr__dropdown hdr__dropdown--tools" role="menu">
          <div class="hdr__dropdown-header">
            <a href="/tools" class="hdr__dropdown-all">Browse all {toolsCategories.length + 11} categories →</a>
          </div>
          <div class="hdr__cat-grid">
            {toolsCategories.map(cat => (
              <a href={cat.href} class="hdr__cat-item" role="menuitem">
                <span class="hdr__cat-emoji">{cat.emoji}</span>
                <span class="hdr__cat-label">{cat.label}</span>
              </a>
            ))}
          </div>
          <div class="hdr__dropdown-footer">
            <a href="/tools/pricing/free">🆓 Free tools</a>
            <a href="/tools/pricing/freemium">✨ Freemium</a>
            <a href="/tools/feature/open-source">🔓 Open source</a>
          </div>
        </div>
      </div>

      <!-- Compare -->
      <a
        href="/compare"
        class:list={["hdr__link", isActive("/compare") && "hdr__link--active"]}
      >
        Compare
        {isActive("/compare") && <span class="hdr__active-dot" aria-hidden="true"></span>}
      </a>

      <!-- Best Of -->
      <a
        href="/best"
        class:list={["hdr__link", isActive("/best") && "hdr__link--active"]}
      >
        Best Of
        {isActive("/best") && <span class="hdr__active-dot" aria-hidden="true"></span>}
      </a>

      <!-- Explore (met dropdown) -->
      <div class="hdr__item hdr__item--dropdown" data-dropdown="explore">
        <button
          class:list={["hdr__link hdr__link--btn", (isActive("/use-case") || isActive("/industry") || isActive("/workflow") || isActive("/capability") || isActive("/alternatives")) && "hdr__link--active"]}
          aria-haspopup="true"
          aria-expanded="false"
        >
          Explore
          <svg class="hdr__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </button>
        <!-- Explore mega dropdown -->
        <div class="hdr__dropdown hdr__dropdown--explore" role="menu">
          <div class="hdr__explore-grid">
            {exploreLinks.map(group => (
              <div class="hdr__explore-group">
                <p class="hdr__explore-group-label">{group.group}</p>
                {group.items.map(item => (
                  <a href={item.href} class="hdr__explore-item" role="menuitem">
                    <span class="hdr__explore-icon">{item.icon}</span>
                    <span class="hdr__explore-body">
                      <span class="hdr__explore-label">{item.label}</span>
                      <span class="hdr__explore-desc">{item.desc}</span>
                    </span>
                  </a>
                ))}
              </div>
            ))}
          </div>
        </div>
      </div>

    </nav>

    <!-- Right side -->
    <div class="hdr__right">
      <a href="/submit-tool" class="hdr__cta">Submit Tool</a>
      <!-- Mobile toggle -->
      <button class="hdr__mobile-btn" id="mobile-menu-btn" aria-label="Open menu" aria-expanded="false">
        <svg id="icon-menu" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6"  x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

  </div>

  <!-- Mobile menu -->
  <div class="hdr__mobile" id="mobile-menu" aria-hidden="true">
    <nav class="hdr__mobile-nav">
      <a href="/tools"        class="hdr__mobile-link">🔧 AI Tools</a>
      <a href="/compare"      class="hdr__mobile-link">⚔️ Compare</a>
      <a href="/best"         class="hdr__mobile-link">🏆 Best Of</a>
      <a href="/alternatives" class="hdr__mobile-link">🔀 Alternatives</a>
      <a href="/use-case"     class="hdr__mobile-link">🎯 By Use Case</a>
      <a href="/industry"     class="hdr__mobile-link">🏭 By Industry</a>
      <a href="/workflow"     class="hdr__mobile-link">⚙️ Workflows</a>
      <a href="/capability"   class="hdr__mobile-link">🔬 By Capability</a>

      <div class="hdr__mobile-div"></div>
      <p class="hdr__mobile-section">Filter</p>
      <a href="/tools/pricing/free"     class="hdr__mobile-link">🆓 Free Tools</a>
      <a href="/tools/pricing/freemium" class="hdr__mobile-link">✨ Freemium Tools</a>

      <div class="hdr__mobile-div"></div>
      <a href="/submit-tool" class="hdr__mobile-cta">➕ Submit a Tool</a>
    </nav>
  </div>
</header>

<style>
/* ── Header shell ────────────────────────────────────────────────── */
.hdr {
  position: sticky; top: 0; z-index: 50;
  width: 100%;
  background: rgba(11, 15, 25, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid #1E293B;
}
.hdr__inner {
  max-width: 1280px; margin: 0 auto;
  padding: 0 1.5rem;
  display: flex; align-items: center;
  height: 4.5rem; gap: 1rem;
}

/* ── Logo ──────────────────────────────────────────────────────── */
.hdr__logo {
  display: flex; align-items: center; gap: .75rem;
  text-decoration: none; flex-shrink: 0;
  transition: transform .2s;
}
.hdr__logo:hover { transform: scale(1.02); }
.hdr__logo-icon {
  position: relative; width: 2.25rem; height: 2.25rem;
  border-radius: .625rem; flex-shrink: 0;
  background: linear-gradient(135deg, #3B82F6, #8B5CF6);
  padding: 1px;
}
.hdr__logo-icon-inner {
  width: 100%; height: 100%; border-radius: .5625rem;
  background: #0B0F19;
  display: flex; align-items: center; justify-content: center;
}
.hdr__logo-glow {
  position: absolute; inset: 0; border-radius: .625rem;
  background: rgba(59,130,246,.2); filter: blur(8px);
  transition: background .2s;
}
.hdr__logo:hover .hdr__logo-glow { background: rgba(59,130,246,.4); }
.hdr__logo-text { font-size: 1.125rem; font-weight: 700; letter-spacing: -.01em; color: #F8FAFC; }
.hdr__logo-ai   { background: linear-gradient(to right, #3B82F6, #22D3EE); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hdr__logo-com  { color: #64748B; font-size: .8125rem; font-weight: 500; }

/* ── Desktop nav ────────────────────────────────────────────────── */
.hdr__nav {
  display: flex; align-items: center; gap: .125rem;
  flex: 1; margin-left: 1rem;
}
@media (max-width: 768px) { .hdr__nav { display: none; } }

.hdr__item { position: relative; }
.hdr__item--dropdown { display: flex; align-items: center; }

.hdr__link, .hdr__link--btn {
  display: flex; align-items: center; gap: .3rem;
  padding: .5rem .875rem; border-radius: .5rem;
  font-size: .875rem; font-weight: 500;
  color: #94A3B8; text-decoration: none;
  cursor: pointer; background: none; border: none;
  transition: color .15s, background .15s;
  position: relative; white-space: nowrap;
}
.hdr__link:hover, .hdr__link--btn:hover {
  color: #F8FAFC; background: #1E293B;
}
.hdr__link--active {
  color: #3B82F6 !important; background: rgba(59,130,246,.1) !important;
}
.hdr__active-dot {
  position: absolute; bottom: 2px; left: 50%; transform: translateX(-50%);
  width: 16px; height: 2px; background: #3B82F6; border-radius: 9999px;
  box-shadow: 0 0 8px #3B82F6;
}
.hdr__chevron { opacity: .5; transition: transform .2s; flex-shrink: 0; }
.hdr__item--dropdown:hover .hdr__chevron { transform: rotate(180deg); opacity: 1; }

/* ── Dropdowns ──────────────────────────────────────────────────── */
.hdr__dropdown {
  position: absolute; top: calc(100% + .5rem); left: 0;
  background: #0B1120; border: 1px solid #1E293B;
  border-radius: 1rem; box-shadow: 0 16px 48px rgba(0,0,0,.5);
  opacity: 0; visibility: hidden; pointer-events: none;
  transform: translateY(-8px);
  transition: opacity .2s, transform .2s, visibility .2s;
  z-index: 100;
}
.hdr__item--dropdown:hover .hdr__dropdown,
.hdr__item--dropdown:focus-within .hdr__dropdown {
  opacity: 1; visibility: visible; pointer-events: auto; transform: translateY(0);
}

/* Tools dropdown */
.hdr__dropdown--tools { width: 520px; padding: 1.25rem; }
.hdr__dropdown-header { margin-bottom: 1rem; padding-bottom: .75rem; border-bottom: 1px solid #1E293B; }
.hdr__dropdown-all { font-size: .8125rem; color: #3B82F6; text-decoration: none; font-weight: 500; }
.hdr__dropdown-all:hover { text-decoration: underline; }
.hdr__cat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .25rem; margin-bottom: 1rem; }
.hdr__cat-item {
  display: flex; align-items: center; gap: .5rem;
  padding: .5rem .625rem; border-radius: .5rem;
  text-decoration: none; font-size: .8125rem; color: #94A3B8;
  transition: all .15s;
}
.hdr__cat-item:hover { background: #1E293B; color: #F8FAFC; }
.hdr__cat-emoji { font-size: .875rem; flex-shrink: 0; }
.hdr__cat-label { font-weight: 500; }
.hdr__dropdown-footer {
  display: flex; gap: .5rem; flex-wrap: wrap;
  padding-top: .75rem; border-top: 1px solid #1E293B;
}
.hdr__dropdown-footer a {
  font-size: .75rem; color: #64748B; text-decoration: none;
  padding: .25rem .625rem; background: #1E293B; border-radius: .375rem;
  transition: all .15s;
}
.hdr__dropdown-footer a:hover { color: #F8FAFC; background: #273548; }

/* Explore dropdown */
.hdr__dropdown--explore { right: 0; left: auto; width: 560px; padding: 1.25rem; }
.hdr__explore-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem; }
.hdr__explore-group-label { font-size: .6875rem; text-transform: uppercase; letter-spacing: .08em; color: #475569; margin: 0 0 .5rem; font-weight: 600; }
.hdr__explore-item {
  display: flex; align-items: flex-start; gap: .625rem;
  padding: .5rem .375rem; border-radius: .5rem;
  text-decoration: none; transition: background .15s;
}
.hdr__explore-item:hover { background: #1E293B; }
.hdr__explore-icon { font-size: 1rem; flex-shrink: 0; margin-top: .1rem; }
.hdr__explore-body { display: flex; flex-direction: column; gap: .125rem; }
.hdr__explore-label { font-size: .875rem; font-weight: 600; color: #F8FAFC; }
.hdr__explore-desc  { font-size: .75rem; color: #64748B; }

/* ── Right side ─────────────────────────────────────────────────── */
.hdr__right { display: flex; align-items: center; gap: .75rem; margin-left: auto; flex-shrink: 0; }

.hdr__cta {
  display: inline-flex; align-items: center;
  padding: .5rem 1.125rem;
  background: linear-gradient(135deg, #3B82F6, #8B5CF6);
  color: #fff; border-radius: .625rem;
  font-size: .875rem; font-weight: 600; text-decoration: none;
  transition: all .2s;
}
.hdr__cta:hover { box-shadow: 0 0 20px rgba(59,130,246,.4); transform: translateY(-1px); }
@media (max-width: 1024px) { .hdr__cta { display: none; } }

.hdr__mobile-btn {
  display: none; padding: .5rem; background: none; border: none;
  color: #94A3B8; cursor: pointer; border-radius: .5rem;
  transition: color .15s, background .15s;
}
.hdr__mobile-btn:hover { color: #F8FAFC; background: #1E293B; }
@media (max-width: 768px) { .hdr__mobile-btn { display: flex; align-items: center; justify-content: center; } }

/* ── Mobile menu ────────────────────────────────────────────────── */
.hdr__mobile {
  display: none;
  border-top: 1px solid #1E293B;
  max-height: 0; overflow: hidden;
  transition: max-height .3s ease;
}
.hdr__mobile.is-open { max-height: 600px; }
@media (max-width: 768px) { .hdr__mobile { display: block; } }

.hdr__mobile-nav {
  padding: 1rem 1.5rem 1.5rem;
  display: flex; flex-direction: column; gap: .25rem;
}
.hdr__mobile-link {
  display: block; padding: .625rem .75rem; border-radius: .5rem;
  font-size: .9375rem; font-weight: 500; color: #94A3B8;
  text-decoration: none; transition: all .15s;
}
.hdr__mobile-link:hover { background: #1E293B; color: #F8FAFC; }
.hdr__mobile-div { height: 1px; background: #1E293B; margin: .5rem 0; }
.hdr__mobile-section { font-size: .6875rem; text-transform: uppercase; letter-spacing: .08em; color: #475569; padding: .25rem .75rem 0; margin: 0; }
.hdr__mobile-cta {
  display: block; padding: .75rem 1rem; margin-top: .25rem;
  background: linear-gradient(135deg, #3B82F6, #8B5CF6);
  color: #fff; border-radius: .625rem;
  font-size: .9375rem; font-weight: 600; text-decoration: none;
  text-align: center; transition: all .2s;
}
.hdr__mobile-cta:hover { box-shadow: 0 0 16px rgba(59,130,246,.4); }
</style>

<script>
// Mobile menu toggle
const btn  = document.getElementById("mobile-menu-btn");
const menu = document.getElementById("mobile-menu");
const iconMenu  = document.getElementById("icon-menu");
const iconClose = document.getElementById("icon-close");

btn?.addEventListener("click", () => {
  const open = menu?.classList.toggle("is-open");
  if (btn)  btn.setAttribute("aria-expanded", String(open));
  if (menu) menu.setAttribute("aria-hidden", String(!open));
  if (iconMenu)  iconMenu.style.display  = open ? "none"  : "block";
  if (iconClose) iconClose.style.display = open ? "block" : "none";
});

// Close mobile menu on link click
menu?.querySelectorAll("a").forEach(a => {
  a.addEventListener("click", () => {
    menu.classList.remove("is-open");
    btn?.setAttribute("aria-expanded", "false");
    if (iconMenu)  iconMenu.style.display  = "block";
    if (iconClose) iconClose.style.display = "none";
  });
});

// Close dropdowns on outside click
document.addEventListener("click", (e) => {
  const target = e.target as Element;
  if (!target.closest(".hdr__item--dropdown")) {
    document.querySelectorAll(".hdr__dropdown").forEach(d => {
      (d as HTMLElement).style.cssText = "";
    });
  }
});
</script>
