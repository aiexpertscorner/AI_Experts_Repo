---
import { SITE_NAME, MAIN_NAV } from "@/data/homeConfig";
const path = Astro.url.pathname;
---
<header class="site-header">
  <div class="container hdr">
    <a href="/" class="logo" aria-label={SITE_NAME}>
      <img
        src="/logos/Logo_icon_dark.png"
        alt={SITE_NAME}
        width="36"
        height="36"
        class="logo-img"
        loading="eager"
      />
      <span class="logo-text">
        <strong>AIExperts</strong><span class="logo-corner">Corner</span><span class="logo-dot">.com</span>
      </span>
    </a>

    <nav class="dnav" aria-label="Main navigation">
      {MAIN_NAV.map(n => (
        <a
          href={n.soon ? undefined : n.href}
          class:list={["nl", { active: path.startsWith(n.href), soon: n.soon }]}
          aria-disabled={n.soon ? "true" : undefined}
        >
          {n.label}
          {n.soon && <span class="hub-soon">Soon</span>}
        </a>
      ))}
    </nav>

    <div class="hdr-r">
      <a href="/submit-tool" class="btn btn-ghost btn-sm">Submit Tool</a>
      <button class="mbtn" id="mbtn" aria-label="Toggle menu" aria-expanded="false">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="mnav" id="mnav" hidden>
    <div class="container">
      {MAIN_NAV.map(n => (
        <a
          href={n.soon ? undefined : n.href}
          class:list={["mnl", { active: path.startsWith(n.href) }]}
        >
          {n.label}
          {n.soon && <span class="hub-soon">Soon</span>}
        </a>
      ))}
      <a href="/submit-tool" class="btn btn-primary btn-sm" style="margin-top:1rem;display:inline-flex">
        Submit a Tool
      </a>
    </div>
  </div>
</header>

<style>
.site-header {
  position:sticky;top:0;z-index:100;
  background:rgba(8,13,26,.90);
  backdrop-filter:blur(14px) saturate(1.5);
  border-bottom:1px solid var(--c-border);
}
.hdr {
  display:flex;align-items:center;gap:var(--sp-6);
  height:var(--header-h);
}
.logo {
  display:flex;align-items:center;gap:10px;
  text-decoration:none;flex-shrink:0;
}
.logo-img { width:36px;height:36px;object-fit:contain }
.logo-text {
  font-family:var(--font-display);font-size:var(--text-base);
  font-weight:400;color:var(--c-text);letter-spacing:-.01em;
}
.logo-text strong { font-weight:800 }
.logo-corner { font-weight:600 }
.logo-dot { color:var(--c-brand-light);font-weight:700 }
.dnav { display:flex;align-items:center;gap:2px;flex:1 }
.nl {
  font-family:var(--font-display);font-size:var(--text-sm);font-weight:500;
  color:var(--c-text-2);padding:6px 12px;border-radius:var(--r-sm);
  text-decoration:none;transition:all var(--t-fast);
  display:flex;align-items:center;gap:4px;
}
.nl:hover { color:var(--c-text);background:var(--c-bg-3) }
.nl.active { color:var(--c-text) }
.nl.soon   { opacity:.5;cursor:default;pointer-events:none }
.hdr-r { display:flex;align-items:center;gap:var(--sp-2);margin-left:auto }
.mbtn  { display:none;background:none;border:none;color:var(--c-text-2);cursor:pointer;padding:6px }
.mnav  { background:var(--c-bg-2);border-top:1px solid var(--c-border);padding:var(--sp-4) 0 }
.mnl   {
  display:flex;align-items:center;gap:6px;padding:10px 0;
  color:var(--c-text-2);text-decoration:none;
  font-family:var(--font-display);font-size:var(--text-base);
  border-bottom:1px solid var(--c-border);
}
.mnl.active { color:var(--c-text) }
@media(max-width:768px) {
  .dnav { display:none }
  .mbtn { display:flex }
}
</style>
<script>
const btn = document.getElementById('mbtn');
const nav = document.getElementById('mnav');
btn?.addEventListener('click', () => {
  const open = nav?.hasAttribute('hidden');
  open ? nav?.removeAttribute('hidden') : nav?.setAttribute('hidden', '');
  btn.setAttribute('aria-expanded', open ? 'true' : 'false');
});
</script>
