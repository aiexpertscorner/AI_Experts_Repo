---
import { SITE_NAME, MAIN_NAV } from "@/data/homeConfig";
const path = Astro.url.pathname;
const isHome = path === "/";
---
<header class="site-header" id="site-header">
  <div class="container hdr">
    <!-- Logo -->
    <a href="/" class="logo" aria-label={SITE_NAME}>
      <div class="logo-icon">
        <img src="/logos/Logo_icon_dark.png" alt="" width="28" height="28" loading="eager"/>
      </div>
      <span class="logo-text">
        <span class="logo-ai">AI</span><span class="logo-experts">Experts</span><span class="logo-corner">Corner</span><span class="logo-tld">.com</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="dnav" aria-label="Main navigation">
      {MAIN_NAV.map(n => (
        <a
          href={n.soon ? undefined : n.href}
          class:list={["nl", {
            active: n.href !== "/" && path.startsWith(n.href),
            soon: n.soon
          }]}
          aria-disabled={n.soon ? "true" : undefined}
        >
          {n.label}
          {n.soon && <span class="hub-soon">Soon</span>}
        </a>
      ))}
    </nav>

    <!-- Right side -->
    <div class="hdr-r">
      <a href="/ai-tools" class="hdr-search-btn" aria-label="Search tools">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <span>Search</span>
      </a>
      <a href="/submit-tool" class="btn btn-primary btn-sm">Submit Tool</a>
      <button class="mbtn" id="mbtn" aria-label="Toggle menu" aria-expanded="false">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" id="icon-menu">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div class="mnav" id="mnav" hidden>
    <div class="container mnav-inner">
      {MAIN_NAV.map(n => (
        <a href={n.soon ? undefined : n.href} class:list={["mnl", { active: path.startsWith(n.href) }]}>
          {n.label}
          {n.soon && <span class="hub-soon">Soon</span>}
        </a>
      ))}
      <div class="mnav-ctas">
        <a href="/ai-tools" class="btn btn-secondary btn-sm" style="flex:1">🔍 Search tools</a>
        <a href="/submit-tool" class="btn btn-primary btn-sm" style="flex:1">Submit Tool</a>
      </div>
    </div>
  </div>
</header>

<style>
/* ── Header shell ──────────────────────────────────────────── */
.site-header {
  position: sticky;
  top: 0;
  z-index: var(--z-header);
  background: rgba(7,12,24,.88);
  backdrop-filter: blur(20px) saturate(1.6);
  -webkit-backdrop-filter: blur(20px) saturate(1.6);
  border-bottom: 1px solid var(--c-border-subtle);
}

/* Subtle top accent line */
.site-header::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent 0%, rgba(79,110,247,.4) 30%, rgba(124,58,237,.4) 70%, transparent 100%);
}

.hdr {
  display: flex;
  align-items: center;
  gap: var(--sp-6);
  height: var(--header-h);
}

/* ── Logo ──────────────────────────────────────────────────── */
.logo {
  display: flex;
  align-items: center;
  gap: 9px;
  text-decoration: none;
  flex-shrink: 0;
  transition: opacity var(--t-fast);
}
.logo:hover { opacity: .85 }
.logo-icon {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: var(--c-brand-glow);
  border: 1px solid rgba(79,110,247,.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.logo-icon img { width: 22px; height: 22px }
.logo-text {
  font-family: var(--font-display);
  font-size: .9375rem;
  font-weight: 400;
  letter-spacing: -.02em;
  line-height: 1;
}
.logo-ai      { font-weight: 800; color: var(--c-brand-light) }
.logo-experts { font-weight: 700; color: var(--c-text) }
.logo-corner  { font-weight: 500; color: var(--c-text-2) }
.logo-tld     { font-weight: 400; color: var(--c-text-3) }

/* ── Desktop nav ───────────────────────────────────────────── */
.dnav {
  display: flex;
  align-items: center;
  gap: 2px;
  flex: 1;
}
.nl {
  display: flex;
  align-items: center;
  gap: 4px;
  font-family: var(--font-display);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--c-text-2);
  padding: 6px 11px;
  border-radius: var(--r-md);
  text-decoration: none;
  transition: color var(--t-fast), background var(--t-fast);
  white-space: nowrap;
  letter-spacing: -.01em;
}
.nl:hover         { color: var(--c-text); background: rgba(255,255,255,.05) }
.nl.active        { color: var(--c-text) }
.nl.soon          { opacity: .4; cursor: default; pointer-events: none }

/* ── Right side ────────────────────────────────────────────── */
.hdr-r {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  margin-left: auto;
  flex-shrink: 0;
}
.hdr-search-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: var(--text-sm);
  font-weight: 500;
  font-family: var(--font-display);
  color: var(--c-text-3);
  background: var(--c-bg-3);
  border: 1px solid var(--c-border);
  padding: 6px 12px;
  border-radius: var(--r-md);
  text-decoration: none;
  transition: all var(--t-fast);
}
.hdr-search-btn:hover { color: var(--c-text-2); border-color: var(--c-border-hover) }
.mbtn {
  display: none;
  background: none;
  border: none;
  color: var(--c-text-2);
  cursor: pointer;
  padding: 6px;
  border-radius: var(--r-sm);
  transition: color var(--t-fast);
}
.mbtn:hover { color: var(--c-text) }

/* ── Mobile nav ────────────────────────────────────────────── */
.mnav {
  background: var(--c-bg-2);
  border-top: 1px solid var(--c-border);
  padding: var(--sp-4) 0;
}
.mnav-inner { display: flex; flex-direction: column; gap: var(--sp-1) }
.mnl {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 11px var(--sp-2);
  color: var(--c-text-2);
  text-decoration: none;
  font-family: var(--font-display);
  font-size: var(--text-base);
  font-weight: 500;
  border-radius: var(--r-md);
  transition: all var(--t-fast);
}
.mnl:hover  { background: var(--c-bg-3); color: var(--c-text) }
.mnl.active { color: var(--c-text) }
.mnav-ctas  { display: flex; gap: var(--sp-3); padding-top: var(--sp-4) }

/* ── Responsive ────────────────────────────────────────────── */
@media (max-width: 900px) {
  .dnav            { display: none }
  .hdr-search-btn span { display: none }
  .mbtn            { display: flex }
}
@media (max-width: 480px) {
  .hdr-search-btn  { display: none }
}
</style>

<script>
const btn = document.getElementById('mbtn');
const nav = document.getElementById('mnav');
btn?.addEventListener('click', () => {
  const open = nav?.hasAttribute('hidden');
  open ? nav?.removeAttribute('hidden') : nav?.setAttribute('hidden', '');
  btn.setAttribute('aria-expanded', open ? 'true' : 'false');
});
</script>
