---
import { MAIN_NAV, SITE_NAME } from "@/data/homeConfig";
const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-50 w-full bg-[#0B0F19]/80 backdrop-blur-xl border-b border-[#1E293B]" id="site-header">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <div class="flex items-center">
        <a href="/" class="flex items-center group transition-transform hover:scale-[1.02]" aria-label={`${SITE_NAME} home`}>
          <div class="relative flex items-center justify-center w-10 h-10 mr-3 rounded-xl bg-gradient-to-br from-[#3B82F6] to-[#8B5CF6] p-[1px]">
            <div class="flex items-center justify-center w-full h-full bg-[#0B0F19] rounded-[11px]">
              <img src="/logos/Logo_icon_dark.png" alt="" width="24" height="24" class="relative z-10" loading="eager" />
            </div>
            <div class="absolute inset-0 bg-[#3B82F6]/20 blur-lg group-hover:bg-[#3B82F6]/40 transition-colors rounded-full"></div>
          </div>
          <span class="text-xl font-bold tracking-tight text-[#F8FAFC]">
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-[#3B82F6] to-[#22D3EE]">AI</span>ExpertsCorner<span class="text-[#64748B] text-sm font-medium">.com</span>
          </span>
        </a>
      </div>

      <nav class="hidden md:flex items-center space-x-1" aria-label="Main navigation">
        {MAIN_NAV.map((item) => {
          const active = item.href === "/" ? pathname === "/" : pathname.startsWith(item.href);
          return (
            <a
              href={item.soon ? "#" : item.href}
              class:list={[
                "relative px-4 py-2 text-sm font-medium transition-all duration-200 rounded-lg group",
                active ? "text-[#3B82F6] bg-[#3B82F6]/10" : "text-[#94A3B8] hover:text-[#F8FAFC] hover:bg-[#1E293B]",
                item.soon ? "opacity-50 cursor-not-allowed pointer-events-none" : ""
              ]}
            >
              {item.label}
              {item.soon && (
                <span class="ml-2 text-[10px] uppercase tracking-widest px-1.5 py-0.5 rounded bg-[#1A2233] text-[#64748B] border border-[#334155]">Soon</span>
              )}
              {active && (
                <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-0.5 bg-[#3B82F6] rounded-full shadow-[0_0_8px_#3B82F6]"></span>
              )}
            </a>
          );
        })}
      </nav>

      <div class="flex items-center space-x-4">
        <a 
          href="/submit-tool" 
          class="hidden lg:inline-flex items-center justify-center px-5 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-[#3B82F6] to-[#8B5CF6] rounded-xl hover:shadow-[0_0_20px_rgba(59,130,246,0.4)] transition-all duration-300 transform hover:-translate-y-0.5 active:scale-95"
        >
          Submit Tool
        </a>
        <button class="md:hidden p-2 text-[#94A3B8] hover:text-[#F8FAFC]" aria-label="Toggle menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </button>
      </div>
    </div>
  </div>
</header>