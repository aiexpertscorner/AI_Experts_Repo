---
import { SITE_NAME, FOOTER_LINKS } from "@/data/homeConfig";
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="ft-top-glow" aria-hidden="true"></div>

  <div class="container">

    <!-- Newsletter row -->
    <div class="ft-nl">
      <div class="ft-nl-text">
        <strong>Stay ahead with AI</strong>
        <p>Weekly digest of the best new tools, guides and AI news.</p>
      </div>
      <form class="ft-nl-form" onsubmit="return false">
        <input
          type="email"
          placeholder="your@email.com"
          class="input ft-nl-input"
          aria-label="Email for newsletter"
        />
        <button type="submit" class="btn btn-primary btn-sm">Subscribe Free</button>
      </form>
    </div>

    <div class="ft-divider" aria-hidden="true"></div>

    <!-- Main grid -->
    <div class="ft-grid">

      <!-- Brand column -->
      <div class="ft-brand">
        <a href="/" class="ft-logo" aria-label={SITE_NAME}>
          <div class="ft-logo-icon" aria-hidden="true">
            <img src="/logos/Logo_icon_dark.png" alt="" width="18" height="18" loading="lazy"/>
          </div>
          <span class="ft-logo-text">
            <span class="logo-ai">AI</span><span class="logo-experts">Experts</span><span class="logo-corner">Corner</span>
          </span>
        </a>

        <p class="ft-tagline">The most complete AI tools directory. Find, compare and discover the best AI tools for every workflow.</p>

        <div class="ft-stats">
          <div class="ft-stat">
            <strong>19,000+</strong>
            <span>AI Tools</span>
          </div>
          <div class="ft-stat">
            <strong>23</strong>
            <span>Categories</span>
          </div>
          <div class="ft-stat">
            <strong>Daily</strong>
            <span>Updates</span>
          </div>
        </div>
      </div>

      <!-- Link columns -->
      {Object.entries(FOOTER_LINKS).map(([col, links]) => (
        <div class="ft-col">
          <h4 class="ft-col-head">{col}</h4>
          <ul>
            {links.map(l => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}

    </div>

    <!-- Bottom bar -->
    <div class="ft-bottom">
      <p>© {year} {SITE_NAME}. All rights reserved.</p>
      <p class="ft-disc">Affiliate links may be present. Tool data maintained independently.</p>
    </div>

  </div>
</footer>

<style>
/* ── Shell ─────────────────────────────────────────────────────*/
.site-footer {
  position: relative;
  background: var(--c-bg-2);
  border-top: 1px solid var(--c-border-subtle);
  margin-top: var(--sp-24);
  padding: var(--sp-12) 0 var(--sp-8);
  overflow: hidden;
}

/* Ambient top glow from border */
.ft-top-glow {
  position: absolute;
  top: -1px; left: 10%; right: 10%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(79,110,247,.40) 35%, rgba(124,58,237,.30) 65%, transparent);
  pointer-events: none;
}

/* ── Newsletter row ────────────────────────────────────────────*/
.ft-nl {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-8);
  padding: var(--sp-8) var(--sp-8);
  background: var(--c-bg-3);
  border: 1px solid var(--c-border);
  border-radius: var(--r-xl);
  margin-bottom: var(--sp-10);
}
.ft-nl-text strong {
  display: block;
  font-family: var(--font-display);
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 4px;
}
.ft-nl-text p { font-size: var(--text-sm); color: var(--c-text-3); margin: 0 }
.ft-nl-form {
  display: flex;
  gap: var(--sp-2);
  flex-shrink: 0;
  align-items: center;
}
.ft-nl-input {
  width: 220px;
  padding: 8px 14px;
  font-size: var(--text-sm);
  border-radius: var(--r-lg);
}

/* ── Divider ───────────────────────────────────────────────────*/
.ft-divider {
  height: 1px;
  background: var(--c-border-subtle);
  margin-bottom: var(--sp-10);
}

/* ── Main grid ─────────────────────────────────────────────────*/
.ft-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: var(--sp-10);
  margin-bottom: var(--sp-10);
}

/* ── Brand column ──────────────────────────────────────────────*/
.ft-brand { display: flex; flex-direction: column; gap: var(--sp-4) }

.ft-logo {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  text-decoration: none;
  transition: opacity var(--t-fast);
}
.ft-logo:hover { opacity: .8 }
.ft-logo-icon {
  width: 28px;
  height: 28px;
  border-radius: var(--r-sm);
  background: linear-gradient(135deg, rgba(79,110,247,.15) 0%, rgba(124,58,237,.10) 100%);
  border: 1px solid rgba(79,110,247,.18);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.ft-logo-icon img { width: 18px; height: 18px }
.ft-logo-text {
  font-family: var(--font-display);
  font-size: .875rem;
  font-weight: 400;
  letter-spacing: -.02em;
  line-height: 1;
}
.ft-logo-text .logo-ai      { font-weight: 800; color: var(--c-brand-light) }
.ft-logo-text .logo-experts { font-weight: 700; color: var(--c-text) }
.ft-logo-text .logo-corner  { font-weight: 500; color: var(--c-text-3) }

.ft-tagline {
  font-size: var(--text-sm);
  color: var(--c-text-3);
  max-width: 250px;
  line-height: var(--lh-base);
  margin: 0;
}

.ft-stats { display: flex; gap: var(--sp-5) }
.ft-stat  { display: flex; flex-direction: column; gap: 2px }
.ft-stat strong {
  font-family: var(--font-display);
  font-size: var(--text-sm);
  font-weight: 800;
  color: var(--c-brand-light);
  letter-spacing: -.02em;
}
.ft-stat span {
  font-size: var(--text-2xs);
  color: var(--c-text-4);
  text-transform: uppercase;
  letter-spacing: .07em;
  font-weight: 600;
}

/* ── Link columns ──────────────────────────────────────────────*/
.ft-col-head {
  font-family: var(--font-display);
  font-size: var(--text-2xs);
  font-weight: 700;
  letter-spacing: .10em;
  text-transform: uppercase;
  color: var(--c-text-3);
  margin-bottom: var(--sp-4);
}
.ft-col ul { display: flex; flex-direction: column; gap: var(--sp-3) }
.ft-col a {
  font-size: var(--text-sm);
  color: var(--c-text-3);
  text-decoration: none;
  transition: color var(--t-fast);
}
.ft-col a:hover { color: var(--c-text-2) }

/* ── Bottom bar ────────────────────────────────────────────────*/
.ft-bottom {
  border-top: 1px solid var(--c-border-subtle);
  padding-top: var(--sp-6);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--sp-3);
}
.ft-bottom p { font-size: var(--text-xs); color: var(--c-text-4); margin: 0 }
.ft-disc     { max-width: 380px; text-align: right }

/* ── Responsive ────────────────────────────────────────────────*/
@media (max-width: 1000px) {
  .ft-grid { grid-template-columns: 1.5fr 1fr 1fr }
  .ft-col:last-child { display: none }
}
@media (max-width: 720px) {
  .ft-grid { grid-template-columns: 1fr 1fr }
  .ft-nl { flex-direction: column; align-items: flex-start; gap: var(--sp-5) }
  .ft-nl-input { width: 180px }
}
@media (max-width: 500px) {
  .ft-grid { grid-template-columns: 1fr }
  .ft-disc { text-align: left }
  .ft-nl-form { flex-direction: column; width: 100% }
  .ft-nl-input { width: 100% }
  .ft-nl-form .btn { width: 100%; justify-content: center }
}
</style>
