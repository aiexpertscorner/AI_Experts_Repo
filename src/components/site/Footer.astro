---
import { FOOTER_LINKS, SITE_DESC, SITE_NAME } from "@/data/homeConfig";
---

<footer class="bg-[#0B0F19] border-t border-[#1E293B] pt-20 pb-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-12 mb-20">
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center mb-6" aria-label={`${SITE_NAME} home`}>
          <span class="text-2xl font-bold tracking-tight text-[#F8FAFC]">
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-[#3B82F6] to-[#22D3EE]">AI</span>ExpertsCorner<span class="text-[#64748B] text-lg font-medium">.com</span>
          </span>
        </a>
        <p class="text-[#94A3B8] text-base leading-relaxed max-w-sm mb-8">
          {SITE_DESC}
        </p>
        <div class="flex space-x-4">
          {[1, 2, 3, 4].map((i) => (
            <a href="#" class="w-10 h-10 flex items-center justify-center rounded-lg bg-[#121826] border border-[#1E293B] text-[#94A3B8] hover:text-[#3B82F6] hover:border-[#3B82F6] transition-all duration-300">
              <span class="sr-only">Social Link {i}</span>
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12c0-5.523-4.477-10-10-10z"/></svg>
            </a>
          ))}
        </div>
      </div>

      {Object.entries(FOOTER_LINKS).map(([title, links]) => (
        <div class="lg:col-span-1">
          <h3 class="text-[#F8FAFC] font-semibold tracking-wider text-sm uppercase mb-6">
            {title}
          </h3>
          <ul class="space-y-4">
            {links.map((link) => (
              <li>
                <a href={link.href} class="text-[#94A3B8] hover:text-[#3B82F6] text-sm transition-colors duration-200 flex items-center group">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#3B82F6] opacity-0 group-hover:opacity-100 transition-opacity mr-2"></span>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="pt-10 border-t border-[#1E293B] flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex flex-col items-center md:items-start">
        <p class="text-[#64748B] text-sm">
          © {new Date().getFullYear()} {SITE_NAME}. All rights reserved.
        </p>
        <p class="text-[#64748B] text-xs mt-1">
          Discovering the future of productivity through artificial intelligence.
        </p>
      </div>
      <div class="flex items-center space-x-8">
        <a href="/privacy" class="text-[#64748B] hover:text-[#F8FAFC] text-xs transition-colors">Privacy Policy</a>
        <a href="/terms" class="text-[#64748B] hover:text-[#F8FAFC] text-xs transition-colors">Terms of Service</a>
        <a href="/sitemap-index.xml" class="text-[#64748B] hover:text-[#F8FAFC] text-xs transition-colors">Sitemap</a>
      </div>
    </div>
  </div>
</footer>