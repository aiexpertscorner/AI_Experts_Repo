---
import { SITE_NAME, FOOTER_LINKS } from "@/data/homeConfig";
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="ft-grid">
      <!-- Brand col -->
      <div class="ft-brand">
        <a href="/" class="ft-logo">
          <img src="/logos/logo_dark.png" alt={SITE_NAME} width="160" height="44" loading="lazy"/>
        </a>
        <p>The most complete AI tools directory. Find, compare and discover the best AI tools for every workflow.</p>
        <div class="ft-stats">
          <div class="ft-stat">
            <strong>19,000+</strong>
            <span>AI Tools</span>
          </div>
          <div class="ft-stat">
            <strong>23</strong>
            <span>Categories</span>
          </div>
          <div class="ft-stat">
            <strong>Daily</strong>
            <span>Updates</span>
          </div>
        </div>
      </div>

      <!-- Link cols -->
      {Object.entries(FOOTER_LINKS).map(([col, links]) => (
        <div class="ft-col">
          <h4>{col}</h4>
          <ul>
            {links.map(l => <li><a href={l.href}>{l.label}</a></li>)}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="ft-bottom">
      <p>© {year} {SITE_NAME}. All rights reserved.</p>
      <p class="ft-disc">AI tool data is collected and maintained independently. Affiliate links may be present.</p>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: var(--c-bg-2);
  border-top: 1px solid var(--c-border);
  margin-top: var(--sp-24);
  padding: var(--sp-16) 0 var(--sp-8);
  position: relative;
}
.site-footer::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(79,110,247,.3) 50%, transparent);
}

.ft-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: var(--sp-12);
  margin-bottom: var(--sp-12);
}
@media (max-width: 900px) { .ft-grid { grid-template-columns: 1fr 1fr } }
@media (max-width: 540px) { .ft-grid { grid-template-columns: 1fr } }

/* Brand */
.ft-brand { display: flex; flex-direction: column; gap: var(--sp-4) }
.ft-logo img { max-width: 160px; opacity: .85 }
.ft-brand p { font-size: var(--text-sm); color: var(--c-text-3); max-width: 260px; line-height: 1.6 }

.ft-stats { display: flex; gap: var(--sp-5) }
.ft-stat  { display: flex; flex-direction: column; gap: 2px }
.ft-stat strong { font-family: var(--font-display); font-size: var(--text-sm); font-weight: 700; color: var(--c-brand-light) }
.ft-stat span   { font-size: 10px; color: var(--c-text-4); text-transform: uppercase; letter-spacing: .05em; font-weight: 600 }

/* Link cols */
.ft-col h4 {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--c-text-3);
  margin-bottom: var(--sp-4);
}
.ft-col ul { display: flex; flex-direction: column; gap: var(--sp-3) }
.ft-col a  {
  font-size: var(--text-sm);
  color: var(--c-text-3);
  transition: color var(--t-fast);
}
.ft-col a:hover { color: var(--c-text-2) }

/* Bottom */
.ft-bottom {
  border-top: 1px solid var(--c-border-subtle);
  padding-top: var(--sp-6);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--sp-3);
}
.ft-bottom p { font-size: var(--text-xs); color: var(--c-text-4) }
.ft-disc     { max-width: 420px; text-align: right }
@media (max-width: 600px) { .ft-disc { text-align: left } }
</style>
