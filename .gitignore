# ============================================================
# AIExpertsCorner — .gitignore
# Astro repo: AI_Experts_V3_PROD/AI_Experts_Repo
# ============================================================

# ── Node ─────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Astro build output ────────────────────────────────────────
dist/
.astro/

# ── Environment — NEVER commit real keys ─────────────────────
.env
.env.local
.env.*.local
.env.production

# ── OS / Editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json

# ============================================================
# DATA BUILD — Large files not needed in repo
# Cloudflare builds from source; these are generated by pipeline
# ============================================================

# ── GIANT unused payload files (374MB total, no page imports them) ──
src/data/build/page-payloads/tool-pages.json
src/data/build/page-payloads/tool-pages-rich.json
src/data/build/page-payloads/compare-pages.json
src/data/build/page-payloads/use-case-pages.json
src/data/build/page-payloads/workflow-pages.json

# ── Logo verification reports (generated by fix-logos.mjs) ───
src/data/build/logos.json
src/data/build/logos-ok.json
src/data/build/logos-missing.json
src/data/build/logos-verification-report.json

# ── Heavy lookup maps — regenerated by pipeline ───────────────
# These are large (30MB+) and only used internally by the pipeline,
# not by Astro pages directly.
src/data/build/alternatives-map.json
src/data/build/related-map.json
src/data/build/compare-map.json
src/data/build/tool-map.json
src/data/build/alternatives-page-data.json
src/data/build/compare-page-data.json
src/data/build/tool-page-data.json
src/data/build/prompt-library-map.json

# ── Audit / report files — not part of the build ─────────────
src/data/build/data-layer-audit.json
src/data/build/data-layer-audit.md
src/data/build/deep-content-stats.json
src/data/build/tool-enrichment-report.json
src/data/build/tools-audit-report.json
src/data/build/skipped-records.json
src/data/build/project-data-inventory.json
src/data/build/project-data-inventory.md

# ── Source tool database — lives in pipeline repo, not here ──
# If tools_source.json is a copy from the pipeline, gitignore it.
# If it's the canonical source here, REMOVE this line.
# src/data/tools_source.json

# ============================================================
# WHAT IS COMMITTED (needed for Astro build on Cloudflare)
# ============================================================
# src/data/build/logo-map.json               ← logos voor alle tools
# src/data/build/tool-slugs.json             ← getStaticPaths
# src/data/build/tool-paths.json             ← sitemap
# src/data/build/tools/*.json                ← 19k individual tool files
# src/data/build/category-map.json           ← categories
# src/data/build/category-paths.json
# src/data/build/compare-pairs.json          ← compare index
# src/data/build/homepage-data.json
# src/data/build/featured-tools.json
# src/data/build/*-map.json (small ones)     ← dimension pages
# src/data/build/*-paths.json (all)          ← dimension pages
# src/data/build/page-payloads/*.json        ← hub pages
#   (except the tool-pages*.json giants above)